import pytest
import jwt
from datetime import datetime, timedelta, timezone
from httpx import AsyncClient

{% set sample_path = services[0].base_path if services else '/api/items' %}
SAMPLE_PATH = "{{ sample_path }}"


class TestAuthentication:

    @pytest.mark.asyncio
    async def test_no_token_returns_401(self, client: AsyncClient):
        resp = await client.get(SAMPLE_PATH)
        assert resp.status_code == 401

    @pytest.mark.asyncio
    async def test_malformed_token_returns_401(self, client: AsyncClient):
        resp = await client.get(SAMPLE_PATH, headers={"Authorization": "Bearer not.a.valid.jwt"})
        assert resp.status_code == 401

    @pytest.mark.asyncio
    async def test_expired_token_returns_401(self, client: AsyncClient):
        import os
        payload = {
            "sub": "user-id",
            "organization_id": "org-id",
            "exp": (datetime.now(timezone.utc) - timedelta(hours=1)).timestamp(),
        }
        token = jwt.encode(payload, os.environ["JWT_SECRET"], algorithm="HS256")
        resp = await client.get(SAMPLE_PATH, headers={"Authorization": f"Bearer {token}"})
        assert resp.status_code == 401

    @pytest.mark.asyncio
    async def test_wrong_secret_returns_401(self, client: AsyncClient):
        payload = {
            "sub": "user-id",
            "organization_id": "org-id",
            "exp": (datetime.now(timezone.utc) + timedelta(hours=1)).timestamp(),
        }
        token = jwt.encode(payload, "WRONG-SECRET", algorithm="HS256")
        resp = await client.get(SAMPLE_PATH, headers={"Authorization": f"Bearer {token}"})
        assert resp.status_code == 401

    @pytest.mark.asyncio
    async def test_valid_token_returns_200(self, client: AsyncClient, auth_headers: dict):
        resp = await client.get(SAMPLE_PATH, headers=auth_headers)
        assert resp.status_code == 200

