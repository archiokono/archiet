func TestXSSInTextFields(t *testing.T) {
	r := setupTestRouter()
	body := `{"name": "<script>alert('xss')</script>"}`
	req := httptest.NewRequest(http.MethodPost, "{{ api_path | default('/api') }}", strings.NewReader(body))
	req.Header.Set("Content-Type", "application/json")
	w := httptest.NewRecorder()
	r.ServeHTTP(w, req)

	// Should either reject or sanitize
	if w.Code >= 200 && w.Code < 300 {
		if strings.Contains(w.Body.String(), "<script>") {
			t.Error("XSS payload was not sanitized in response")
		}
	}
}

// ── Rate Limiting Tests ──

func TestRateLimitingEnforced(t *testing.T) {
	r := setupTestRouter()
	rateLimited := false

	for i := 0; i < 100; i++ {
		req := httptest.NewRequest(http.MethodGet, "{{ api_path | default('/health') }}", nil)
		w := httptest.NewRecorder()
		r.ServeHTTP(w, req)

		if w.Code == http.StatusTooManyRequests {
			rateLimited = true
			break
		}
	}

	if !rateLimited {
		t.Log("WARNING: Rate limiting not enforced after 100 rapid requests")
	}
}

// ── CORS Tests ──

func TestCORSHeadersPresent(t *testing.T) {
	r := setupTestRouter()
	req := httptest.NewRequest(http.MethodOptions, "{{ api_path | default('/health') }}", nil)
	req.Header.Set("Origin", "http://example.com")
	w := httptest.NewRecorder()
	r.ServeHTTP(w, req)

	expectedHeaders := []string{
		"Access-Control-Allow-Origin",
		"Access-Control-Allow-Methods",
	}
	for _, header := range expectedHeaders {
		if w.Header().Get(header) == "" {
			t.Errorf("Missing CORS header: %s", header)
		}
	}
}
