{# app/modules/solutions_product/templates/go_chi/helm_values.yaml.j2 #}
{# Generates Helm chart values with all deployment parameters. #}
{# Context: solution_id, bundle_id, solution_name, deployment #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE

replicaCount: {{ deployment.scaling.min_replicas | default(1) }}

image:
  repository: {{ solution_name | lower | replace(' ', '-') | replace('_', '-') }}
  tag: "latest"
  pullPolicy: IfNotPresent

service:
  type: ClusterIP
  port: 80
  targetPort: 8080

resources:
  limits:
    cpu: 200m
    memory: 128Mi
  requests:
    cpu: 50m
    memory: 32Mi

autoscaling:
  enabled: true
  minReplicas: {{ deployment.scaling.min_replicas | default(1) }}
  maxReplicas: {{ deployment.scaling.max_replicas | default(3) }}
  targetCPUUtilizationPercentage: {{ deployment.scaling.threshold | default(80) }}

securityContext:
  runAsNonRoot: true
  runAsUser: 65534
  readOnlyRootFilesystem: true
  allowPrivilegeEscalation: false

{% if deployment.database and deployment.database != 'none' %}
database:
  type: {{ deployment.database }}
  host: ""
  port: {% if deployment.database == 'postgresql' %}5432{% elif deployment.database == 'mysql' %}3306{% elif deployment.database == 'mongodb' %}27017{% else %}5432{% endif %}

  name: {{ solution_name | lower | replace(' ', '-') | replace('_', '-') }}
{% endif %}

{% if deployment.cache and deployment.cache != 'none' %}
cache:
  type: {{ deployment.cache }}
  host: ""
  port: {% if deployment.cache == 'redis' %}6379{% else %}11211{% endif %}

{% endif %}

{% if deployment.messaging and deployment.messaging != 'none' %}
messaging:
  type: {{ deployment.messaging }}
  host: ""
  port: {% if deployment.messaging == 'rabbitmq' %}5672{% elif deployment.messaging == 'kafka' %}9092{% else %}443{% endif %}

{% endif %}

observability:
  logging: {{ deployment.observability.logging | default('stdout') }}
  metrics: {{ deployment.observability.metrics | default('prometheus') }}
  traces: {{ deployment.observability.traces | default('jaeger') }}

secretsBackend: {{ deployment.secrets_backend | default('env-vars') }}
