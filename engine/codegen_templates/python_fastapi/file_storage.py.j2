class LocalStorage:
    """Store files on local filesystem. Good for development."""

    def __init__(self, base_path: str):
        self.base_path = Path(base_path)
        self.base_path.mkdir(parents=True, exist_ok=True)

    async def upload(self, file: UploadFile, folder: str = "general") -> StoredFile:
        file_id = str(uuid.uuid4())
        ext = Path(file.filename or "file").suffix
        safe_name = f"{file_id}{ext}"
        dest_dir = self.base_path / folder
        dest_dir.mkdir(parents=True, exist_ok=True)
        dest = dest_dir / safe_name

        content = await file.read()
        if len(content) > MAX_FILE_SIZE_MB * 1024 * 1024:
            raise HTTPException(status_code=status.HTTP_413_REQUEST_ENTITY_TOO_LARGE,
                                detail=f"File exceeds {MAX_FILE_SIZE_MB}MB limit")

        dest.write_bytes(content)
        content_type = file.content_type or mimetypes.guess_type(file.filename or "")[0] or "application/octet-stream"

        return StoredFile(
            id=file_id,
            filename=file.filename or safe_name,
            content_type=content_type,
            size=len(content),
            path=f"{folder}/{safe_name}",
            url=f"/files/{folder}/{safe_name}",
            created_at=datetime.now(timezone.utc).isoformat(),
        )

    async def download(self, path: str) -> Path:
        full = self.base_path / path
        if not full.exists():
            raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail="File not found")
        return full

    async def delete(self, path: str) -> bool:
        full = self.base_path / path
        if full.exists():
            full.unlink()
            return True
        return False

    async def get_url(self, path: str, expires: int = 3600) -> str:
        return f"/files/{path}"


class S3Storage:
    """Store files in S3-compatible storage (AWS S3, MinIO, Cloudflare R2)."""

    def __init__(self):
        try:
            import boto3
            kwargs = {"region_name": S3_REGION}
            if S3_ENDPOINT_URL:
                kwargs["endpoint_url"] = S3_ENDPOINT_URL
            if S3_ACCESS_KEY and S3_SECRET_KEY:
                kwargs["aws_access_key_id"] = S3_ACCESS_KEY
                kwargs["aws_secret_access_key"] = S3_SECRET_KEY
            self.s3 = boto3.client("s3", **kwargs)
            self.bucket = S3_BUCKET
        except ImportError:
            raise RuntimeError("boto3 is required for S3 storage: pip install boto3")

    async def upload(self, file: UploadFile, folder: str = "general") -> StoredFile:
        file_id = str(uuid.uuid4())
        ext = Path(file.filename or "file").suffix
        key = f"{folder}/{file_id}{ext}"

        content = await file.read()
        if len(content) > MAX_FILE_SIZE_MB * 1024 * 1024:
            raise HTTPException(status_code=status.HTTP_413_REQUEST_ENTITY_TOO_LARGE,
                                detail=f"File exceeds {MAX_FILE_SIZE_MB}MB limit")

        content_type = file.content_type or mimetypes.guess_type(file.filename or "")[0] or "application/octet-stream"
        self.s3.put_object(Bucket=self.bucket, Key=key, Body=content, ContentType=content_type)
        url = await self.get_url(key)

        return StoredFile(
            id=file_id,
            filename=file.filename or f"{file_id}{ext}",
            content_type=content_type,
            size=len(content),
            path=key,
            url=url,
            created_at=datetime.now(timezone.utc).isoformat(),
        )

    async def download(self, path: str) -> bytes:
        try:
            response = self.s3.get_object(Bucket=self.bucket, Key=path)
            return response["Body"].read()
        except Exception:
            raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail="File not found")

    async def delete(self, path: str) -> bool:
        try:
            self.s3.delete_object(Bucket=self.bucket, Key=path)
            return True
        except Exception:
            return False

    async def get_url(self, path: str, expires: int = 3600) -> str:
        return self.s3.generate_presigned_url(
            "get_object", Params={"Bucket": self.bucket, "Key": path}, ExpiresIn=expires,
        )


def get_storage():
    """Factory: returns the configured storage backend."""
    if STORAGE_BACKEND == "s3" and S3_BUCKET:
        return S3Storage()
    return LocalStorage(STORAGE_LOCAL_PATH)


# ── API routes ─────────────────────────────────────────────────────────────────

router = APIRouter(prefix="/files", tags=["files"])


@router.post("/upload", status_code=status.HTTP_201_CREATED)
async def upload_file(
    file: UploadFile = File(...),
    folder: str = "general",
):
    """Upload a file. Returns file metadata with download URL."""
    storage = get_storage()
    result = await storage.upload(file, folder)
    return {
        "id": result.id,
        "filename": result.filename,
        "content_type": result.content_type,
        "size": result.size,
        "url": result.url,
        "created_at": result.created_at,
    }


@router.get("/{folder}/{filename}")
async def download_file(folder: str, filename: str):
    """Download a file by path."""
    storage = get_storage()
    path = f"{folder}/{filename}"
    if isinstance(storage, LocalStorage):
        file_path = await storage.download(path)
        return FileResponse(str(file_path))
    else:
        content = await storage.download(path)
        content_type = mimetypes.guess_type(filename)[0] or "application/octet-stream"
        from fastapi.responses import Response
        return Response(content=content, media_type=content_type)


@router.delete("/{folder}/{filename}", status_code=status.HTTP_204_NO_CONTENT)
async def delete_file(folder: str, filename: str):
    """Delete a file."""
    storage = get_storage()
    await storage.delete(f"{folder}/{filename}")
