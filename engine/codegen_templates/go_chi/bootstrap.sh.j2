{#- app/modules/solutions_product/templates/go_chi/bootstrap.sh.j2 -#}
{#- One-command bootstrap for the generated Go/Chi project. -#}
{#- Context: project_name, solution_id, bundle_id, db_name, port -#}
#!/usr/bin/env bash
set -euo pipefail

PROJECT="{{ project_name }}"
PORT="{{ port | default('8080') }}"

echo "=== Bootstrapping $PROJECT ==="
echo "    Generated by A.R.C.H.I.E. (Solution #{{ solution_id }})"
echo ""

# ── Check prerequisites ───────────────────────────────────────────────────

check_cmd() {
    command -v "$1" >/dev/null 2>&1 || { echo "ERROR: $1 is required but not installed."; exit 1; }
}

check_cmd docker
check_cmd "docker compose" || check_cmd docker-compose

echo "[1/5] Prerequisites OK"

# ── Create .env from template ─────────────────────────────────────────────

if [ ! -f .env ]; then
    cp .env.example .env
    echo "[2/5] Created .env from template — edit with your values"
else
    echo "[2/5] .env already exists — skipping"
fi

# ── Start services ────────────────────────────────────────────────────────

echo "[3/5] Starting services..."
docker compose up -d --build

# ── Wait for database ────────────────────────────────────────────────────

echo "[4/5] Waiting for database..."
for i in $(seq 1 30); do
    if docker compose exec -T db pg_isready -U postgres >/dev/null 2>&1; then
        echo "       Database ready"
        break
    fi
    if [ "$i" -eq 30 ]; then
        echo "ERROR: Database did not become ready in 30 seconds"
        exit 1
    fi
    sleep 1
done

# Run migrations
echo "       Running migrations..."
docker compose run --rm app ./migrate 2>/dev/null || echo "       (no migrations to run)"

# Seed data
echo "       Seeding sample data..."
docker compose run --rm app ./seed 2>/dev/null || echo "       (no seed binary found)"

# ── Verify ────────────────────────────────────────────────────────────────

echo "[5/5] Verifying..."
sleep 3
if curl -sf "http://localhost:${PORT}/health" >/dev/null 2>&1; then
    echo "       Health: OK"
else
    echo "       Health: FAILED (service may still be starting)"
fi

if curl -sf "http://localhost:${PORT}/readyz" >/dev/null 2>&1; then
    echo "       Ready:  OK"
else
    echo "       Ready:  FAILED (service may still be starting)"
fi

echo ""
echo "=== $PROJECT is running ==="
echo "  App:     http://localhost:${PORT}"
echo "  Health:  http://localhost:${PORT}/health"
echo ""
