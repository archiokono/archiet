    fireEvent.changeText(emailInput, 'user@example.com');
    fireEvent.changeText(passInput, 'Valid@123');
    fireEvent.press(screen.getByText(/sign in|log in/i));
    await waitFor(() => expect(mockReplace).toHaveBeenCalled());
    // Token must be stored in SecureStore
    expect(SecureStore.setItemAsync).toHaveBeenCalled();
    // Verify the value stored is a token (not the password)
    const calls = (SecureStore.setItemAsync as jest.Mock).mock.calls;
    const storedValues = calls.map((c: unknown[]) => c[1] as string);
    storedValues.forEach(val => {
      expect(val).not.toBe('Valid@123');
    });
  });

