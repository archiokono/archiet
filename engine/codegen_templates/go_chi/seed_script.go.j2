//
// Seed script — load sample data into the database.
//
// Usage:
//   go run seed.go                          # Uses DATABASE_URL from environment
//   go run seed.go -url "postgres://..."    # Uses explicit connection string

package main

import (
	"database/sql"
	"flag"
	"fmt"
	"os"

	_ "github.com/lib/pq"
)

func main() {
	dbURL := flag.String("url", os.Getenv("DATABASE_URL"), "PostgreSQL connection string")
	seedFile := flag.String("file", "seed_data.sql", "Path to SQL seed file")
	flag.Parse()

	if *dbURL == "" {
		fmt.Fprintln(os.Stderr, "ERROR: No database URL provided. Set DATABASE_URL or use -url.")
		os.Exit(1)
	}

	sqlBytes, err := os.ReadFile(*seedFile)
	if err != nil {
		fmt.Fprintf(os.Stderr, "ERROR: Could not read seed file %s: %v\n", *seedFile, err)
		os.Exit(1)
	}

	fmt.Println("Connecting to database...")
	db, err := sql.Open("postgres", *dbURL)
	if err != nil {
		fmt.Fprintf(os.Stderr, "ERROR: Could not connect: %v\n", err)
		os.Exit(1)
	}
	defer db.Close()

	if err := db.Ping(); err != nil {
		fmt.Fprintf(os.Stderr, "ERROR: Could not ping database: %v\n", err)
		os.Exit(1)
	}

	_, err = db.Exec(string(sqlBytes))
	if err != nil {
		fmt.Fprintf(os.Stderr, "ERROR: Seed failed: %v\n", err)
		os.Exit(1)
	}

	fmt.Println("Seed data loaded successfully.")
}
