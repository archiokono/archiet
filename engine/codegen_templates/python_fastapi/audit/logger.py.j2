            return await call_next(request)

        # Extract entity type from URL path (e.g., /api/orders/123 → orders)
        path_parts = [p for p in request.url.path.split("/") if p]
        entity_type = None
        entity_id = None
        for i, part in enumerate(path_parts):
            if part == "api" and i + 1 < len(path_parts):
                entity_type = path_parts[i + 1].rstrip("s")  # plural → singular
