# ── WebSocket Connection Manager ───────────────────────────────────────────────

class ConnectionManager:
    """Manages active WebSocket connections per user."""

    def __init__(self):
        self.active: dict[str, list[WebSocket]] = {}

    async def connect(self, websocket: WebSocket, user_id: str):
        await websocket.accept()
        if user_id not in self.active:
            self.active[user_id] = []
        self.active[user_id].append(websocket)
        logger.info("ws: user %s connected (%d total)", user_id, len(self.active[user_id]))

    def disconnect(self, websocket: WebSocket, user_id: str):
        if user_id in self.active:
            self.active[user_id] = [ws for ws in self.active[user_id] if ws != websocket]
            if not self.active[user_id]:
                del self.active[user_id]

    async def send_to_user(self, user_id: str, message: dict):
        """Send a message to all connections for a user."""
        for ws in self.active.get(user_id, []):
            try:
                await ws.send_json(message)
            except Exception:
                pass

    async def broadcast(self, message: dict, exclude_user: Optional[str] = None):
        """Broadcast a message to all connected users."""
        for user_id, connections in self.active.items():
            if user_id == exclude_user:
                continue
            for ws in connections:
                try:
                    await ws.send_json(message)
                except Exception:
                    pass


manager = ConnectionManager()


# ── Notification Service ───────────────────────────────────────────────────────

async def notify(
    db: AsyncSession,
    user_id: str,
    title: str,
    body: str = "",
    notification_type: str = "info",
    entity_type: str = "",
    entity_id: str = "",
):
    """Create a persistent notification and push via WebSocket."""
    notif = Notification(
        user_id=str(user_id),
        title=title,
        body=body,
        type=notification_type,
        entity_type=entity_type,
        entity_id=entity_id,
    )
    db.add(notif)
    # Don't commit — caller's transaction handles it

    # Real-time push
    await manager.send_to_user(str(user_id), {
        "type": "notification",
        "title": title,
        "body": body,
        "notification_type": notification_type,
        "entity_type": entity_type,
        "entity_id": entity_id,
        "timestamp": datetime.now(timezone.utc).isoformat(),
    })


async def broadcast_entity_change(
    action: str,
    entity_type: str,
    entity_id: str,
    actor_id: str = "",
):
    """Broadcast entity change to all connected users (except the actor)."""
    await manager.broadcast(
        {
            "type": "entity_change",
            "action": action,
            "entity_type": entity_type,
            "entity_id": entity_id,
            "actor_id": actor_id,
            "timestamp": datetime.now(timezone.utc).isoformat(),
        },
        exclude_user=actor_id,
    )


