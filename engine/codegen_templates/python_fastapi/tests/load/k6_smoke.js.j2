// GENERATED BY ARCHIE — solution_id: {{ solution_id }}
// k6 Smoke Test — validates basic API functionality under minimal load.
// Run: k6 run tests/load/k6_smoke.js
// Requires: K6_API_URL env var pointing to your deployed API.
// Threshold: p95 < 500ms, error rate < 1%.

import http from "k6/http";
import { check, sleep, group } from "k6";
import { Counter, Rate, Trend } from "k6/metrics";

// ── Config ────────────────────────────────────────────────────────────────────
const BASE_URL = __ENV.K6_API_URL || "http://localhost:8000";
const TOKEN    = __ENV.K6_AUTH_TOKEN || "";  // set in CI: k6 run -e K6_AUTH_TOKEN=xxx

const errorRate  = new Rate("error_rate");
const authErrors = new Counter("auth_errors");
{% for svc in services %}
const {{ svc.name | lower }}Trend = new Trend("{{ svc.name | lower }}_duration", true);
{% endfor %}

export const options = {
  vus: 10,
  duration: "30s",
  thresholds: {
    "http_req_duration{type:read}":  ["p(95)<500"],
    "http_req_duration{type:write}": ["p(95)<1000"],
    "error_rate":                    ["rate<0.01"],    // < 1% errors
    "http_req_failed":               ["rate<0.01"],
  },
};

const HEADERS = {
  "Content-Type": "application/json",
  ...(TOKEN ? { Authorization: `Bearer ${TOKEN}` } : {}),
};

export function setup() {
  // Verify the API is alive before running tests
  const res = http.get(`${BASE_URL}/health`);
  if (res.status !== 200) {
    throw new Error(`Health check failed: ${res.status} — is the API running at ${BASE_URL}?`);
  }
  return { baseUrl: BASE_URL, headers: HEADERS };
}

export default function (data) {
  const { baseUrl, headers } = data;

{% for svc in services %}
  group("{{ svc.name }} API", () => {
    // List
    const listRes = http.get(`${baseUrl}{{ svc.base_path }}?page=1&per_page=10`, {
      headers,
      tags: { type: "read", resource: "{{ svc.name | lower }}" },
    });
    {{ svc.name | lower }}Trend.add(listRes.timings.duration);

    check(listRes, {
      "{{ svc.name }} list returns 200": (r) => r.status === 200,
      "{{ svc.name }} list has items key": (r) => {
        try { return JSON.parse(r.body).hasOwnProperty("items"); } catch { return false; }
      },
      "{{ svc.name }} list p95 < 500ms": (r) => r.timings.duration < 500,
    }) || errorRate.add(1);

    if (listRes.status === 401) authErrors.add(1);
  });

{% endfor %}

  sleep(1);
}

export function teardown(data) {
  console.log(`Smoke test complete. Error rate check: ${errorRate.name}`);
}
