{# app/modules/solutions_product/templates/go_chi/github_actions.yml.j2 #}
{# GitHub Actions CI/CD pipeline for Go/Chi microservices. #}
{# Context: solution_id, bundle_id, solution_name, ci_cd (dict with provider config) #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE
{% set svc_name = solution_name | lower | replace(' ', '-') | replace('_', '-') %}
{% set registry = ci_cd.container_registry | default('ghcr') %}
{% set staging_ns = ci_cd.k8s_staging_namespace | default('staging') %}
{% set prod_ns = ci_cd.k8s_prod_namespace | default('production') %}
{% set manual_approval = ci_cd.require_manual_approval | default(true) %}
{% set security_scan = ci_cd.run_security_scan | default(true) %}
{% set compliance_url = ci_cd.compliance_check_url | default('') %}

name: "{{ svc_name }} CI/CD"

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

env:
  IMAGE_NAME: {{ svc_name }}
{% if registry == 'ghcr' %}
  REGISTRY: ghcr.io/${{ '{{' }} github.repository_owner {{ '}}' }}
{% elif registry == 'ecr' %}
  REGISTRY: ${{ '{{' }} secrets.AWS_ACCOUNT_ID {{ '}}' }}.dkr.ecr.${{ '{{' }} secrets.AWS_REGION {{ '}}' }}.amazonaws.com
{% elif registry == 'gcr' %}
  REGISTRY: gcr.io/${{ '{{' }} secrets.GCP_PROJECT_ID {{ '}}' }}
{% elif registry == 'acr' %}
  REGISTRY: ${{ '{{' }} secrets.ACR_REGISTRY {{ '}}' }}.azurecr.io
{% endif %}

jobs:
  # ── Stage 1: Build & Lint ──
  build-lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Go 1.22
        uses: actions/setup-go@v5
        with:
          go-version: "1.22"
          cache: true

      - name: Download dependencies
        run: go mod download

      - name: Run golangci-lint
        uses: golangci/golangci-lint-action@v4
        with:
          version: latest

  # ── Stage 2: Test ──
  test:
    runs-on: ubuntu-latest
    needs: build-lint
    services:
      postgres:
        image: postgres:16
        env:
          POSTGRES_USER: test
          POSTGRES_PASSWORD: test
          POSTGRES_DB: test_db
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
    env:
      DATABASE_URL: postgresql://test:test@localhost:5432/test_db  # secrets-safety-ok
    steps:
      - uses: actions/checkout@v4

      - name: Set up Go 1.22
        uses: actions/setup-go@v5
        with:
          go-version: "1.22"
          cache: true

      - name: Run database migrations
        run: go run migration.go

      - name: Run unit tests with coverage
        run: go test -v -coverprofile=coverage.out -count=1 ./...

      - name: Run contract tests
        run: go test -v -run TestContract ./...

      - name: Upload coverage artifact
        uses: actions/upload-artifact@v4
        with:
          name: coverage-report
          path: coverage.out
{% if security_scan %}

  # ── Stage 3: Security Scan ──
  security-scan:
    runs-on: ubuntu-latest
    needs: test
    steps:
      - uses: actions/checkout@v4

      - name: Build Docker image
        run: docker build -t ${{ '{{' }} env.IMAGE_NAME {{ '}}' }}:scan .

      - name: Run Trivy container scan
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: ${{ '{{' }} env.IMAGE_NAME {{ '}}' }}:scan
          format: table
          exit-code: 1
          severity: CRITICAL,HIGH
          ignore-unfixed: true

      - name: Set up Go 1.22
        uses: actions/setup-go@v5
        with:
          go-version: "1.22"

      - name: Run govulncheck
        run: |
          go install golang.org/x/vuln/cmd/govulncheck@latest
          govulncheck ./...
{% endif %}

  # ── Stage 4: Push Image ──
  push-image:
    runs-on: ubuntu-latest
{% if security_scan %}
    needs: security-scan
{% else %}
    needs: test
{% endif %}
    if: github.ref == 'refs/heads/main' && github.event_name == 'push'
    permissions:
      contents: read
      packages: write
    steps:
      - uses: actions/checkout@v4

{% if registry == 'ghcr' %}
      - name: Login to GitHub Container Registry
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ '{{' }} github.actor {{ '}}' }}
          password: ${{ '{{' }} secrets.GITHUB_TOKEN {{ '}}' }}
{% elif registry == 'ecr' %}
      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ '{{' }} secrets.AWS_ACCESS_KEY_ID {{ '}}' }}
          aws-secret-access-key: ${{ '{{' }} secrets.AWS_SECRET_ACCESS_KEY {{ '}}' }}
          aws-region: ${{ '{{' }} secrets.AWS_REGION {{ '}}' }}

      - name: Login to Amazon ECR
        uses: aws-actions/amazon-ecr-login@v2
{% elif registry == 'gcr' %}
      - name: Authenticate to Google Cloud
        uses: google-github-actions/auth@v2
        with:
          credentials_json: ${{ '{{' }} secrets.GCP_SA_KEY {{ '}}' }}

      - name: Login to Google Container Registry
        run: gcloud auth configure-docker
{% elif registry == 'acr' %}
      - name: Login to Azure Container Registry
        uses: azure/docker-login@v2
        with:
          login-server: ${{ '{{' }} secrets.ACR_REGISTRY {{ '}}' }}.azurecr.io
          username: ${{ '{{' }} secrets.ACR_USERNAME {{ '}}' }}
          password: ${{ '{{' }} secrets.ACR_PASSWORD {{ '}}' }}
{% endif %}

      - name: Build and push Docker image
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: |
            ${{ '{{' }} env.REGISTRY {{ '}}' }}/${{ '{{' }} env.IMAGE_NAME {{ '}}' }}:${{ '{{' }} github.sha {{ '}}' }}
            ${{ '{{' }} env.REGISTRY {{ '}}' }}/${{ '{{' }} env.IMAGE_NAME {{ '}}' }}:latest

  # ── Stage 5: Deploy to Staging ──
  deploy-staging:
    runs-on: ubuntu-latest
    needs: push-image
    environment: staging
    steps:
      - uses: actions/checkout@v4

      - name: Configure kubectl
        uses: azure/setup-kubectl@v4

      - name: Set kubeconfig
        run: echo "${{ '{{' }} secrets.KUBECONFIG {{ '}}' }}" | base64 -d > $HOME/.kube/config

      - name: Update image tag in manifests
        run: |
          sed -i "s|image:.*|image: ${{ '{{' }} env.REGISTRY {{ '}}' }}/${{ '{{' }} env.IMAGE_NAME {{ '}}' }}:${{ '{{' }} github.sha {{ '}}' }}|g" k8s/deployment.yaml

      - name: Apply K8s manifests to staging
        run: kubectl apply -f k8s/ -n {{ staging_ns }}

      - name: Wait for rollout
        run: kubectl rollout status deployment/{{ svc_name }} -n {{ staging_ns }} --timeout=300s

      - name: Run smoke test
        run: |
          STAGING_URL=$(kubectl get svc {{ svc_name }} -n {{ staging_ns }} -o jsonpath='{.status.loadBalancer.ingress[0].ip}')
          curl -sf "http://${STAGING_URL}/health" || exit 1

  # ── Stage 6: Deploy to Production ──
  deploy-production:
    runs-on: ubuntu-latest
    needs: deploy-staging
{% if manual_approval %}
    environment: production
{% endif %}
    steps:
      - uses: actions/checkout@v4

      - name: Configure kubectl
        uses: azure/setup-kubectl@v4

      - name: Set kubeconfig
        run: echo "${{ '{{' }} secrets.KUBECONFIG {{ '}}' }}" | base64 -d > $HOME/.kube/config

      - name: Update image tag in manifests
        run: |
          sed -i "s|image:.*|image: ${{ '{{' }} env.REGISTRY {{ '}}' }}/${{ '{{' }} env.IMAGE_NAME {{ '}}' }}:${{ '{{' }} github.sha {{ '}}' }}|g" k8s/deployment.yaml

      - name: Apply K8s manifests to production
        run: kubectl apply -f k8s/ -n {{ prod_ns }}

      - name: Wait for rollout
        run: kubectl rollout status deployment/{{ svc_name }} -n {{ prod_ns }} --timeout=300s
{% if compliance_url %}

      - name: Run compliance check
        run: |
          curl -sf -X POST "{{ compliance_url }}" \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer ${{ '{{' }} secrets.ARCHIE_API_TOKEN {{ '}}' }}" \
            -d '{"service_url": "http://{{ svc_name }}.{{ prod_ns }}.svc.cluster.local"}' || echo "Compliance check failed (non-blocking)"
{% endif %}
