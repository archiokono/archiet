def run(self, payload: dict | None = None):
    """{{ worker.name | replace('_', ' ') | title }}.

    Trigger: {{ worker.trigger | default('manual') }}
{% if worker.get('trigger_event') %}
    Event:   {{ worker.get('trigger_event', '') }}
{% endif %}
{% if worker.get('trigger') == 'schedule' and worker.get('cron') %}
    Cron:    {{ worker.get('cron', '') }}
{% endif %}
    """
    start = time.monotonic()
    logger.info("Starting %s (attempt %d/%d)", self.name, self.request.retries + 1, {{ max_retries }})

    try:
