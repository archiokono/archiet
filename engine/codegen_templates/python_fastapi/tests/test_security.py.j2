# ─── A03: Injection ───────────────────────────────────────────────────────────

class TestInjectionVulnerabilities:
    """A03 — SQL injection and NoSQL injection payloads must be rejected or sanitised."""

    SQL_PAYLOADS = [
        "' OR '1'='1",
        "'; DROP TABLE users; --",
        "1; SELECT * FROM users",
        "' UNION SELECT null,null,null --",
        "\" OR \"1\"=\"1",
    ]

    @pytest.mark.asyncio
    @pytest.mark.parametrize("payload", SQL_PAYLOADS)
    async def test_sql_injection_in_query_param_does_not_500(self, client: AsyncClient, auth_headers: dict, payload: str):
        """SQL injection in query params must return 400/422/404, never 500."""
        resp = await client.get(SAMPLE_PATH, params={"search": payload}, headers=auth_headers)
        assert resp.status_code != 500, \
            f"SQL injection payload caused 500: {payload!r}\nResponse: {resp.text[:200]}"
        assert resp.status_code in (200, 400, 404, 422), \
            f"Unexpected status {resp.status_code} for injection payload"

    @pytest.mark.asyncio
    @pytest.mark.parametrize("payload", SQL_PAYLOADS)
    async def test_sql_injection_in_path_param_does_not_500(self, client: AsyncClient, auth_headers: dict, payload: str):
        """SQL injection in path params must not cause 500."""
        import urllib.parse
        encoded = urllib.parse.quote(payload, safe="")
        resp = await client.get(f"{SAMPLE_PATH}/{encoded}", headers=auth_headers)
        assert resp.status_code != 500, \
            f"SQL injection in path caused 500: {payload!r}"


# ─── A02: Cryptographic Failures ─────────────────────────────────────────────

class TestCryptographicFailures:
    """A02 — Sensitive data must not appear in API responses."""

    @pytest.mark.asyncio
    async def test_response_does_not_expose_password_hash(self, client: AsyncClient, auth_headers: dict):
        """User objects must not include hashed_password / password fields."""
        resp = await client.get(SAMPLE_PATH, headers=auth_headers)
        if resp.status_code == 200:
            body_str = resp.text.lower()
            assert "password" not in body_str or "password_hash" not in body_str, \
                "API response contains 'password' field — credential exposure risk!"
            assert "hashed_password" not in body_str, \
                "API response contains 'hashed_password' field — credential exposure risk!"

    @pytest.mark.asyncio
    async def test_response_does_not_expose_internal_ids(self, client: AsyncClient, auth_headers: dict):
        """Responses should not expose database auto-increment IDs that enable enumeration."""
        resp = await client.get(SAMPLE_PATH, headers=auth_headers)
        if resp.status_code == 200:
            body = resp.json()
            items = body.get("items", [body] if isinstance(body, dict) else body)
            for item in (items[:3] if isinstance(items, list) else []):
                if isinstance(item, dict):
                    # IDs should be UUIDs (long strings), not sequential integers
                    item_id = item.get("id")
                    if item_id is not None and isinstance(item_id, int):
                        pytest.fail(
                            f"Sequential integer ID exposed: {item_id} — enables enumeration attacks. "
                            "Use UUIDs for public-facing IDs."
                        )


# ─── A05: Security Misconfiguration ──────────────────────────────────────────

class TestSecurityMisconfiguration:
    """A05 — Security headers and safe defaults."""

    @pytest.mark.asyncio
    async def test_security_headers_present(self, client: AsyncClient, auth_headers: dict):
        """Every response must include OWASP-recommended security headers."""
        resp = await client.get(SAMPLE_PATH, headers=auth_headers)
        headers = resp.headers

        missing = []
        expected_headers = {
            "x-content-type-options": "nosniff",
            "x-frame-options": None,          # any value
            "strict-transport-security": None, # any value (HTTPS only)
        }
        for header_name, expected_value in expected_headers.items():
            if header_name not in headers:
                missing.append(header_name)
            elif expected_value and headers[header_name].lower() != expected_value.lower():
                missing.append(f"{header_name}={headers[header_name]} (expected {expected_value})")

        # HSTS is only relevant in production, so just warn
        if "strict-transport-security" in missing:
            missing.remove("strict-transport-security")

        assert not missing, f"Missing security headers: {', '.join(missing)}"

    @pytest.mark.asyncio
    async def test_no_server_version_in_headers(self, client: AsyncClient):
        """Server version must not be exposed in headers."""
        resp = await client.get("/health")
        server_header = resp.headers.get("server", "")
        # Should not expose uvicorn version, Python version, etc.
        assert "uvicorn" not in server_header.lower() or "/" not in server_header, \
            f"Server version exposed in 'Server' header: {server_header}"

    @pytest.mark.asyncio
    async def test_options_preflight_does_not_allow_all_origins(self, client: AsyncClient):
        """CORS must not use wildcard for credentialed requests."""
        resp = await client.options(
            SAMPLE_PATH,
            headers={
                "Origin": "https://evil.example.com",
                "Access-Control-Request-Method": "GET",
            }
        )
        allow_origin = resp.headers.get("access-control-allow-origin", "")
        # Should not allow ALL origins with credentials
        # (wildcard + credentials = critical CORS misconfiguration)
        allow_credentials = resp.headers.get("access-control-allow-credentials", "false")
        if allow_credentials.lower() == "true":
            assert allow_origin != "*", \
                "CRITICAL: CORS allows wildcard origin WITH credentials — credential theft risk!"


# ─── A07: Identification and Authentication Failures ──────────────────────────

class TestAuthenticationFailures:
    """A07 — Rate limiting, account lockout, and token validation."""

    @pytest.mark.asyncio
    async def test_brute_force_login_triggers_rate_limit(self, client: AsyncClient):
        """Repeated failed logins should eventually return 429."""
{% if is_jwt_local %}
        status_codes = []
        for _ in range(20):
            resp = await client.post("/auth/login", json={
                "email": "nonexistent@example.com",
                "password": "wrong-password",
            })
            status_codes.append(resp.status_code)
        # After 20 attempts, at least one should be 429 (rate limited) or still 401
        # If all return 401 without 429, rate limiting is not configured
        has_rate_limit = 429 in status_codes
        if not has_rate_limit:
            # Soft fail — log as warning, not hard failure, since rate limiting may be at infra level
            import warnings
            warnings.warn(
                "No 429 responses after 20 failed login attempts — "
                "rate limiting may not be configured at the application level.",
                UserWarning,
            )
{% else %}
        pytest.skip("jwt-local auth not configured — skipping login rate limit test")
{% endif %}

    @pytest.mark.asyncio
    async def test_token_without_organization_id_is_rejected(self, client: AsyncClient):
        """Tokens missing organization_id claim must be rejected."""
        import jwt as pyjwt
        import os
        from datetime import datetime, timedelta, timezone

        payload = {
            "sub": "user-id",
            # INTENTIONALLY missing organization_id
            "exp": (datetime.now(timezone.utc) + timedelta(hours=1)).timestamp(),
        }
        token = pyjwt.encode(payload, os.environ["JWT_SECRET"], algorithm="HS256")
        resp = await client.get(SAMPLE_PATH, headers={"Authorization": f"Bearer {token}"})
        assert resp.status_code in (401, 403), \
            f"Token missing organization_id was accepted (status {resp.status_code}) — tenant isolation broken!"


