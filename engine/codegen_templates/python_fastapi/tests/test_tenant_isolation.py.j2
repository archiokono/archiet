        )

    @pytest.mark.asyncio
    async def test_list_only_returns_own_org_records(
        self, client: AsyncClient, auth_headers: dict, other_org_headers: dict
    ):
        # Create one record in each org
        await self._create(client, auth_headers, suffix="-org-a")
        await self._create(client, other_org_headers, suffix="-org-b")

        resp_a = await client.get(self.BASE, headers=auth_headers)
        resp_b = await client.get(self.BASE, headers=other_org_headers)

        items_a = resp_a.json().get("items", [])
        items_b = resp_b.json().get("items", [])

        org_a_ids = {r["id"] for r in items_a}
        org_b_ids = {r["id"] for r in items_b}

        assert not org_a_ids.intersection(org_b_ids), (
            f"Tenant isolation VIOLATED: shared records between orgs: {org_a_ids & org_b_ids}"
        )

