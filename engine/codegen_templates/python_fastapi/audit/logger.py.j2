        if entity_type and entity_type in [e.lower() for e in AUDITED_ENTITIES]:
            # Store request context for post-response audit logging
            request.state.audit_entity_type = entity_type
            request.state.audit_entity_id = entity_id

        response = await call_next(request)
        return response


