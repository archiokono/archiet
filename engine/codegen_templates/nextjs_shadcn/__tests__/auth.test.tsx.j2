import React from 'react';
import { render, screen, waitFor } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { rest } from 'msw';
import { setupServer } from 'msw/node';
import LoginPage from '@/app/(auth)/login/page';
import { AuthProvider } from '@/lib/auth/AuthProvider';

const BASE = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:8000';
const mockPush = jest.fn();

jest.mock('next/navigation', () => ({
  useRouter: () => ({ push: mockPush, replace: jest.fn(), back: jest.fn(), prefetch: jest.fn() }),
  usePathname: () => '/login',
  useSearchParams: () => new URLSearchParams(),
}));

const validToken = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.' +
  btoa(JSON.stringify({ sub: 'user-1', org_id: 'org-1', exp: Math.floor(Date.now() / 1000) + 3600 })) +
  '.signature';

const server = setupServer(
  rest.post(`${BASE}/api/v1/auth/token`, async (req, res, ctx) => {
    const body = await req.json();
    if (body.username === 'test@example.com' && body.password === 'Valid@123') {
      return res(ctx.json({ access_token: validToken, token_type: 'bearer', expires_in: 3600 }));
    }
    return res(ctx.status(401), ctx.json({ detail: 'Invalid credentials' }));
  }),
  rest.post(`${BASE}/api/v1/auth/refresh`, (_req, res, ctx) =>
    res(ctx.json({ access_token: validToken, token_type: 'bearer', expires_in: 3600 }))
  ),
  rest.post(`${BASE}/api/v1/auth/logout`, (_req, res, ctx) => res(ctx.status(204))),
  rest.get(`${BASE}/api/v1/auth/me`, (req, res, ctx) => {
    const auth = req.headers.get('authorization');
    if (auth?.startsWith('Bearer ')) {
      return res(ctx.json({ id: 'user-1', email: 'test@example.com', org_id: 'org-1' }));
    }
    return res(ctx.status(401));
  }),
);

beforeAll(() => server.listen({ onUnhandledRequest: 'warn' }));
afterEach(() => { server.resetHandlers(); mockPush.mockClear(); localStorage.clear(); sessionStorage.clear(); });
afterAll(() => server.close());

const Wrapper = ({ children }: { children: React.ReactNode }) => (
  <AuthProvider>{children}</AuthProvider>
);

