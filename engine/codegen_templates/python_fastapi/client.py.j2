    {% if contract.auth_method == 'oauth2' %}
    def _refresh_token(self):
        """Obtain or refresh OAuth2 access token using client credentials."""
        if not self._token_url:
            logger.error("OAuth2 token_url not configured")
            return
        try:
            resp = httpx.post(
                self._token_url,
                data={
                    "grant_type": "{{ auth_config.get('grant_type', 'client_credentials') }}",
                    "client_id": self._client_id,
                    "client_secret": self._client_secret,
                    {% if auth_config.get('scope') %}
                    "scope": self._scope,
                    {% endif %}
                },
                timeout=10,
            )
            resp.raise_for_status()
            token_data = resp.json()
            self._access_token = token_data.get("access_token")
            self._headers["Authorization"] = f"Bearer {self._access_token}"
            logger.debug("OAuth2 token refreshed for {{ integration_name }}")
        except Exception as exc:
            logger.error("OAuth2 token refresh failed: %s", exc)

    {% endif %}
