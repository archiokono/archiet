"""
Seed script — generate realistic demo data for {{ solution_name }}.

Usage:
    python seed.py                    # 25 records per entity (default)
    python seed.py --count 100        # 100 records per entity
    python seed.py --clean            # Wipe + reseed
"""
import argparse
import asyncio
import os
import random
import sys
from datetime import datetime, timedelta, timezone

# Faker is optional — falls back to simple random values
try:
    from faker import Faker
    fake = Faker()
except ImportError:
    fake = None

# ── Database setup ─────────────────────────────────────────────────────────────

DATABASE_URL = os.environ.get("DATABASE_URL", "sqlite+aiosqlite:///./app.db")


async def get_engine():
    from sqlalchemy.ext.asyncio import create_async_engine
    return create_async_engine(DATABASE_URL, echo=False)


# ── Fake data generators per field type ────────────────────────────────────────

def _fake_value(field_name: str, field_type: str, field_format: str = "",
                enum_values: list = None, max_length: int = 255, **kwargs) -> object:
    """Generate a realistic fake value based on field name, type, and format."""
    fn = field_name.lower()
    ft = (field_type or "string").lower()
    ff = (field_format or "").lower()

    # Enum — pick from allowed values
    if enum_values:
        return random.choice(enum_values)

    # Name-based heuristics (more realistic than type-only)
    if fake:
        if fn in ("email", "email_address"):
            return fake.email()
        if fn in ("full_name", "name", "customer_name", "contact_name"):
            return fake.name()
        if fn in ("first_name",):
            return fake.first_name()
        if fn in ("last_name", "surname"):
            return fake.last_name()
        if fn in ("phone", "phone_number", "mobile"):
            return fake.phone_number()[:20]
        if fn in ("address", "street_address"):
            return fake.address().replace("\n", ", ")[:max_length]
        if fn in ("city",):
            return fake.city()
        if fn in ("country",):
            return fake.country()[:max_length]
        if fn in ("zip_code", "postal_code"):
            return fake.zipcode()
        if fn in ("company", "company_name", "organization"):
            return fake.company()[:max_length]
        if fn in ("url", "website"):
            return fake.url()
        if fn in ("description", "notes", "comment", "remarks"):
            return fake.paragraph(nb_sentences=2)[:max_length]
        if fn in ("title", "subject"):
            return fake.sentence(nb_words=5)[:max_length]
        if "amount" in fn or "price" in fn or "cost" in fn or "total" in fn:
            return round(random.uniform(10.0, 10000.0), 2)
        if "quantity" in fn or "count" in fn:
            return random.randint(1, 100)
        if "priority" in fn:
            return random.choice(["low", "medium", "high", "critical"])

    # Type-based fallbacks
    if ft == "json":
        import json
        return json.dumps({"key": f"value_{random.randint(1, 100)}"})
    if ft in ("integer", "int"):
        return random.randint(1, 1000)
    if ft in ("number", "float", "decimal"):
        return round(random.uniform(1.0, 10000.0), 2)
    if ft == "boolean":
        return random.choice([True, False])
    if ft in ("datetime", "timestamp") or ff == "date-time":
        base = datetime.now(timezone.utc) - timedelta(days=random.randint(0, 90))
        return base.isoformat()
    if ft == "date" or ff == "date":
        base = datetime.now(timezone.utc) - timedelta(days=random.randint(0, 90))
        return base.date().isoformat()
    if ff == "email":
        return fake.email() if fake else f"user{random.randint(1,999)}@example.com"
    if ff == "uuid":
        import uuid
        return str(uuid.uuid4())

    # Default string
    if fake:
        return fake.text(max_nb_chars=min(max_length, 100))[:max_length]
    return f"sample_{field_name}_{random.randint(1, 999)}"


# ── Entity seed definitions ────────────────────────────────────────────────────

ENTITIES = {
{% for model_name, model_def in models.items() %}
    "{{ model_name }}": {
        "table": "{{ model_name | lower }}s",
        "fields": [
{% for field in model_def.fields %}
{% if field.name != 'id' and field.name != 'deleted_at' and not field.readonly and not field.primary_key %}
            {
                "name": "{{ field.name }}",
                "type": "{{ field.type | default('string') }}",
                "format": "{{ field.format | default('') }}",
                "required": {{ 'True' if field.required else 'False' }},
                "max_length": {{ field.max_length | default(255) }},
{% if field.enum_values %}
                "enum_values": {{ field.enum_values | tojson }},
{% else %}
                "enum_values": [],
{% endif %}
            },
{% endif %}
{% endfor %}
        ],
    },
{% endfor %}
}


async def seed_entity(engine, entity_name: str, entity_def: dict, count: int,
                      created_ids: dict):
    """Seed one entity with fake data. FK fields reference previously-seeded IDs."""
    import uuid as _uuid
    from sqlalchemy.ext.asyncio import AsyncSession
    from sqlalchemy.orm import sessionmaker

    Session = sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
    fields = entity_def["fields"]
    table = entity_def["table"]

    if not fields:
        print(f"  {entity_name}: skipped (no writable fields)")
        return

    col_names = [f["name"] for f in fields if f["required"] or random.random() > 0.3]
    if not col_names:
        col_names = [fields[0]["name"]]

    field_map = {f["name"]: f for f in fields}
    inserted = 0
    entity_ids = []

    async with Session() as session:
        for _ in range(count):
            row_id = str(_uuid.uuid4())
            values = {"id": row_id}
            for col in col_names:
                fd = field_map[col]
                # FK fields: reference an existing ID from the target entity
                if col.endswith("_id") and col != "id":
                    ref_entity = col[:-3]  # owner_id -> owner
                    # Try matching entity names (case-insensitive, with/without plural)
                    ref_ids = (
                        created_ids.get(ref_entity) or
                        created_ids.get(ref_entity + "s") or
                        created_ids.get(ref_entity.capitalize()) or
                        created_ids.get(ref_entity.replace("_", "")) or
                        None
                    )
                    if ref_ids:
                        values[col] = random.choice(ref_ids)
                    else:
                        values[col] = str(_uuid.uuid4())  # fallback
                else:
                    values[col] = _fake_value(
                        col, fd["type"], fd.get("format", ""),
                        fd.get("enum_values", []), fd.get("max_length", 255),
                    )

            from sqlalchemy import table as sa_table, column as sa_column, insert
            tbl = sa_table(table, *[sa_column(k) for k in values])
            stmt = insert(tbl).values(**values)
            try:
                await session.execute(stmt)
                inserted += 1
                entity_ids.append(row_id)
            except Exception as e:
                await session.rollback()
                print(f"  {entity_name}: insert failed — {e}")
                break

        await session.commit()

    # Store created IDs for FK reference by later entities
    created_ids[entity_name.lower()] = entity_ids
    # Also store under table name (without 's' suffix handled above)
    created_ids[table.rstrip("s")] = entity_ids
    print(f"  {entity_name}: {inserted} records seeded")


async def clean_all(engine):
    """Delete all data from seeded tables."""
    from sqlalchemy import table as sa_table
    from sqlalchemy.ext.asyncio import AsyncSession
    from sqlalchemy.orm import sessionmaker

    Session = sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
    async with Session() as session:
        for name, entity_def in reversed(list(ENTITIES.items())):
            try:
                tbl = sa_table(entity_def['table'])
                await session.execute(tbl.delete())
                print(f"  {name}: cleaned")
            except Exception as e:
                print(f"  {name}: clean failed — {e}")
        await session.commit()


async def main(count: int = 25, clean: bool = False):
    engine = await get_engine()

    # Create tables if they don't exist
    # Import models so they register on Base.metadata before create_all
    from app.database import Base
    import app.models.entities  # noqa: F401 — registers all model tables
    try:
        import app.models.user  # noqa: F401 — jwt-local auth user table
    except ImportError:
        pass
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)

    if clean:
        print("Cleaning existing data...")
        await clean_all(engine)

    print(f"Seeding {count} records per entity...")
    created_ids = {}  # entity_name -> [id1, id2, ...] for FK reference
    for name, entity_def in ENTITIES.items():
        await seed_entity(engine, name, entity_def, count, created_ids)

    await engine.dispose()
    print("Done.")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Seed {{ solution_name }} with demo data")
    parser.add_argument("--count", type=int, default=25, help="Records per entity (default: 25)")
    parser.add_argument("--clean", action="store_true", help="Wipe existing data before seeding")
    args = parser.parse_args()
    asyncio.run(main(count=args.count, clean=args.clean))
