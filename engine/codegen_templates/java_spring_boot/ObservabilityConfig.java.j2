/**
 * Observability configuration: OpenTelemetry tracing + structured logging.
 *
 * In production (OTEL_EXPORTER_OTLP_ENDPOINT set):
 *   Traces exported via OTLP/gRPC. Spring Boot auto-configures via
 *   opentelemetry-spring-boot-starter.
 *
 * In development (no OTLP endpoint):
 *   Console exporter prints traces to stdout.
 *
 * Structured logging:
 *   Uses SLF4J MDC for correlation IDs. Configure logback-spring.xml
 *   for JSON output in production.
 */
@Configuration
public class ObservabilityConfig {

    private static final Logger log = LoggerFactory.getLogger(ObservabilityConfig.class);

    @Value("${spring.application.name:{{ solution_name | lower | replace(' ', '-') }}}")
    private String serviceName;

    /**
     * Request correlation filter — adds X-Request-ID to MDC for structured logging.
     */
    @Bean
    public OncePerRequestFilter requestCorrelationFilter() {
        return new OncePerRequestFilter() {
            @Override
            protected void doFilterInternal(HttpServletRequest request,
                                            HttpServletResponse response,
                                            FilterChain chain) throws ServletException, IOException {
                String requestId = request.getHeader("X-Request-ID");
                if (requestId == null || requestId.isBlank()) {
                    requestId = UUID.randomUUID().toString();
                }
                MDC.put("requestId", requestId);
                MDC.put("service", serviceName);
                response.setHeader("X-Request-ID", requestId);

                long start = System.currentTimeMillis();
                try {
                    chain.doFilter(request, response);
                } finally {
                    long duration = System.currentTimeMillis() - start;
                    log.info("request method={} path={} status={} duration={}ms requestId={}",
                            request.getMethod(), request.getRequestURI(),
                            response.getStatus(), duration, requestId);
                    MDC.clear();
                }
            }
        };
    }
}
