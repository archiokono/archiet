{# Profile screen — user info, app info, settings, sign out #}
import { ScrollView, Text, TouchableOpacity, View } from "react-native"
import { SafeAreaView } from "react-native-safe-area-context"
import { User, Info, Shield, LogOut, ChevronRight, Bell } from "lucide-react-native"
import Constants from "expo-constants"
{% if auth == "jwt-local" %}
import { useAuth } from "@/providers/AuthProvider"
{% endif %}

const SCROLL_STYLE = { padding: 20, paddingBottom: 32 }
const EDGES = ["bottom"] as const
const CARD_SHADOW = { shadowColor: "#000", shadowOffset: { width: 0, height: 1 }, shadowOpacity: 0.05, shadowRadius: 3, elevation: 2 }

const appVersion = Constants.expoConfig?.version ?? "1.0.0"

function SettingsRow({
  icon,
  label,
  value,
  onPress,
}: {
  icon: React.ReactNode
  label: string
  value?: string
  onPress?: () => void
}) {
  const inner = (
    <View className="flex-row items-center py-3.5 border-b border-slate-50">
      <View className="w-9 h-9 rounded-xl bg-slate-100 items-center justify-center mr-3">
        {icon}
      </View>
      <View className="flex-1">
        <Text className="text-sm font-medium text-slate-900">{label}</Text>
        {value ? <Text className="text-xs text-slate-400 mt-0.5">{value}</Text> : null}
      </View>
      {onPress ? <ChevronRight size={16} color="#cbd5e1" /> : null}
    </View>
  )
  if (onPress) {
    return (
      <TouchableOpacity onPress={onPress} accessibilityLabel={label}>
        {inner}
      </TouchableOpacity>
    )
  }
  return inner
}

export default function ProfileScreen() {
  {% if auth == "jwt-local" %}
  const { user, signOut } = useAuth()
  const initials = user?.full_name
    ? user.full_name.split(" ").map((n) => n[0]).slice(0, 2).join("").toUpperCase()
    : user?.email?.charAt(0).toUpperCase() ?? "?"
  {% endif %}

  return (
    <SafeAreaView className="flex-1 bg-slate-50" edges={EDGES}>
      <ScrollView className="flex-1" contentContainerStyle={SCROLL_STYLE}>

        {/* Avatar + name */}
        <View className="items-center mb-6">
          <View className="w-20 h-20 rounded-full bg-indigo-100 items-center justify-center mb-3">
            {% if auth == "jwt-local" %}
            <Text className="text-2xl font-bold text-indigo-600">{initials}</Text>
            {% else %}
            <User size={36} color="#6366f1" />
            {% endif %}
          </View>
          {% if auth == "jwt-local" %}
          <Text className="text-xl font-bold text-slate-900">{user?.full_name || "User"}</Text>
          <Text className="text-sm text-slate-500 mt-0.5">{user?.email || ""}</Text>
          {% else %}
          <Text className="text-xl font-bold text-slate-900">Profile</Text>
          {% endif %}
        </View>

        {% if auth == "jwt-local" %}
        {/* Account */}
        <View className="bg-white rounded-2xl border border-slate-100 px-5 mb-4" style={CARD_SHADOW}>
          <View className="py-3 border-b border-slate-100">
            <Text className="text-xs font-semibold text-slate-400 uppercase tracking-wider">Account</Text>
          </View>
          <SettingsRow
            icon={<User size={18} color="#64748b" />}
            label="Email"
            value={user?.email}
          />
          <SettingsRow
            icon={<Bell size={18} color="#64748b" />}
            label="Notifications"
            onPress={() => {}}
          />
          <SettingsRow
            icon={<Shield size={18} color="#64748b" />}
            label="Change Password"
            onPress={() => {}}
          />
        </View>
        {% endif %}

        {/* About */}
        <View className="bg-white rounded-2xl border border-slate-100 px-5 mb-4" style={CARD_SHADOW}>
          <View className="py-3 border-b border-slate-100">
            <Text className="text-xs font-semibold text-slate-400 uppercase tracking-wider">About</Text>
          </View>
          <SettingsRow
            icon={<Info size={18} color="#64748b" />}
            label="{{ solution_name }}"
            value="Generated by A.R.C.H.I.E."
          />
          <SettingsRow
            icon={<Shield size={18} color="#64748b" />}
            label="Version"
            value={appVersion}
          />
        </View>

        {% if auth == "jwt-local" %}
        {/* Sign out */}
        <TouchableOpacity
          onPress={signOut}
          className="bg-white rounded-2xl border border-red-100 px-5 py-4 flex-row items-center justify-center"
          style={CARD_SHADOW}
          accessibilityLabel="Sign out"
        >
          <LogOut size={18} color="#dc2626" />
          <Text className="text-base font-semibold text-red-600 ml-2">Sign Out</Text>
        </TouchableOpacity>
        {% endif %}

      </ScrollView>
    </SafeAreaView>
  )
}
