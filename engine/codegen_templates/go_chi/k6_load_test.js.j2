// GENERATED BY ARCHIE -- k6 load test from SLAs
// solution_id: {{ solution_id }}
// bundle_id: {{ bundle_id }}
// Run: k6 run tests/k6_load_test.js --env BASE_URL=http://localhost:8080
// DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE

import http from 'k6/http';
import { check, sleep } from 'k6';
import { Rate, Trend } from 'k6/metrics';

// Custom metrics
const errorRate = new Rate('errors');
const latencyTrend = new Trend('custom_latency');

export const options = {
  scenarios: {
{% for scenario_name, scenario in load_config.scenarios.items() %}
    {{ scenario_name }}: {
      executor: '{{ scenario.executor }}',
{% if scenario.vus is defined %}
      vus: {{ scenario.vus }},
{% endif %}
{% if scenario.duration is defined %}
      duration: '{{ scenario.duration }}',
{% endif %}
{% if scenario.startVUs is defined %}
      startVUs: {{ scenario.startVUs }},
{% endif %}
{% if scenario.stages is defined %}
      stages: [
{% for stage in scenario.stages %}
        { duration: '{{ stage.duration }}', target: {{ stage.target }} },
{% endfor %}
      ],
{% endif %}
    },
{% endfor %}
  },
  thresholds: {
{% for threshold in load_config.thresholds %}
    '{{ threshold.k6_metric }}': ['{{ threshold.condition }}'],  // SLA: {{ threshold.source_sla }}
{% endfor %}
  },
};

export default function () {
  const BASE_URL = __ENV.BASE_URL || 'http://localhost:8080';
  const AUTH_TOKEN = __ENV.AUTH_TOKEN || '';
  const headers = {
    'Content-Type': 'application/json',
  };
  if (AUTH_TOKEN) {
    headers['Authorization'] = `Bearer ${AUTH_TOKEN}`;
  }

  // Health check
  const health = http.get(`${BASE_URL}/health`);
  check(health, {
    'health OK': (r) => r.status === 200,
  });

{% for endpoint in load_config.endpoints %}
  // {{ endpoint.name_display }}
{% if endpoint.method == 'GET' %}
  const {{ endpoint.name_snake }}_resp = http.get(
    `${BASE_URL}{{ endpoint.path }}`,
    { headers },
  );
  check({{ endpoint.name_snake }}_resp, {
    '{{ endpoint.name_display }} {{ endpoint.method }} 200': (r) => r.status === 200,
    '{{ endpoint.name_display }} latency < 500ms': (r) => r.timings.duration < 500,
  });
  errorRate.add({{ endpoint.name_snake }}_resp.status !== 200);
  latencyTrend.add({{ endpoint.name_snake }}_resp.timings.duration);
{% elif endpoint.method == 'POST' %}
  const {{ endpoint.name_snake }}_resp = http.post(
    `${BASE_URL}{{ endpoint.path }}`,
{% if endpoint.sample_payload %}
    JSON.stringify({{ endpoint.sample_payload | tojson }}),
{% else %}
    JSON.stringify({}),
{% endif %}
    { headers },
  );
  check({{ endpoint.name_snake }}_resp, {
    '{{ endpoint.name_display }} {{ endpoint.method }} 201': (r) => r.status === 201,
    '{{ endpoint.name_display }} latency < 500ms': (r) => r.timings.duration < 500,
  });
  errorRate.add({{ endpoint.name_snake }}_resp.status > 299);
  latencyTrend.add({{ endpoint.name_snake }}_resp.timings.duration);
{% else %}
  const {{ endpoint.name_snake }}_resp = http.request(
    '{{ endpoint.method }}',
    `${BASE_URL}{{ endpoint.path }}`,
{% if endpoint.sample_payload %}
    JSON.stringify({{ endpoint.sample_payload | tojson }}),
{% else %}
    null,
{% endif %}
    { headers },
  );
  check({{ endpoint.name_snake }}_resp, {
    '{{ endpoint.name_display }} {{ endpoint.method }} OK': (r) => r.status < 400,
  });
  errorRate.add({{ endpoint.name_snake }}_resp.status >= 400);
  latencyTrend.add({{ endpoint.name_snake }}_resp.timings.duration);
{% endif %}

{% endfor %}
  sleep(1);
}
