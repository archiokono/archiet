	return EventResult{Status: "processed", EventID: event.ID}
}

func (h *EventHandler) sendToDLQ(event CloudEvent, errMsg string) {
	h.mu.Lock()
	defer h.mu.Unlock()
	h.dlq = append(h.dlq, DLQEntry{
		Event:    event,
