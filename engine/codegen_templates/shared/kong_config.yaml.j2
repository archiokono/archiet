{# app/modules/solutions_product/templates/shared/kong_config.yaml.j2 #}
{# Kong declarative config: routes, services, JWT plugin, rate-limiting. #}
{# Context: solution_id, bundle_id, solution_name, services (list) #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE

_format_version: "3.0"
_transform: true

services:
  - name: {{ solution_name | lower | replace(' ', '-') }}
    url: http://{{ solution_name | lower | replace(' ', '-') }}:8000
    connect_timeout: 5000
    read_timeout: 30000
    write_timeout: 30000
    retries: 3
    routes:
      - name: {{ solution_name | lower | replace(' ', '-') }}-route
        paths:
          - /api/{{ solution_name | lower | replace(' ', '-') }}
        strip_path: true
        methods:
          - GET
          - POST
          - PUT
          - DELETE
          - PATCH
          - OPTIONS
        protocols:
          - http
          - https
    plugins:
      # JWT authentication
      - name: jwt
        config:
          claims_to_verify:
            - exp
          key_claim_name: iss
          secret_is_base64: false
          run_on_preflight: true

      # Rate limiting
      - name: rate-limiting
        config:
          minute: 60
          hour: 1000
          policy: local
          fault_tolerant: true
          hide_client_headers: false

      # Request size limiting
      - name: request-size-limiting
        config:
          allowed_payload_size: 10
          size_unit: megabytes

      # CORS
      - name: cors
        config:
          origins:
            - "*"
          methods:
            - GET
            - POST
            - PUT
            - DELETE
            - PATCH
            - OPTIONS
          headers:
            - Content-Type
            - Authorization
            - X-Request-ID
          exposed_headers:
            - X-Request-ID
          max_age: 3600

      # Request/response logging
      - name: file-log
        config:
          path: /dev/stdout
          reopen: false

# Health check route (no auth required)
  - name: {{ solution_name | lower | replace(' ', '-') }}-health
    url: http://{{ solution_name | lower | replace(' ', '-') }}:8000/health
    routes:
      - name: {{ solution_name | lower | replace(' ', '-') }}-health-route
        paths:
          - /api/{{ solution_name | lower | replace(' ', '-') }}/health
        strip_path: true
        methods:
          - GET
