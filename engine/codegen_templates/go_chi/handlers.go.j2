package main

import (
	"context"
	"fmt"

	"github.com/jmoiron/sqlx"
	"github.com/rs/zerolog/log"
)

{% for model_name, model_def in models.items() %}
// {{ model_name }}Handler encapsulates business logic for {{ model_name }}.
// Spec version: {{ model_def.version | default(0) }}
// Spec hash: {{ model_def.hash | default('N/A') }}
type {{ model_name }}Handler struct {
	db *sqlx.DB
}

// New{{ model_name }}Handler creates a new handler with a database connection.
func New{{ model_name }}Handler(db *sqlx.DB) *{{ model_name }}Handler {
	return &{{ model_name }}Handler{db: db}
}

{% for rule in model_def.business_rules %}
// {{ rule.trigger | capitalize }}{{ model_name }} — {{ rule.type }}: {{ rule.entity }}.{{ rule.trigger }}
//
// Preconditions:
{% for pc in rule.preconditions %}
//   - {{ pc.field }} {{ pc.operator }} {{ pc.value }}
{% endfor %}
// Postconditions:
{% for post in rule.postconditions %}
//   - {{ post.field }} = {{ post.value }}
{% endfor %}
func (h *{{ model_name }}Handler) {{ rule.trigger | capitalize }}{{ model_name }}(ctx context.Context, entity *{{ model_name }}) error {
	logger := log.With().
		Str("handler", "{{ model_name }}Handler").
		Str("trigger", "{{ rule.trigger }}").
		Str("entity_type", "{{ model_name }}").
		Logger()

	logger.Info().Msg("state_transition_started")

	// Validate preconditions
{% for pc in rule.preconditions %}
{% if pc.operator == '==' %}
	if entity.{{ pc.field | capitalize }} != {{ pc.value | tojson }} {
		logger.Warn().
			Str("field", "{{ pc.field }}").
			Str("operator", "==").
			Msg("precondition_failed")
		return fmt.Errorf("precondition failed: {{ pc.field }} must be == {{ pc.value }}")
	}
{% elif pc.operator == '!=' %}
	if entity.{{ pc.field | capitalize }} == {{ pc.value | tojson }} {
		logger.Warn().
			Str("field", "{{ pc.field }}").
			Str("operator", "!=").
			Msg("precondition_failed")
		return fmt.Errorf("precondition failed: {{ pc.field }} must be != {{ pc.value }}")
	}
{% elif pc.operator == '>' %}
	if entity.{{ pc.field | capitalize }} <= {{ pc.value }} {
		logger.Warn().
			Str("field", "{{ pc.field }}").
			Str("operator", ">").
			Msg("precondition_failed")
		return fmt.Errorf("precondition failed: {{ pc.field }} must be > {{ pc.value }}")
	}
{% elif pc.operator == '>=' %}
	if entity.{{ pc.field | capitalize }} < {{ pc.value }} {
		logger.Warn().
			Str("field", "{{ pc.field }}").
			Str("operator", ">=").
			Msg("precondition_failed")
		return fmt.Errorf("precondition failed: {{ pc.field }} must be >= {{ pc.value }}")
	}
{% endif %}
{% endfor %}

	// Apply postconditions
{% for post in rule.postconditions %}
	entity.{{ post.field | capitalize }} = {{ post.value | tojson }}
{% endfor %}

{% if rule.side_effects %}
	// Side effects
{% for se in rule.side_effects %}
{% if se.type == 'event' %}
	logger.Info().Str("event", "{{ se.name }}").Msg("side_effect_event_queued")
	// Event: {{ se.name }} — wire to your message broker (Kafka/NATS/SQS) via the EventPublisher interface.
	// Example: h.events.Publish(ctx, "{{ se.name }}", map[string]string{"entity_id": entity.ID})
{% elif se.type == 'audit' %}
	logger.Info().Str("trigger", "{{ rule.trigger }}").Msg("side_effect_audit")
{% endif %}
{% endfor %}
{% endif %}

	// Persist changes to the database
{% if rule.postconditions %}
	if _, err := h.db.ExecContext(ctx,
		`UPDATE {{ model_def.table_name | default(model_name | lower ~ 's') }} SET {% for post in rule.postconditions %}{{ post.field | lower }} = ${{ loop.index }}{% if not loop.last %}, {% endif %}{% endfor %}, updated_at = NOW() WHERE id = ${{ rule.postconditions | length + 1 }}`,
		{% for post in rule.postconditions %}entity.{{ post.field | capitalize }}, {% endfor %}entity.ID,
	); err != nil {
		logger.Error().Err(err).Str("entity_id", entity.ID).Msg("persist_failed")
		return fmt.Errorf("persist {{ model_name | lower }}: %w", err)
	}
{% else %}
	if _, err := h.db.ExecContext(ctx,
		`UPDATE {{ model_def.table_name | default(model_name | lower ~ 's') }} SET updated_at = NOW() WHERE id = $1`,
		entity.ID,
	); err != nil {
		logger.Error().Err(err).Str("entity_id", entity.ID).Msg("persist_failed")
		return fmt.Errorf("persist {{ model_name | lower }}: %w", err)
	}
{% endif %}
	logger.Info().Msg("state_transition_completed")
	return nil
}

{% endfor %}
{% endfor %}
