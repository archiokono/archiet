{# app/modules/solutions_product/templates/shared/Makefile.j2 #}
{# Common build/run/deploy targets for the generated project. #}
{# Context: project_name, solution_id, bundle_id, language, image_name, #}
{#          test_command, lint_command, migrate_command, seed_command, #}
{#          staging_namespace, prod_namespace #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}

PROJECT  := {{ project_name }}
IMAGE    := {{ image_name | default(project_name) }}
ENV      ?= staging

.PHONY: dev mock test test-behavioral test-edge-cases test-security test-load test-all lint db-migrate db-seed infra-plan infra-apply deploy-staging deploy-prod clean

# ── Local Development ──────────────────────────────────────────────────────

dev:
	docker compose up -d --build
	@echo ""
	@echo "  $(PROJECT) is running"
	@echo "  App:     http://localhost:{{ port | default('8000') }}"
{% if language == 'python-fastapi' %}
	@echo "  Swagger: http://localhost:{{ port | default('8000') }}/docs"
{% endif %}
	@echo "  Health:  http://localhost:{{ port | default('8000') }}/health"

# ── Mock Server (zero dependencies) ──────────────────────────────────────

mock:
	python mock_server.py --port {{ port | default('8000') }}
	@echo "Mock server: http://localhost:{{ port | default('8000') }}"

# ── Testing ────────────────────────────────────────────────────────────────

test:
	docker compose run --rm app {{ test_command | default('pytest tests/ -v') }}

test-behavioral:
{% if language == 'python-fastapi' %}
	docker compose run --rm app pytest tests/test_behavioral.py -v
{% else %}
	docker compose run --rm app go test -run TestBehavioral -v ./...
{% endif %}

test-edge-cases:
{% if language == 'python-fastapi' %}
	docker compose run --rm app pytest tests/test_edge_cases.py -v
{% else %}
	docker compose run --rm app go test -run TestEdgeCase -v ./...
{% endif %}

test-security:
{% if language == 'python-fastapi' %}
	docker compose run --rm app pytest tests/test_security.py -v
{% else %}
	docker compose run --rm app go test -run "TestSecurity|TestCORS|TestRateLimit|TestInjection|TestAuth" -v ./...
{% endif %}

test-load:
	k6 run tests/k6_load_test.js --env BASE_URL=http://localhost:{{ port | default('8000') }}

test-all: test test-behavioral test-edge-cases test-security

lint:
	docker compose run --rm app {{ lint_command | default('ruff check .') }}

# ── Database ───────────────────────────────────────────────────────────────

db-migrate:
	docker compose run --rm app {{ migrate_command | default('alembic upgrade head') }}

db-seed:
	docker compose run --rm app {{ seed_command | default('python seed.py') }}

# ── Infrastructure (requires Terraform + cloud credentials) ───────────────

infra-plan:
	cd terraform && terraform init && terraform plan -var="environment=$(ENV)"

infra-apply:
	cd terraform && terraform init && terraform apply -auto-approve -var="environment=$(ENV)"

# ── Deploy ─────────────────────────────────────────────────────────────────

deploy-staging:
	kubectl apply -f k8s/ -n {{ staging_namespace | default(project_name ~ '-staging') }}
	kubectl rollout status deployment/$(PROJECT) -n {{ staging_namespace | default(project_name ~ '-staging') }} --timeout=120s

deploy-prod:
	kubectl apply -f k8s/ -n {{ prod_namespace | default(project_name ~ '-prod') }}
	kubectl rollout status deployment/$(PROJECT) -n {{ prod_namespace | default(project_name ~ '-prod') }} --timeout=120s

# ── Cleanup ────────────────────────────────────────────────────────────────

clean:
	docker compose down -v
	docker rmi $(IMAGE) 2>/dev/null || true
