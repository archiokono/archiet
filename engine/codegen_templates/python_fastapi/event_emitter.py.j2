"""
Centralized event emission for webhook delivery.

Call emit_event() from route handlers and state machine effects to trigger
webhook delivery to all matching subscriptions.

Events follow the pattern: {entity}.{action}
  - {entity}.created
  - {entity}.updated
  - {entity}.deleted
  - {entity}.status_changed

Usage in route handlers:
    from app.event_emitter import emit_event
    await emit_event(db, "work_order.created", {"id": obj.id, ...})
"""
import logging
from datetime import datetime, timezone

from sqlalchemy import select
from sqlalchemy.ext.asyncio import AsyncSession

logger = logging.getLogger(__name__)


async def emit_event(db: AsyncSession, event_type: str, payload: dict) -> int:
    """Queue webhook delivery for all subscriptions matching the event type.

    Args:
        db: Async database session.
        event_type: Event name, e.g. "work_order.created" or "work_order.status_changed".
        payload: Event payload dict (will be JSON-serialized).

    Returns:
        Number of webhook deliveries queued.
    """
    from app.webhook_service import WebhookSubscription, deliver_webhook

    # Find all active subscriptions that listen for this event
    result = await db.execute(
        select(WebhookSubscription).where(WebhookSubscription.is_active == True)
    )
    subscriptions = result.scalars().all()

    queued = 0
    envelope = {
        "event": event_type,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "data": payload,
    }

    for sub in subscriptions:
        # Match event: subscription can list specific events or use wildcards
        sub_events = sub.events or []
        if _event_matches(event_type, sub_events):
            try:
                await deliver_webhook(db, sub, event_type, envelope)
                queued += 1
            except Exception as exc:
                logger.error("Failed to queue webhook for subscription %d: %s", sub.id, exc)

    if queued:
        logger.info("Emitted '%s' → %d webhook(s) queued", event_type, queued)

    return queued


def _event_matches(event_type: str, subscribed_events: list[str]) -> bool:
    """Check if an event type matches any of the subscribed event patterns.

    Supports exact match and wildcard suffix:
      - "work_order.created" matches ["work_order.created"]
      - "work_order.created" matches ["work_order.*"]
      - "work_order.status_changed" matches ["*.status_changed"]
    """
    for pattern in subscribed_events:
        if pattern == event_type:
            return True
        if pattern == "*":
            return True
        if "*" in pattern:
            prefix, _, suffix = pattern.partition("*")
            if event_type.startswith(prefix) and event_type.endswith(suffix):
                return True
    return False


