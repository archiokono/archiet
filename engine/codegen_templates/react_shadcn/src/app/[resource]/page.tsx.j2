"use client"

import { useState, useEffect } from "react"
import Link from "next/link"
import { useQuery, useQueryClient } from "@tanstack/react-query"
import { {{ name | lower }}Api } from "@/lib/api"
import type { {{ name }} } from "@/lib/schemas"
import { Button } from "@/components/ui/button"
import { Input } from "@/components/ui/input"
import { Skeleton } from "@/components/ui/skeleton"
import {
  Table, TableBody, TableCell, TableHead, TableHeader, TableRow,
} from "@/components/ui/table"

{% set col_count = (fields | rejectattr('primary_key') | list | length) + 1 %}
const PAGE_SIZE = 25

export default function {{ name }}ListPage() {
  const queryClient = useQueryClient()
  const [search, setSearch] = useState("")
  const [debouncedSearch, setDebouncedSearch] = useState("")
  const [page, setPage] = useState(0)

  useEffect(() => {
    const t = setTimeout(() => { setDebouncedSearch(search); setPage(0) }, 300)
    return () => clearTimeout(t)
  }, [search])

  const params: Record<string, string> = {
    limit: String(PAGE_SIZE),
    offset: String(page * PAGE_SIZE),
  }
  if (debouncedSearch) params.search = debouncedSearch

  const { data: items = [], isLoading, isError, error } = useQuery<{{ name }}[]>({
    queryKey: ["{{ table_name }}", debouncedSearch, page],
    queryFn: () => {{ name | lower }}Api.list(params),
  })

  const hasNextPage = items.length === PAGE_SIZE

  if (isLoading) {
    return (
      <div className="space-y-3">
        <Skeleton className="h-8 w-48" />
        {Array.from({ length: 5 }).map((_, i) => (
          <Skeleton key={i} className="h-12 w-full" />
        ))}
      </div>
    )
  }

  if (isError) {
    return (
      <div className="rounded-md border border-destructive/50 bg-destructive/10 p-4 text-destructive text-sm">
        {error instanceof Error ? error.message : "Failed to load {{ name }} records"}
        <Button
          variant="outline"
          size="sm"
          className="ml-3"
          onClick={() => queryClient.invalidateQueries({ queryKey: ["{{ table_name }}"] })}
        >
          Retry
        </Button>
      </div>
    )
  }

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <h1 className="text-2xl font-bold">{{ name | replace('_', ' ') }}</h1>
        <Link href="/{{ table_name }}/new">
          <Button>New {{ name }}</Button>
        </Link>
      </div>
      <Input
        placeholder="Search {{ name | lower | replace('_', ' ') }}s..."
        value={search}
        onChange={(e) => setSearch(e.target.value)}
        className="max-w-sm"
      />
      <div className="rounded-md border border-border">
        <Table>
          <TableHeader>
            <TableRow>
              {% for field in fields[:6] %}{% if not field.primary_key %}
              <TableHead>{{ field.name | replace('_', ' ') | title }}</TableHead>
              {% endif %}{% endfor %}
              <TableHead className="w-[80px]">Actions</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {items.length === 0 ? (
              <TableRow>
                <TableCell colSpan={ {{ col_count }} } className="text-center text-muted-foreground py-8">
                  {debouncedSearch ? `No {{ name | lower | replace('_', ' ') }}s match "${debouncedSearch}"` : "No records yet."}
                </TableCell>
              </TableRow>
            ) : items.map((item) => (
              <TableRow key={item.id}>
                {% for field in fields[:6] %}{% if not field.primary_key %}
                <TableCell className="max-w-[200px] truncate">
                  {String(item.{{ field.name }} ?? "—")}
                </TableCell>
                {% endif %}{% endfor %}
                <TableCell>
                  <Link href={`/{{ table_name }}/${item.id}`} className="text-primary text-sm hover:underline">
                    Edit
                  </Link>
                </TableCell>
              </TableRow>
            ))}
          </TableBody>
        </Table>
      </div>
      {(page > 0 || hasNextPage) && (
        <div className="flex items-center justify-end gap-2 py-2">
          <Button
            variant="outline" size="sm"
            disabled={page === 0 || isLoading}
            onClick={() => setPage(p => Math.max(0, p - 1))}
          >
            Previous
          </Button>
          <span className="text-sm text-muted-foreground px-1">Page {page + 1}</span>
          <Button
            variant="outline" size="sm"
            disabled={!hasNextPage || isLoading}
            onClick={() => setPage(p => p + 1)}
          >
            Next
          </Button>
        </div>
      )}
    </div>
  )
}
