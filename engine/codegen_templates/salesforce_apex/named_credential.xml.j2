{# salesforce_apex/named_credential.xml.j2 #}
{# Generates Named Credential for external system callouts from integration flows. #}
{# Context: solution_id, integration_name, integration_def (protocol, auth_method, base_url) #}
<?xml version="1.0" encoding="UTF-8"?>
<!-- GENERATED BY ARCHIE — solution_id: {{ solution_id }} -->
<!-- x-archimate-source: {{ integration_def.archimate_source_id | default('N/A') }} -->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>{{ integration_name | replace('_', ' ') | title }}</label>
    <fullName>{{ integration_name }}</fullName>
    {% if integration_def.base_url %}
    <endpoint>{{ integration_def.base_url }}</endpoint>
    {% else %}
    <endpoint>https://api.example.com</endpoint>
    {% endif %}
    <principalType>NamedUser</principalType>
    {% if integration_def.auth_method == 'oauth2' %}
    <protocol>OAuth</protocol>
    <oauthScope>{{ integration_def.get('scope', 'api') }}</oauthScope>
    {% elif integration_def.auth_method == 'basic' %}
    <protocol>Password</protocol>
    {% elif integration_def.auth_method == 'certificate' or integration_def.auth_method == 'mtls' %}
    <protocol>Jwt</protocol>
    {% else %}
    <protocol>NoAuthentication</protocol>
    {% endif %}
    <generateAuthorizationHeader>true</generateAuthorizationHeader>
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>true</allowMergeFieldsInHeader>
</NamedCredential>
