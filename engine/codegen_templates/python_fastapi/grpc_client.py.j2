logger = logging.getLogger(__name__)


class RetryInterceptor(grpc.aio.UnaryUnaryClientInterceptor):
    """Client interceptor that retries on transient gRPC failures."""

    RETRYABLE_CODES = {
        grpc.StatusCode.UNAVAILABLE,
        grpc.StatusCode.DEADLINE_EXCEEDED,
        grpc.StatusCode.RESOURCE_EXHAUSTED,
    }

    def __init__(self, max_retries: int = 3, initial_backoff: float = 0.1):
        self._max_retries = max_retries
        self._initial_backoff = initial_backoff

    async def intercept_unary_unary(self, continuation, client_call_details, request):
        import asyncio
        last_error = None
        for attempt in range(self._max_retries + 1):
            try:
                response = await continuation(client_call_details, request)
                return response
            except grpc.aio.AioRpcError as exc:
                last_error = exc
                if exc.code() not in self.RETRYABLE_CODES or attempt == self._max_retries:
                    raise
                backoff = self._initial_backoff * (2 ** attempt)
                logger.warning(
                    "gRPC retry attempt=%d/%d code=%s backoff=%.2fs",
                    attempt + 1, self._max_retries, exc.code(), backoff,
                )
                await asyncio.sleep(backoff)
        raise last_error


