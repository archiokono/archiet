// ── JWKS key cache ──
// Keys are fetched from the IdP's JWKS endpoint and cached for 1 hour.

type jwksCache struct {
	mu        sync.RWMutex
	keys      []jwksKey
	fetchedAt time.Time
}

type jwksKey struct {
	Kid string `json:"kid"`
	Kty string `json:"kty"`
	Alg string `json:"alg"`
	Use string `json:"use"`
	N   string `json:"n"`
	E   string `json:"e"`
}

type jwksResponse struct {
	Keys []jwksKey `json:"keys"`
}

var (
	_jwksCache    = &jwksCache{}
	_jwksCacheTTL = 1 * time.Hour
	_httpClient   = &http.Client{Timeout: 10 * time.Second}
)

func (c *jwksCache) getKeys(jwksURI string) ([]jwksKey, error) {
	c.mu.RLock()
	if len(c.keys) > 0 && time.Since(c.fetchedAt) < _jwksCacheTTL {
		keys := c.keys
		c.mu.RUnlock()
		return keys, nil
	}
	c.mu.RUnlock()

	return c.refresh(jwksURI)
}

func (c *jwksCache) refresh(jwksURI string) ([]jwksKey, error) {
	c.mu.Lock()
	defer c.mu.Unlock()

	// Double-check after acquiring write lock
	if len(c.keys) > 0 && time.Since(c.fetchedAt) < _jwksCacheTTL {
		return c.keys, nil
	}

	resp, err := _httpClient.Get(jwksURI)
	if err != nil {
		if len(c.keys) > 0 {
			return c.keys, nil // Return stale keys rather than failing
		}
		return nil, fmt.Errorf("failed to fetch JWKS from %s: %w", jwksURI, err)
	}
	defer resp.Body.Close()

	body, err := io.ReadAll(resp.Body)
	if err != nil {
		return nil, fmt.Errorf("failed to read JWKS response: %w", err)
	}

	var jwks jwksResponse
	if err := json.Unmarshal(body, &jwks); err != nil {
		return nil, fmt.Errorf("failed to parse JWKS: %w", err)
	}

	c.keys = jwks.Keys
	c.fetchedAt = time.Now()
	return c.keys, nil
}

func (c *jwksCache) invalidate() {
	c.mu.Lock()
	c.fetchedAt = time.Time{}
	c.mu.Unlock()
}

func parseRSAPublicKey(key jwksKey) (*rsa.PublicKey, error) {
	nBytes, err := base64.RawURLEncoding.DecodeString(key.N)
	if err != nil {
		return nil, fmt.Errorf("failed to decode modulus: %w", err)
	}
	eBytes, err := base64.RawURLEncoding.DecodeString(key.E)
	if err != nil {
		return nil, fmt.Errorf("failed to decode exponent: %w", err)
	}

	n := new(big.Int).SetBytes(nBytes)
	e := new(big.Int).SetBytes(eBytes)

	return &rsa.PublicKey{
		N: n,
		E: int(e.Int64()),
	}, nil
}

// JWTAuthMiddleware validates the Authorization: Bearer <token> header using OIDC JWKS.
func JWTAuthMiddleware(next http.Handler) http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		cfg, err := LoadConfig()
		if err != nil {
			writeJSON(w, http.StatusInternalServerError, map[string]string{
				"error": "configuration error",
			})
			return
		}

		jwksURI := cfg.OIDCJwksURI
		if jwksURI == "" {
			jwksURI = "{{ identity_provider.get('jwks_uri', '') }}"
		}
		if jwksURI == "" {
			writeJSON(w, http.StatusInternalServerError, map[string]string{
				"error": "OIDC_JWKS_URI not configured",
			})
			return
		}

		authHeader := r.Header.Get("Authorization")
		if authHeader == "" || !strings.HasPrefix(authHeader, "Bearer ") {
			writeJSON(w, http.StatusUnauthorized, map[string]string{
				"error": "missing or invalid Authorization header",
			})
			return
		}

		tokenStr := strings.TrimPrefix(authHeader, "Bearer ")

		// Parse unverified to get kid
		parser := jwt.NewParser()
		unverified, _, err := parser.ParseUnverified(tokenStr, jwt.MapClaims{})
		if err != nil {
			writeJSON(w, http.StatusUnauthorized, map[string]string{
				"error": fmt.Sprintf("invalid token: %v", err),
			})
			return
		}

		kid, _ := unverified.Header["kid"].(string)
		if kid == "" {
			writeJSON(w, http.StatusUnauthorized, map[string]string{
				"error": "token missing kid header",
			})
			return
		}

		// Find signing key from JWKS
		keys, err := _jwksCache.getKeys(jwksURI)
		if err != nil {
			writeJSON(w, http.StatusServiceUnavailable, map[string]string{
				"error": fmt.Sprintf("JWKS fetch failed: %v", err),
			})
			return
		}

		var signingKey *rsa.PublicKey
		for _, k := range keys {
			if k.Kid == kid {
				signingKey, err = parseRSAPublicKey(k)
				if err != nil {
					writeJSON(w, http.StatusInternalServerError, map[string]string{
						"error": "failed to parse signing key",
					})
					return
				}
				break
			}
		}

		// If kid not found, try refreshing JWKS (key rotation)
		if signingKey == nil {
			_jwksCache.invalidate()
			keys, err = _jwksCache.getKeys(jwksURI)
			if err == nil {
				for _, k := range keys {
					if k.Kid == kid {
						signingKey, err = parseRSAPublicKey(k)
						break
					}
				}
			}
		}

		if signingKey == nil {
			writeJSON(w, http.StatusUnauthorized, map[string]string{
				"error": fmt.Sprintf("no matching JWKS key for kid=%s", kid),
			})
			return
		}

		// Verify token with RSA public key
		token, err := jwt.Parse(tokenStr, func(t *jwt.Token) (interface{}, error) {
			if _, ok := t.Method.(*jwt.SigningMethodRSA); !ok {
				return nil, fmt.Errorf("unexpected signing method: %v", t.Header["alg"])
			}
			return signingKey, nil
		}, jwt.WithIssuer(cfg.OIDCIssuer), jwt.WithAudience(cfg.OIDCAudience))

		if err != nil || !token.Valid {
			writeJSON(w, http.StatusUnauthorized, map[string]string{
				"error": fmt.Sprintf("invalid token: %v", err),
			})
			return
		}

		mapClaims, ok := token.Claims.(jwt.MapClaims)
		if !ok {
			writeJSON(w, http.StatusUnauthorized, map[string]string{
				"error": "invalid token claims",
			})
			return
		}

		// Check expiration
		if exp, ok := mapClaims["exp"].(float64); ok {
			if time.Unix(int64(exp), 0).Before(time.Now()) {
				writeJSON(w, http.StatusForbidden, map[string]string{
					"error": "token expired",
				})
				return
			}
		}

		// Extract claims with provider-specific role claim
		claims := TokenClaims{
			Sub: mapClaimString(mapClaims, "sub"),
			Iss: mapClaimString(mapClaims, "iss"),
		}
		if exp, ok := mapClaims["exp"].(float64); ok {
			claims.Exp = int64(exp)
		}
		claims.Roles = extractRoles(mapClaims)

		ctx := context.WithValue(r.Context(), ContextKeyClaims, &claims)
		next.ServeHTTP(w, r.WithContext(ctx))
	})
}

// extractRoles extracts roles from JWT claims using the provider-specific claim path.
func extractRoles(claims jwt.MapClaims) []string {
	claimPath := "{{ identity_provider.get('role_claim', 'roles') }}"
	parts := strings.Split(claimPath, ".")

	var current interface{} = map[string]interface{}(claims)
	for _, part := range parts {
		m, ok := current.(map[string]interface{})
		if !ok {
			return nil
		}
		current = m[part]
		if current == nil {
			return nil
		}
	}

	roles, ok := current.([]interface{})
	if !ok {
		// Single string role
		if s, ok := current.(string); ok {
			return mapRoles([]string{s})
		}
		return nil
	}

	var result []string
	for _, role := range roles {
		if s, ok := role.(string); ok {
			result = append(result, s)
		}
	}
	return mapRoles(result)
}

// mapRoles maps IdP role names to application roles using configured mapping.
func mapRoles(raw []string) []string {
{% if identity_provider and identity_provider.get("role_mapping") %}
	mapped := make([]string, 0, len(raw))
	seen := make(map[string]bool)
	for _, r := range raw {
		if m, ok := roleMapping[r]; ok {
			if !seen[m] {
				mapped = append(mapped, m)
				seen[m] = true
			}
		} else {
			if !seen[r] {
				mapped = append(mapped, r)
				seen[r] = true
			}
		}
	}
	return mapped
{% else %}
	return raw
{% endif %}
