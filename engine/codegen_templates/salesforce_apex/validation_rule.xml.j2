{# salesforce_apex/validation_rule.xml.j2 #}
{# Generates Salesforce Validation Rule metadata from ArchiMate Constraint/Requirement elements. #}
{# Context: solution_id, model_name, rule_name, rule (with field, rule_type, value, description) #}
<?xml version="1.0" encoding="UTF-8"?>
<!-- GENERATED BY ARCHIE — solution_id: {{ solution_id }} -->
<!-- x-archimate-source: {{ rule.source_id | default('N/A') }} -->
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>{{ rule_name }}</fullName>
    <active>true</active>
    <description>{{ rule.description | default('Generated from architecture constraint') }}</description>
    {% if rule.rule_type == 'required' %}
    <errorConditionFormula>ISBLANK({{ rule.field }}__c)</errorConditionFormula>
    <errorDisplayField>{{ rule.field }}__c</errorDisplayField>
    <errorMessage>{{ rule.field | replace('_', ' ') | title }} is required.</errorMessage>
    {% elif rule.rule_type == 'min_length' %}
    <errorConditionFormula>LEN({{ rule.field }}__c) &lt; {{ rule.value }}</errorConditionFormula>
    <errorDisplayField>{{ rule.field }}__c</errorDisplayField>
    <errorMessage>{{ rule.field | replace('_', ' ') | title }} must be at least {{ rule.value }} characters.</errorMessage>
    {% elif rule.rule_type == 'max_length' %}
    <errorConditionFormula>LEN({{ rule.field }}__c) &gt; {{ rule.value }}</errorConditionFormula>
    <errorDisplayField>{{ rule.field }}__c</errorDisplayField>
    <errorMessage>{{ rule.field | replace('_', ' ') | title }} must not exceed {{ rule.value }} characters.</errorMessage>
    {% elif rule.rule_type == 'range' %}
    <errorConditionFormula>OR({{ rule.field }}__c &lt; {{ rule.min | default(0) }}, {{ rule.field }}__c &gt; {{ rule.max | default(999999) }})</errorConditionFormula>
    <errorDisplayField>{{ rule.field }}__c</errorDisplayField>
    <errorMessage>{{ rule.field | replace('_', ' ') | title }} must be between {{ rule.min | default(0) }} and {{ rule.max | default(999999) }}.</errorMessage>
    {% elif rule.rule_type == 'regex' %}
    <errorConditionFormula>NOT(REGEX({{ rule.field }}__c, "{{ rule.value }}"))</errorConditionFormula>
    <errorDisplayField>{{ rule.field }}__c</errorDisplayField>
    <errorMessage>{{ rule.field | replace('_', ' ') | title }} format is invalid.</errorMessage>
    {% elif rule.rule_type == 'unique' %}
    {# Unique is handled at the field level, not as a validation rule #}
    <errorConditionFormula>false</errorConditionFormula>
    <errorMessage>Placeholder — uniqueness enforced at field level.</errorMessage>
    {% else %}
    {# Generic formula-based rule #}
    <errorConditionFormula>{{ rule.formula | default('false') }}</errorConditionFormula>
    <errorMessage>{{ rule.description | default('Validation failed.') }}</errorMessage>
    {% endif %}
</ValidationRule>
