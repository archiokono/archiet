{# app/modules/solutions_product/templates/shared/istio_virtual_service.yaml.j2 #}
{# Istio VirtualService + DestinationRule per service. #}
{# Context: solution_id, bundle_id, solution_name, services (list) #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE
---
apiVersion: networking.istio.io/v1beta1
kind: VirtualService
metadata:
  name: {{ solution_name | lower | replace(' ', '-') }}
  labels:
    app: {{ solution_name | lower | replace(' ', '-') }}
    generated-by: archie
spec:
  hosts:
    - {{ solution_name | lower | replace(' ', '-') }}
  http:
    - match:
        - uri:
            prefix: /
      route:
        - destination:
            host: {{ solution_name | lower | replace(' ', '-') }}
            port:
              number: 8000
          weight: 100
      retries:
        attempts: 3
        perTryTimeout: 5s
        retryOn: 5xx,reset,connect-failure,retriable-4xx
      timeout: 30s
      fault:
        delay:
          percentage:
            value: 0
          fixedDelay: 0s
---
apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: {{ solution_name | lower | replace(' ', '-') }}
  labels:
    app: {{ solution_name | lower | replace(' ', '-') }}
    generated-by: archie
spec:
  host: {{ solution_name | lower | replace(' ', '-') }}
  trafficPolicy:
    connectionPool:
      tcp:
        maxConnections: 100
        connectTimeout: 5s
      http:
        h2UpgradePolicy: DEFAULT
        maxRequestsPerConnection: 100
    outlierDetection:
      consecutive5xxErrors: 5
      interval: 30s
      baseEjectionTime: 30s
      maxEjectionPercent: 50
    tls:
      mode: ISTIO_MUTUAL
