{# app/modules/solutions_product/templates/shared/env_example.j2 #}
{# .env.example with all required env vars documented. #}
{# Context: project_name, solution_id, bundle_id, db_name, #}
{#          identity_provider, integrations, port #}
# {{ project_name }} — Environment Configuration
# Generated by A.R.C.H.I.E. from Solution #{{ solution_id }}
# Bundle: {{ bundle_id }}
#
# Copy to .env and fill in values before running bootstrap.sh or make dev.

# ── Application ────────────────────────────────────────────────────────────
ENV=development
API_PORT={{ port | default('8000') }}
FRONTEND_PORT=3000
LOG_LEVEL=info

# ── Security ───────────────────────────────────────────────────────────────
# Generated automatically by bootstrap.sh — DO NOT commit real values
SECRET_KEY=CHANGE_THIS_IMMEDIATELY
JWT_SECRET=CHANGE_THIS_IMMEDIATELY
ADMIN_EMAIL=admin@{{ project_name | lower | replace(' ', '-') }}.internal
ADMIN_PASSWORD=CHANGE_THIS_IMMEDIATELY

# CORS: comma-separated list of allowed origins (no wildcards in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Maximum items returned per page on list endpoints
MAX_PAGE_SIZE=200

# ── Database ───────────────────────────────────────────────────────────────
# Used by docker-compose — change POSTGRES_PASSWORD before deploying
POSTGRES_DB={{ db_name | default(project_name) }}
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme  # secrets-safety-ok — template placeholder for generated .env.example

# Direct URL for local development outside Docker
DATABASE_URL=postgresql+asyncpg://app:changeme@localhost:5432/{{ db_name | default(project_name) }}  # secrets-safety-ok

{% if identity_provider and identity_provider.type | default('') == 'oidc' %}
# ── Auth (OIDC) ───────────────────────────────────────────────────────────
OIDC_ISSUER={{ identity_provider.issuer_url | default('https://auth.example.com') }}
OIDC_CLIENT_ID=your-client-id-here
OIDC_CLIENT_SECRET=your-client-secret-here
OIDC_AUDIENCE={{ identity_provider.audience | default('') }}
{% else %}
# ── Auth (JWT) ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=
{% endif %}

{% if integrations %}
# ── Integration Endpoints ─────────────────────────────────────────────────
{% for name, contract in integrations.items() %}
{% set env_var = name | upper | replace('-', '_') | replace(' ', '_') %}
{{ env_var }}_BASE_URL={{ contract.base_url | default('https://api.example.com') if contract is mapping else 'https://api.example.com' }}
{% endfor %}
{% endif %}

# ── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME={{ project_name }}
