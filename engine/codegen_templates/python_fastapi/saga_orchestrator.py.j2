class SagaOrchestrator:
    """Execute a sequence of steps with compensation on failure.

    Usage:
        saga = SagaOrchestrator("create-order")
        saga.add_step("reserve_inventory", reserve, compensate=release)
        saga.add_step("charge_payment", charge, compensate=refund)
        saga.add_step("send_confirmation", notify)
        result = await saga.execute(context={"order_id": "123"})
    """

    def __init__(self, name: str, timeout_seconds: float = 300.0):
        self._state = SagaState(name=name)
        self._timeout_seconds = timeout_seconds

    @property
    def state(self) -> SagaState:
        return self._state

    def add_step(
        self,
        name: str,
        action: Callable[..., Coroutine],
        compensation: Optional[Callable[..., Coroutine]] = None,
        timeout_seconds: float = 30.0,
    ):
        """Add a step to the saga."""
        self._state.steps.append(SagaStep(
            name=name,
            action=action,
            compensation=compensation,
            timeout_seconds=timeout_seconds,
        ))

    async def execute(self, context: Optional[dict] = None) -> SagaState:
        """Execute all steps. On failure, compensate completed steps in reverse."""
        self._state.context = context or {}
        self._state.status = SagaStatus.RUNNING
        self._state.started_at = time.time()

        logger.info("Saga %s started: %s", self._state.name, self._state.saga_id)

        completed_steps: list[SagaStep] = []

        for step in self._state.steps:
            # Check saga-level timeout
            elapsed = time.time() - self._state.started_at
            if elapsed > self._timeout_seconds:
                self._state.status = SagaStatus.TIMED_OUT
                self._state.error = f"Saga timed out after {elapsed:.1f}s"
                logger.error("Saga %s timed out", self._state.name)
                await self._compensate(completed_steps)
                break

            step.status = StepStatus.RUNNING
            step.started_at = time.time()

            try:
                step.result = await asyncio.wait_for(
                    step.action(self._state.context),
                    timeout=step.timeout_seconds,
                )
                step.status = StepStatus.COMPLETED
                step.completed_at = time.time()
                completed_steps.append(step)
                logger.info(
                    "Saga %s step '%s' completed in %.0fms",
                    self._state.name,
                    step.name,
                    (step.completed_at - step.started_at) * 1000,
                )
            except asyncio.TimeoutError:
                step.status = StepStatus.FAILED
                step.error = f"Step timed out after {step.timeout_seconds}s"
                step.completed_at = time.time()
                self._state.status = SagaStatus.FAILED
                self._state.error = f"Step '{step.name}' timed out"
                logger.error("Saga %s step '%s' timed out", self._state.name, step.name)
                await self._compensate(completed_steps)
                break
            except Exception as exc:
                step.status = StepStatus.FAILED
                step.error = str(exc)
                step.completed_at = time.time()
                self._state.status = SagaStatus.FAILED
                self._state.error = f"Step '{step.name}' failed: {exc}"
                logger.error(
                    "Saga %s step '%s' failed: %s",
                    self._state.name, step.name, exc,
                )
                await self._compensate(completed_steps)
                break
        else:
            # All steps completed successfully
            self._state.status = SagaStatus.COMPLETED
            self._state.completed_at = time.time()
            logger.info("Saga %s completed successfully", self._state.name)

        return self._state

    async def _compensate(self, completed_steps: list[SagaStep]):
        """Run compensation handlers in reverse order."""
        if not completed_steps:
            return

        self._state.status = SagaStatus.COMPENSATING
        logger.info(
            "Saga %s compensating %d steps",
            self._state.name, len(completed_steps),
        )

        for step in reversed(completed_steps):
            if not step.compensation:
                logger.debug("Step '%s' has no compensation — skipping", step.name)
                continue
            try:
                await asyncio.wait_for(
                    step.compensation(self._state.context),
                    timeout=step.timeout_seconds,
                )
                step.status = StepStatus.COMPENSATED
                logger.info("Saga %s: compensated step '%s'", self._state.name, step.name)
            except Exception as exc:
                logger.error(
                    "Saga %s: compensation failed for step '%s': %s",
                    self._state.name, step.name, exc,
                )
                # Compensation failure is logged but does not stop other compensations

        self._state.status = SagaStatus.FAILED
        self._state.completed_at = time.time()


