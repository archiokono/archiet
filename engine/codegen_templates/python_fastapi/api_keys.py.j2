"""
API Key Management

Provides machine-to-machine authentication for B2B integrations.
Supports: key creation, rotation, revocation, scoped permissions,
usage tracking, and rate limiting per key.

Authentication: Include `X-API-Key: <key>` header in requests.
The key is verified against a hashed store (never stored in plaintext).
"""
import hashlib
import logging
import secrets
import uuid
from datetime import datetime, timezone
from typing import Optional

from fastapi import APIRouter, Depends, HTTPException, Request, Security
from fastapi.security import APIKeyHeader
from pydantic import BaseModel, Field
from sqlalchemy import Column, DateTime, Integer, String, Boolean, JSON
from sqlalchemy.orm import Session

from app.database import Base, get_db

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/api/keys", tags=["API Keys"])

# Security scheme
api_key_header = APIKeyHeader(name="X-API-Key", auto_error=False)


# ── Model ──

class APIKey(Base):
    __tablename__ = "api_keys"
    __table_args__ = {"extend_existing": True}

    id = Column(String(36), primary_key=True, default=lambda: str(uuid.uuid4()))
    name = Column(String(255), nullable=False)
    key_prefix = Column(String(8), nullable=False, index=True)
    key_hash = Column(String(128), nullable=False, unique=True)
    scopes = Column(JSON, default=list)
    rate_limit = Column(Integer, default=1000)  # requests per hour
    organization_id = Column(String(64), nullable=False, index=True)
    created_by_id = Column(String(36), nullable=False)
    is_active = Column(Boolean, default=True, nullable=False)
    last_used_at = Column(DateTime, nullable=True)
    usage_count = Column(Integer, default=0)
    expires_at = Column(DateTime, nullable=True)
    created_at = Column(DateTime, default=lambda: datetime.now(timezone.utc))
    revoked_at = Column(DateTime, nullable=True)


# ── Schemas ──

class APIKeyCreate(BaseModel):
    name: str = Field(..., min_length=1, max_length=255)
    scopes: list[str] = Field(default=["read"])
    rate_limit: int = Field(default=1000, ge=1, le=100000)
    expires_in_days: Optional[int] = Field(default=None, ge=1, le=365)


class APIKeyResponse(BaseModel):
    id: str
    name: str
    key_prefix: str
    scopes: list[str]
    rate_limit: int
    is_active: bool
    last_used_at: Optional[datetime]
    usage_count: int
    expires_at: Optional[datetime]
    created_at: datetime

    class Config:
        from_attributes = True


class APIKeyCreated(APIKeyResponse):
    """Returned only on creation — includes the full key (shown once)."""
    key: str


# ── Key hashing ──

def _hash_key(raw_key: str) -> str:
    """Hash an API key using SHA-256. Keys are never stored in plaintext."""
    return hashlib.sha256(raw_key.encode()).hexdigest()


def _generate_key() -> tuple[str, str, str]:
    """Generate a new API key. Returns (full_key, prefix, hash)."""
    raw = secrets.token_urlsafe(32)
    prefix = raw[:8]
    key_hash = _hash_key(raw)
    return raw, prefix, key_hash


# ── Authentication dependency ──

async def verify_api_key(
    api_key: Optional[str] = Security(api_key_header),
    db: Session = Depends(get_db),
) -> Optional[APIKey]:
    """Verify an API key from the X-API-Key header.

    Returns the APIKey record if valid, None if no key provided.
    Raises 401 if the key is invalid, revoked, or expired.
    """
    if not api_key:
        return None

    key_hash = _hash_key(api_key)
    record = db.query(APIKey).filter(
        APIKey.key_hash == key_hash,
        APIKey.is_active == True,
    ).first()

    if not record:
        raise HTTPException(status_code=401, detail="Invalid API key")

    if record.expires_at and record.expires_at < datetime.now(timezone.utc):
        raise HTTPException(status_code=401, detail="API key expired")

    # Update usage tracking
    record.last_used_at = datetime.now(timezone.utc)
    record.usage_count = (record.usage_count or 0) + 1
    db.commit()

    return record


def require_scope(scope: str):
    """Dependency factory that checks if the API key has the required scope."""
    async def _check(key: Optional[APIKey] = Depends(verify_api_key)):
        if key is None:
            raise HTTPException(status_code=401, detail="API key required")
        if scope not in (key.scopes or []) and "*" not in (key.scopes or []):
            raise HTTPException(
                status_code=403,
                detail=f"API key missing required scope: {scope}",
            )
        return key
    return _check


# ── CRUD Routes ──

@router.post("", response_model=APIKeyCreated)
def create_api_key(
    body: APIKeyCreate,
    request: Request,
    db: Session = Depends(get_db),
):
    """Create a new API key. The full key is returned ONCE — store it securely."""
    raw_key, prefix, key_hash = _generate_key()

    expires_at = None
    if body.expires_in_days:
        from datetime import timedelta
        expires_at = datetime.now(timezone.utc) + timedelta(days=body.expires_in_days)

    # Get org_id and user_id from request context (set by auth middleware)
    org_id = getattr(request.state, "org_id", "default")
    user_id = getattr(request.state, "user_id", "system")

    record = APIKey(
        name=body.name,
        key_prefix=prefix,
        key_hash=key_hash,
        scopes=body.scopes,
        rate_limit=body.rate_limit,
        organization_id=str(org_id),
        created_by_id=str(user_id),
        expires_at=expires_at,
    )
    db.add(record)
    db.commit()
    db.refresh(record)

    logger.info("API key created: name=%s, prefix=%s, org=%s", body.name, prefix, org_id)

    return APIKeyCreated(
        id=record.id,
        name=record.name,
        key_prefix=record.key_prefix,
        key=raw_key,  # Only returned on creation
        scopes=record.scopes or [],
        rate_limit=record.rate_limit,
        is_active=record.is_active,
        last_used_at=record.last_used_at,
        usage_count=record.usage_count or 0,
        expires_at=record.expires_at,
        created_at=record.created_at,
    )


@router.get("", response_model=list[APIKeyResponse])
def list_api_keys(request: Request, db: Session = Depends(get_db)):
    """List all API keys for the current organization."""
    org_id = getattr(request.state, "org_id", "default")
    keys = db.query(APIKey).filter(
        APIKey.organization_id == str(org_id),
    ).order_by(APIKey.created_at.desc()).all()
    return keys


@router.delete("/{key_id}")
def revoke_api_key(key_id: str, request: Request, db: Session = Depends(get_db)):
    """Revoke an API key. This is permanent — revoked keys cannot be reactivated."""
    org_id = getattr(request.state, "org_id", "default")
    record = db.query(APIKey).filter(
        APIKey.id == key_id,
        APIKey.organization_id == str(org_id),
    ).first()

    if not record:
        raise HTTPException(status_code=404, detail="API key not found")

    record.is_active = False
    record.revoked_at = datetime.now(timezone.utc)
    db.commit()

    logger.info("API key revoked: id=%s, prefix=%s", key_id, record.key_prefix)
    return {"status": "revoked", "id": key_id}


@router.post("/{key_id}/rotate", response_model=APIKeyCreated)
def rotate_api_key(key_id: str, request: Request, db: Session = Depends(get_db)):
    """Rotate an API key. Revokes the old key and creates a new one with the same config."""
    org_id = getattr(request.state, "org_id", "default")
    old_record = db.query(APIKey).filter(
        APIKey.id == key_id,
        APIKey.organization_id == str(org_id),
        APIKey.is_active == True,
    ).first()

    if not old_record:
        raise HTTPException(status_code=404, detail="API key not found or already revoked")

    # Revoke old key
    old_record.is_active = False
    old_record.revoked_at = datetime.now(timezone.utc)

    # Create new key with same config
    raw_key, prefix, key_hash = _generate_key()
    new_record = APIKey(
        name=old_record.name,
        key_prefix=prefix,
        key_hash=key_hash,
        scopes=old_record.scopes,
        rate_limit=old_record.rate_limit,
        organization_id=old_record.organization_id,
        created_by_id=getattr(request.state, "user_id", "system"),
        expires_at=old_record.expires_at,
    )
    db.add(new_record)
    db.commit()
    db.refresh(new_record)

    logger.info("API key rotated: old=%s, new_prefix=%s", key_id, prefix)

    return APIKeyCreated(
        id=new_record.id,
        name=new_record.name,
        key_prefix=new_record.key_prefix,
        key=raw_key,
        scopes=new_record.scopes or [],
        rate_limit=new_record.rate_limit,
        is_active=new_record.is_active,
        last_used_at=new_record.last_used_at,
        usage_count=new_record.usage_count or 0,
        expires_at=new_record.expires_at,
        created_at=new_record.created_at,
    )
