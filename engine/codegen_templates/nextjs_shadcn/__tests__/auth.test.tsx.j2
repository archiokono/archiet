// Login
// ---------------------------------------------------------------------------
describe('Login page', () => {
  it('renders email and password fields with submit button', () => {
    render(<LoginPage />, { wrapper: Wrapper });
    expect(screen.getByLabelText(/email/i)).toBeInTheDocument();
    expect(screen.getByLabelText(/password/i)).toBeInTheDocument();
    expect(screen.getByRole('button', { name: /sign in|log in/i })).toBeInTheDocument();
  });

  it('shows validation error if email is invalid', async () => {
    render(<LoginPage />, { wrapper: Wrapper });
    await userEvent.type(screen.getByLabelText(/email/i), 'not-an-email');
    await userEvent.type(screen.getByLabelText(/password/i), 'anything');
    await userEvent.click(screen.getByRole('button', { name: /sign in|log in/i }));
    await waitFor(() => expect(screen.getByRole('alert')).toBeInTheDocument());
  });

  it('redirects to dashboard on valid credentials', async () => {
    render(<LoginPage />, { wrapper: Wrapper });
    await userEvent.type(screen.getByLabelText(/email/i), 'test@example.com');
    await userEvent.type(screen.getByLabelText(/password/i), 'Valid@123');
    await userEvent.click(screen.getByRole('button', { name: /sign in|log in/i }));
    await waitFor(() => expect(mockPush).toHaveBeenCalledWith(expect.stringMatching(/dashboard|\//)));
  });

  it('shows error banner on invalid credentials', async () => {
    render(<LoginPage />, { wrapper: Wrapper });
    await userEvent.type(screen.getByLabelText(/email/i), 'test@example.com');
    await userEvent.type(screen.getByLabelText(/password/i), 'WrongPassword');
    await userEvent.click(screen.getByRole('button', { name: /sign in|log in/i }));
    await waitFor(() => expect(screen.getByRole('alert')).toHaveTextContent(/invalid|credentials|wrong/i));
  });

  it('does NOT store plain password in localStorage or sessionStorage', async () => {
    render(<LoginPage />, { wrapper: Wrapper });
    await userEvent.type(screen.getByLabelText(/email/i), 'test@example.com');
    await userEvent.type(screen.getByLabelText(/password/i), 'Valid@123');
    await userEvent.click(screen.getByRole('button', { name: /sign in|log in/i }));
    await waitFor(() => expect(mockPush).toHaveBeenCalled());
    const allStorage = {
      ...Object.fromEntries(Object.entries(localStorage)),
      ...Object.fromEntries(Object.entries(sessionStorage)),
    };
    const values = Object.values(allStorage).join(' ');
    expect(values).not.toContain('Valid@123');
  });

  it('disables submit button while request is in-flight', async () => {
    let resolveRequest: () => void;
    server.use(
      rest.post(`${BASE}/api/v1/auth/token`, (_req, res, ctx) =>
        new Promise<ReturnType<typeof res>>((resolve) => {
          resolveRequest = () => resolve(res(ctx.json({ access_token: validToken, token_type: 'bearer', expires_in: 3600 })));
          setTimeout(resolveRequest, 2000);
        })
      )
    );
    render(<LoginPage />, { wrapper: Wrapper });
    await userEvent.type(screen.getByLabelText(/email/i), 'test@example.com');
    await userEvent.type(screen.getByLabelText(/password/i), 'Valid@123');
    const btn = screen.getByRole('button', { name: /sign in|log in/i });
    await userEvent.click(btn);
    expect(btn).toBeDisabled();
  });
});

