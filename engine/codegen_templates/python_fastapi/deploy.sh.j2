{# deploy.sh.j2 — One-command deploy script with platform auto-detection.
   Context: solution_id, solution_name #}
#!/bin/bash
# GENERATED BY ARCHIE — solution {{ solution_id }}
# One-command deploy for {{ solution_name }}
# Usage: ./deploy.sh [platform]
# Supported: railway, fly, render, docker

set -e

APP_NAME="{{ solution_name | lower | replace(' ', '-') | replace('_', '-') }}"
IMAGE_NAME="${APP_NAME}:latest"

echo "🚀 Deploying ${APP_NAME}..."

# Auto-detect platform
PLATFORM="${1:-auto}"
if [ "$PLATFORM" = "auto" ]; then
    if command -v railway &>/dev/null; then
        PLATFORM="railway"
    elif command -v flyctl &>/dev/null; then
        PLATFORM="fly"
    elif command -v render &>/dev/null; then
        PLATFORM="render"
    else
        PLATFORM="docker"
    fi
fi

echo "Platform: ${PLATFORM}"

case "$PLATFORM" in
    railway)
        echo "Deploying to Railway..."
        railway up --detach
        railway domain
        echo "✅ Deployed to Railway"
        ;;
    fly)
        echo "Deploying to Fly.io..."
        if ! flyctl apps list | grep -q "$APP_NAME"; then
            flyctl launch --name "$APP_NAME" --no-deploy --region iad
        fi
        flyctl deploy
        flyctl open
        echo "✅ Deployed to Fly.io"
        ;;
    render)
        echo "Deploying to Render..."
        echo "Push to your git repository — Render auto-deploys from the Dockerfile."
        echo "Or create a new Web Service at https://dashboard.render.com/new/web"
        echo "  - Environment: Docker"
        echo "  - Build Command: (auto from Dockerfile)"
        echo "  - Start Command: (auto from Dockerfile)"
        ;;
    docker)
        echo "Building and running locally with Docker Compose..."
        docker compose up -d --build
        echo "✅ Running at http://localhost:8000"
        echo "   API docs: http://localhost:8000/docs"
        echo "   Health:   http://localhost:8000/health"
        ;;
    *)
        echo "Unknown platform: $PLATFORM"
        echo "Usage: ./deploy.sh [railway|fly|render|docker]"
        exit 1
        ;;
esac
