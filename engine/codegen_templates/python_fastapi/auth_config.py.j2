def _map_roles(raw_roles: list[str]) -> list[str]:
    """Map IdP group/role names to application roles using configured mapping.

    If no mapping is configured, roles pass through unchanged.
    """
    if not _ROLE_MAPPING:
        return raw_roles
    mapped = []
    for role in raw_roles:
        if role in _ROLE_MAPPING:
            mapped.append(_ROLE_MAPPING[role])
        else:
            mapped.append(role)
    return list(set(mapped))


def _extract_roles(payload: dict) -> list[str]:
    """Extract roles from JWT payload using the provider-specific claim path.

    Supports dotted paths like 'realm_access.roles' for Keycloak.
    """
{% if identity_provider and identity_provider.get("role_claim") %}
    claim_path = "{{ identity_provider.get('role_claim', 'roles') }}"
{% else %}
    claim_path = "roles"
{% endif %}
    parts = claim_path.split(".")
    value = payload
    for part in parts:
        if isinstance(value, dict):
            value = value.get(part)
        else:
            return []
        if value is None:
            return []

    if isinstance(value, list):
        return _map_roles([str(v) for v in value])
    if isinstance(value, str):
        return _map_roles([value])
    return []


