# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}

APP_NAME := {{ solution_name | default('archie-service') | lower | replace(' ', '-') }}
BUILD_DIR := ./bin
MAIN := ./main.go

.PHONY: run test build migrate lint clean docker-build docker-run

## run: Start the server in development mode
run:
	go run $(MAIN)

## test: Run all tests with verbose output
test:
	go test -v -count=1 -race ./...

## build: Compile the binary
build:
	CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o $(BUILD_DIR)/$(APP_NAME) $(MAIN)

## migrate: Run database migration
migrate:
	go run $(MAIN) migrate

## lint: Run golangci-lint
lint:
	golangci-lint run ./...

## clean: Remove build artifacts
clean:
	rm -rf $(BUILD_DIR)

## docker-build: Build Docker image
docker-build:
	docker build -t $(APP_NAME):latest .

## docker-run: Run Docker container
docker-run:
	docker run -p 8080:8080 --env-file .env $(APP_NAME):latest
