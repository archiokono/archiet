# Admin bootstrap — seeds the first admin user on startup.

import os
import logging

from sqlalchemy import select
from sqlalchemy.ext.asyncio import AsyncSession

logger = logging.getLogger(__name__)


async def seed_admin(db: AsyncSession) -> None:
    """Create an admin user if none exists.

    Reads ADMIN_EMAIL and ADMIN_PASSWORD from environment variables.
    Skips silently if env vars are not set or an admin already exists.
    Called once from main.py lifespan after init_db().
    """
    from app.models.user import User

    admin_email = os.environ.get("ADMIN_EMAIL", "").strip()
    admin_password = os.environ.get("ADMIN_PASSWORD", "").strip()

    if not admin_email or not admin_password:
        logger.info("ADMIN_EMAIL/ADMIN_PASSWORD not set — skipping admin bootstrap")
        return

    # Check if any admin already exists
    result = await db.execute(
        select(User).where(User.role == "admin").limit(1)
    )
    existing = result.scalar_one_or_none()
    if existing:
        logger.debug("Admin user already exists (%s) — skipping bootstrap", existing.email)
        return

    # Also check if this specific email exists (maybe as non-admin)
    result = await db.execute(
        select(User).where(User.email == admin_email).limit(1)
    )
    existing_email = result.scalar_one_or_none()
    if existing_email:
        # Promote to admin
        existing_email.role = "admin"
        existing_email.email_verified = True
        await db.commit()
        logger.info("Promoted existing user %s to admin", admin_email)
        return

    # Create new admin user
    from passlib.context import CryptContext
    pwd_context = CryptContext(schemes=["bcrypt"], deprecated="auto")

    admin = User(
        email=admin_email,
        full_name="Administrator",
        hashed_password=pwd_context.hash(admin_password),
        role="admin",
        is_active=True,
        email_verified=True,
    )
    db.add(admin)
    await db.commit()
    logger.info("Admin user created: %s (role=admin)", admin_email)
