{# annotations.cds.j2 — Fiori Elements annotations per entity.
   Context: solution_id, bundle_id, service_name, service_kebab, entity_name, model_def #}
// GENERATED BY ARCHIE
// solution_id: {{ solution_id }}
// bundle_id: {{ bundle_id }}

using {{ service_name }} from '../../srv/{{ service_kebab }}-service';

// ── Fiori Elements: List Report ──────────────────────────────────
annotate {{ service_name }}.{{ entity_name }} with @(
  UI.LineItem: [
{% for field in model_def.fields[:8] %}
{% if field.name not in ('id', 'created_at', 'created_by', 'modified_at', 'modified_by', 'updated_at', 'deleted_at') %}
    { Value: {{ field.name }}, Label: '{{ field.display_name }}' },
{% endif %}
{% endfor %}
  ],
  UI.HeaderInfo: {
    TypeName: '{{ entity_name }}',
    TypeNamePlural: '{{ entity_name }}s',
{% set title_field = model_def.fields | selectattr('type', 'equalto', 'string') | rejectattr('name', 'in', ['id', 'status', 'created_at']) | first %}
{% if title_field is defined %}
    Title: { Value: {{ title_field.name }} },
{% endif %}
  },
);

// ── Fiori Elements: Object Page ──────────────────────────────────
annotate {{ service_name }}.{{ entity_name }} with @(
  UI.FieldGroup #Main: {
    Data: [
{% for field in model_def.fields %}
{% if field.name not in ('id', 'created_at', 'created_by', 'modified_at', 'modified_by', 'updated_at', 'deleted_at') %}
      { Value: {{ field.name }}, Label: '{{ field.display_name }}' },
{% endif %}
{% endfor %}
    ]
  },
  UI.Facets: [
    { $Type: 'UI.ReferenceFacet', Target: '@UI.FieldGroup#Main', Label: 'Details' },
  ],
);
