describe('Token security', () => {
  it('does not store access token in localStorage', async () => {
    render(<LoginPage />, { wrapper: Wrapper });
    await userEvent.type(screen.getByLabelText(/email/i), 'test@example.com');
    await userEvent.type(screen.getByLabelText(/password/i), 'Valid@123');
    await userEvent.click(screen.getByRole('button', { name: /sign in|log in/i }));
    await waitFor(() => expect(mockPush).toHaveBeenCalled());
    // Tokens must NOT be in localStorage (XSS risk)
    const localValues = Object.values(localStorage).join(' ');
    expect(localValues).not.toContain(validToken);
  });
});

