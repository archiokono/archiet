#!/usr/bin/env python3
"""
mock_server.py — Standalone API mock server (zero dependencies).

Generated by A.R.C.H.I.E. from Solution #{{ solution_id }} ({{ solution_name }})
Run: python mock_server.py --port 8000

Returns realistic mock responses built from seed data for all API endpoints.
Supports: GET (list/detail), POST (echo+ID), PUT (echo), DELETE (204).
"""
import argparse
import json
import random
import time
from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse, parse_qs

# Pre-generated mock data from seed data generator
MOCK_DATA = {{ mock_data_json }}

# Configurable latency range (seconds)
MIN_LATENCY = 0.05
MAX_LATENCY = 0.2


class MockHandler(BaseHTTPRequestHandler):
    """Handle mock API requests with realistic responses."""

    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")
        params = parse_qs(parsed.query)

        # Simulate realistic latency
        time.sleep(random.uniform(MIN_LATENCY, MAX_LATENCY))

        {% for entity in entities %}
        # List {{ entity.name }}
        if path == "/{{ entity.name_snake }}":
            items = MOCK_DATA.get("{{ entity.name_snake }}", [])
            q = params.get("q", [None])[0]
            if q:
                items = [i for i in items if q.lower() in json.dumps(i).lower()]
            page = int(params.get("page", [1])[0])
            per_page = int(params.get("per_page", [20])[0])
            start = (page - 1) * per_page
            paged = items[start:start + per_page]
            self._json_response(200, {
                "items": paged,
                "total": len(items),
                "page": page,
                "per_page": per_page,
            })
            return

        # Detail {{ entity.name }}: /{{ entity.name_snake }}/<id>
        if path.startswith("/{{ entity.name_snake }}/") and path.count("/") == 2:
            item_id = path.split("/")[-1]
            items = MOCK_DATA.get("{{ entity.name_snake }}", [])
            item = next((i for i in items if str(i.get("id")) == item_id), None)
            if item:
                self._json_response(200, item)
            else:
                self._json_response(404, {"error": "Not found", "id": item_id})
            return

        {% endfor %}
        # Health check
        if path == "/health":
            self._json_response(200, {"status": "healthy", "mock": True})
            return

        self._json_response(404, {"error": "Unknown endpoint", "path": path})

    def do_POST(self):
        path = urlparse(self.path).path.rstrip("/")
        time.sleep(random.uniform(MIN_LATENCY, MAX_LATENCY))

        content_length = int(self.headers.get("Content-Length", 0))
        body = json.loads(self.rfile.read(content_length)) if content_length else {}
        body["id"] = random.randint(1000, 9999)
        body["created_at"] = "{{ generated_at }}"
        self._json_response(201, body)

    def do_PUT(self):
        path = urlparse(self.path).path.rstrip("/")
        time.sleep(random.uniform(MIN_LATENCY, MAX_LATENCY))

        content_length = int(self.headers.get("Content-Length", 0))
        body = json.loads(self.rfile.read(content_length)) if content_length else {}
        item_id = path.split("/")[-1]
        body["id"] = item_id
        body["updated_at"] = "{{ generated_at }}"
        self._json_response(200, body)

    def do_DELETE(self):
        time.sleep(random.uniform(MIN_LATENCY, MAX_LATENCY))
        self.send_response(204)
        self._cors_headers()
        self.end_headers()

    def do_OPTIONS(self):
        """Handle CORS preflight."""
        self.send_response(204)
        self._cors_headers()
        self.send_header("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type, Authorization")
        self.send_header("Access-Control-Max-Age", "86400")
        self.end_headers()

    def _json_response(self, status, data):
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self._cors_headers()
        self.end_headers()
        self.wfile.write(json.dumps(data, indent=2).encode())

    def _cors_headers(self):
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Expose-Headers", "Content-Length")

    def log_message(self, format, *args):
        """Override to add timestamp prefix."""
        print(f"[MOCK] {self.address_string()} - {format % args}")


def main():
    parser = argparse.ArgumentParser(description="Mock API server for {{ solution_name }}")
    parser.add_argument("--port", type=int, default=8000, help="Port to listen on")
    parser.add_argument("--host", default="0.0.0.0", help="Host to bind to")
    parser.add_argument("--latency-min", type=float, default=0.05, help="Min latency (seconds)")
    parser.add_argument("--latency-max", type=float, default=0.2, help="Max latency (seconds)")
    args = parser.parse_args()

    global MIN_LATENCY, MAX_LATENCY
    MIN_LATENCY = args.latency_min
    MAX_LATENCY = args.latency_max

    server = HTTPServer((args.host, args.port), MockHandler)
    print(f"Mock server for {{ solution_name }} (Solution #{{ solution_id }})")
    print(f"Listening on http://{args.host}:{args.port}")
    print(f"Latency: {MIN_LATENCY*1000:.0f}-{MAX_LATENCY*1000:.0f}ms")
    print(f"Endpoints:")
    {% for entity in entities %}
    print(f"  GET  /{{ entity.name_snake }}          (list)")
    print(f"  GET  /{{ entity.name_snake }}/<id>     (detail)")
    print(f"  POST /{{ entity.name_snake }}          (create)")
    {% endfor %}
    print(f"  GET  /health              (health check)")
    print()

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down mock server.")
        server.shutdown()


if __name__ == "__main__":
    main()
