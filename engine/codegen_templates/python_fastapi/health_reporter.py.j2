{# Background health reporter — posts runtime metrics to the A.R.C.H.I.E. webhook. #}
{# Context: solution_id, spec_hash, service_name, archie_webhook_url #}
"""
health_reporter.py — Runtime compliance reporter for A.R.C.H.I.E.

Generated by A.R.C.H.I.E. for Solution #{{ solution_id }} ({{ service_name }})

Runs as a background thread that collects endpoint health metrics every 5 minutes
and POSTs them to the A.R.C.H.I.E. compliance webhook. Gracefully degrades if the
webhook is unreachable — the service continues running without interruption.

Configuration (via environment variables):
    ARCHIE_WEBHOOK_URL   — full URL of the A.R.C.H.I.E. health report endpoint
                           (default: {{ archie_webhook_url | default('http://localhost:5000/solutions/api/runtime/health-report', true) }})
    ARCHIE_REPORT_INTERVAL_SECONDS — how often to report (default: 300)
    ARCHIE_SPEC_HASH     — SHA-256 hash of the spec this service was generated from
"""
import logging
import os
import statistics
import threading
import time
from typing import Callable, Dict, List, Optional

import httpx

logger = logging.getLogger(__name__)

# ── Configuration ─────────────────────────────────────────────────────────────

_SOLUTION_ID: int = {{ solution_id }}
_SERVICE_NAME: str = "{{ service_name }}"
_SPEC_HASH: str = os.environ.get(
    "ARCHIE_SPEC_HASH",
    "{{ spec_hash | default('', true) }}",
)
_WEBHOOK_URL: str = os.environ.get(
    "ARCHIE_WEBHOOK_URL",
    "{{ archie_webhook_url | default('http://localhost:5000/solutions/api/runtime/health-report', true) }}",
)
_REPORT_INTERVAL_SECONDS: int = int(
    os.environ.get("ARCHIE_REPORT_INTERVAL_SECONDS", "300")
)
_REQUEST_TIMEOUT_SECONDS: int = 10

# ── Metrics Collection ─────────────────────────────────────────────────────────


class _MetricsStore:
    """Thread-safe in-memory store for request metrics."""

    def __init__(self) -> None:
        self._lock = threading.Lock()
        self._latencies: Dict[str, List[float]] = {}   # endpoint_key -> latency list (ms)
        self._errors: Dict[str, int] = {}               # endpoint_key -> error count
        self._totals: Dict[str, int] = {}               # endpoint_key -> total count
        self._uptime_checks: List[bool] = []            # True = up, False = down

    def record_request(self, method: str, path: str, latency_ms: float, error: bool) -> None:
        key = f"{method.upper()} {path}"
        with self._lock:
            self._latencies.setdefault(key, []).append(latency_ms)
            self._totals[key] = self._totals.get(key, 0) + 1
            if error:
                self._errors[key] = self._errors.get(key, 0) + 1
            self._uptime_checks.append(True)

    def record_health_check(self, up: bool) -> None:
        with self._lock:
            self._uptime_checks.append(up)

    def snapshot_and_reset(self) -> dict:
        with self._lock:
            all_latencies: List[float] = []
            endpoints_active: List[str] = []
            endpoints_erroring: List[str] = []

            for key, latencies in self._latencies.items():
                all_latencies.extend(latencies)
                total = self._totals.get(key, 0)
                errors = self._errors.get(key, 0)
                if total > 0:
                    endpoints_active.append(key)
                    if errors > 0 and (errors / total) >= 0.05:
                        endpoints_erroring.append(key)

            avg_latency_ms = statistics.mean(all_latencies) if all_latencies else 0.0

            total_checks = len(self._uptime_checks)
            up_count = sum(1 for c in self._uptime_checks if c)
            uptime_pct = (up_count / total_checks * 100) if total_checks > 0 else 100.0

            total_requests = sum(self._totals.values())
            total_errors = sum(self._errors.values())
            error_rate_pct = (total_errors / total_requests * 100) if total_requests > 0 else 0.0

            # Reset for next window
            self._latencies.clear()
            self._errors.clear()
            self._totals.clear()
            self._uptime_checks.clear()

            return {
                "endpoints_active": endpoints_active,
                "endpoints_erroring": endpoints_erroring,
                "avg_latency_ms": round(avg_latency_ms, 2),
                "error_rate_pct": round(error_rate_pct, 4),
                "uptime_pct": round(uptime_pct, 4),
            }


# Module-level metrics store — import this in your FastAPI middleware
metrics: _MetricsStore = _MetricsStore()


# ── Reporter Thread ────────────────────────────────────────────────────────────


def _send_report(payload: dict) -> None:
    """POST a single health report to the A.R.C.H.I.E. webhook.

    Gracefully degrades on any network or HTTP error — logs a warning and returns.
    """
    if not _WEBHOOK_URL:
        logger.debug("ARCHIE_WEBHOOK_URL not set — skipping health report")
        return

    try:
        with httpx.Client(timeout=_REQUEST_TIMEOUT_SECONDS) as client:
            response = client.post(_WEBHOOK_URL, json=payload)
            response.raise_for_status()
            data = response.json()
            logger.info(
                "Health report accepted: spec_in_sync=%s sla_compliant=%s score=%s",
                data.get("spec_in_sync"),
                data.get("sla_compliant"),
                data.get("compliance_score"),
            )
    except httpx.ConnectError:
        logger.warning(
            "A.R.C.H.I.E. webhook unreachable at %s — health report skipped (service continues normally)",
            _WEBHOOK_URL,
        )
    except httpx.TimeoutException:
        logger.warning(
            "A.R.C.H.I.E. webhook timed out after %ds — health report skipped",
            _REQUEST_TIMEOUT_SECONDS,
        )
    except httpx.HTTPStatusError as exc:
        logger.warning(
            "A.R.C.H.I.E. webhook returned HTTP %d — health report skipped",
            exc.response.status_code,
        )
    except Exception as exc:  # pragma: no cover — network catch-all
        logger.warning("Unexpected error sending health report: %s", exc)


def _reporter_loop(stop_event: threading.Event) -> None:
    """Main loop: collect metrics every N seconds and POST to A.R.C.H.I.E."""
    logger.info(
        "A.R.C.H.I.E. health reporter started — interval=%ds solution_id=%d service=%s",
        _REPORT_INTERVAL_SECONDS,
        _SOLUTION_ID,
        _SERVICE_NAME,
    )
    while not stop_event.is_set():
        stop_event.wait(timeout=_REPORT_INTERVAL_SECONDS)
        if stop_event.is_set():
            break

        snapshot = metrics.snapshot_and_reset()
        payload = {
            "solution_id": _SOLUTION_ID,
            "service_name": _SERVICE_NAME,
            "spec_hash": _SPEC_HASH,
            **snapshot,
        }
        _send_report(payload)

    logger.info("A.R.C.H.I.E. health reporter stopped")


# ── Public API ─────────────────────────────────────────────────────────────────

_stop_event: threading.Event = threading.Event()
_reporter_thread: Optional[threading.Thread] = None


def start_reporter() -> None:
    """Start the background health reporter thread.

    Call this once at application startup (e.g., in a FastAPI lifespan handler).
    Safe to call multiple times — subsequent calls are no-ops if already running.
    """
    global _reporter_thread
    if _reporter_thread is not None and _reporter_thread.is_alive():
        logger.debug("Health reporter already running")
        return

    _stop_event.clear()
    _reporter_thread = threading.Thread(
        target=_reporter_loop,
        args=(_stop_event,),
        daemon=True,
        name="archie-health-reporter",
    )
    _reporter_thread.start()


def stop_reporter() -> None:
    """Signal the health reporter thread to stop.

    Call this at application shutdown (e.g., in a FastAPI lifespan handler).
    """
    _stop_event.set()
    if _reporter_thread is not None:
        _reporter_thread.join(timeout=5)


# ── FastAPI Middleware Helper ──────────────────────────────────────────────────


def make_metrics_middleware(app) -> Callable:
    """Return a Starlette/FastAPI middleware that records request latency.

    Usage in main.py:
        from health_reporter import make_metrics_middleware
        app.middleware("http")(make_metrics_middleware(app))
    """
    import time as _time

    async def metrics_middleware(request, call_next):
        start = _time.monotonic()
        error = False
        try:
            response = await call_next(request)
            if response.status_code >= 500:
                error = True
            return response
        except Exception:
            error = True
            raise
        finally:
            latency_ms = (_time.monotonic() - start) * 1000
            metrics.record_request(
                method=request.method,
                path=request.url.path,
                latency_ms=latency_ms,
                error=error,
            )

    return metrics_middleware
