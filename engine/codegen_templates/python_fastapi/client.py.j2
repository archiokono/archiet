    def _setup_auth(self):
        """Configure authentication from environment variables. Never hard-code secrets."""
        {% if contract.auth_method == 'oauth2' %}
        # OAuth2 client credentials flow — secrets read from env vars at runtime
        self._token_url = "{{ auth_config.get('token_url', '') }}"
        self._client_id = _get_env("{{ auth_config.get('client_id_env', 'OAUTH_CLIENT_ID') }}")
        self._client_secret = _get_env("{{ auth_config.get('client_secret_env', 'OAUTH_CLIENT_SECRET') }}")
        self._scope = "{{ auth_config.get('scope', '') }}"
        self._access_token = None
        self._refresh_token()
        {% elif contract.auth_method == 'api_key' %}
        # API key from environment variable
        api_key = _get_env("{{ auth_config.get('api_key_env', 'API_KEY') }}")
        header_name = "{{ auth_config.get('api_key_header', 'X-API-Key') }}"
        self._headers[header_name] = api_key
        {% elif contract.auth_method == 'basic' %}
        # Basic auth — credentials from environment variables
        import base64
        username = _get_env("{{ auth_config.get('username_env', 'BASIC_AUTH_USER') }}")
        password = _get_env("{{ auth_config.get('password_env', 'BASIC_AUTH_PASS') }}")
        credentials = base64.b64encode(f"{username}:{password}".encode()).decode()
        self._headers["Authorization"] = f"Basic {credentials}"
        {% elif contract.auth_method == 'mtls' %}
        # mTLS — certificate paths from environment variables
        self._cert_path = _get_env("{{ auth_config.get('cert_path_env', 'MTLS_CERT_PATH') }}")
