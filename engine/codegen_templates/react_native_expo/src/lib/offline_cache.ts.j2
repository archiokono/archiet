import { QueryClient } from "@tanstack/react-query"
import { createAsyncStoragePersister } from "@tanstack/query-async-storage-persister"
import AsyncStorage from "@react-native-async-storage/async-storage"
import NetInfo from "@react-native-community/netinfo"

// ── Query Client with persistent cache ──

export const queryClient = new QueryClient({
  defaultOptions: {
    queries: {
      staleTime: {{ '86400000' if offline_tier | default(1) == 1 else '30000' }}, // {{ '24h' if offline_tier | default(1) == 1 else '30s' }}
      gcTime: 86400000, // 24h — keep cache alive for offline
      retry: 2,
      networkMode: "offlineFirst", // Serve from cache first, revalidate in background
    },
    mutations: {
      networkMode: "offlineFirst",
      retry: 3,
    },
  },
})

// ── AsyncStorage Persister ──

export const asyncStoragePersister = createAsyncStoragePersister({
  storage: AsyncStorage,
  key: "{{ solution_name | lower | replace(' ', '-') }}-cache",
  throttleTime: 1000, // Debounce writes to storage
})

{% if offline_tier | default(1) >= 2 %}
// ── Mutation Queue (Tier 2: Optimistic Mutations) ──

interface PendingMutation {
  id: string
  url: string
  method: "POST" | "PUT" | "PATCH" | "DELETE"
  body?: string
  headers: Record<string, string>
  createdAt: number
  retryCount: number
  entity: string
}

const MUTATION_QUEUE_KEY = "{{ solution_name | lower | replace(' ', '-') }}-mutation-queue"

/**
 * Entities that support offline mutations.
 * Other entities use read-only cache (Tier 1).
 */
export const OFFLINE_ENTITIES = new Set([
{% for entity in offline_entities | default([]) %}
  "{{ entity }}",
{% endfor %}
])

/**
 * Queue a mutation for later sync.
 * Called when the device is offline and the entity supports offline mutations.
 */
export async function queueMutation(mutation: Omit<PendingMutation, "id" | "createdAt" | "retryCount">): Promise<void> {
  const queue = await getPendingMutations()
  const entry: PendingMutation = {
    ...mutation,
    id: `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`,
    createdAt: Date.now(),
    retryCount: 0,
  }
  queue.push(entry)
  await AsyncStorage.setItem(MUTATION_QUEUE_KEY, JSON.stringify(queue))
}

/**
 * Get all pending mutations from the queue.
 */
export async function getPendingMutations(): Promise<PendingMutation[]> {
  const raw = await AsyncStorage.getItem(MUTATION_QUEUE_KEY)
  return raw ? JSON.parse(raw) : []
}

/**
 * Remove a mutation from the queue after successful sync.
 */
async function removeMutation(id: string): Promise<void> {
  const queue = await getPendingMutations()
  const filtered = queue.filter((m) => m.id !== id)
  await AsyncStorage.setItem(MUTATION_QUEUE_KEY, JSON.stringify(filtered))
}

/**
 * Sync all pending mutations to the server.
 * Called when the device comes back online.
 *
 * Conflict strategy: last_write_wins
 *   - Server compares updated_at timestamps
 *   - If server record is newer, mutation is discarded (logged, not retried)
 *   - If client mutation is newer, it overwrites
 */
export async function syncPendingMutations(authToken: string): Promise<{
  synced: number
  failed: number
  conflicts: number
}> {
  const queue = await getPendingMutations()
  if (queue.length === 0) return { synced: 0, failed: 0, conflicts: 0 }

  let synced = 0
  let failed = 0
  let conflicts = 0

  for (const mutation of queue) {
    try {
      const res = await fetch(mutation.url, {
        method: mutation.method,
        headers: {
          ...mutation.headers,
          Authorization: `Bearer ${authToken}`,
          "X-Offline-Mutation": "true",
          "X-Mutation-Timestamp": String(mutation.createdAt),
        },
        body: mutation.body,
      })

      if (res.ok) {
        await removeMutation(mutation.id)
        synced++
      } else if (res.status === 409) {
        // Conflict — server has newer data. Discard mutation.
        console.warn(`Conflict for ${mutation.entity}: server data is newer, discarding mutation ${mutation.id}`)
        await removeMutation(mutation.id)
        conflicts++
      } else if (res.status >= 500 && mutation.retryCount < 3) {
        // Server error — retry later
        mutation.retryCount++
        failed++
      } else {
        // Client error (4xx) — discard
        console.error(`Mutation ${mutation.id} failed with ${res.status}, discarding`)
        await removeMutation(mutation.id)
        failed++
      }
    } catch (err) {
      // Network error — will retry on next sync
      mutation.retryCount++
      failed++
    }
  }

  // Update queue with remaining mutations
  const remaining = await getPendingMutations()
  const updated = remaining.map((m) => {
    const match = queue.find((q) => q.id === m.id)
    return match ?? m
  })
  await AsyncStorage.setItem(MUTATION_QUEUE_KEY, JSON.stringify(updated))

  return { synced, failed, conflicts }
}

/**
 * Listen for network state changes and auto-sync when coming online.
 */
export function setupAutoSync(getAuthToken: () => Promise<string | null>): () => void {
  const unsubscribe = NetInfo.addEventListener(async (state) => {
    if (state.isConnected && state.isInternetReachable) {
      const token = await getAuthToken()
      if (token) {
        const result = await syncPendingMutations(token)
        if (result.synced > 0 || result.conflicts > 0) {
          console.log(`Auto-sync: ${result.synced} synced, ${result.conflicts} conflicts, ${result.failed} failed`)
          // Invalidate affected queries to refresh from server
          queryClient.invalidateQueries()
        }
      }
    }
  })
  return unsubscribe
}

/**
 * Get the count of pending mutations for UI display.
 */
export async function getPendingCount(): Promise<number> {
  const queue = await getPendingMutations()
  return queue.length
}
{% endif %}

// ── Connectivity Status ──

import { useEffect, useState } from "react"

/**
 * Returns true when the device has an active internet connection.
 * Subscribes to NetInfo state changes and updates reactively.
 */
export function useIsOnline(): boolean {
  const [online, setOnline] = useState(true)
  useEffect(() => {
    const unsubscribe = NetInfo.addEventListener((state) => {
      setOnline(!!(state.isConnected && state.isInternetReachable))
    })
    // Check immediately on mount
    NetInfo.fetch().then((state) => {
      setOnline(!!(state.isConnected && state.isInternetReachable))
    })
    return unsubscribe
  }, [])
  return online
}
