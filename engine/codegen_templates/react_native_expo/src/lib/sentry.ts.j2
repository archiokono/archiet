/**
 * Sentry crash reporting — {{ solution_name }}
 * Generated by A.R.C.H.I.E. — conditionally included when genome.mobile.monitoring.enabled = true
 *
 * Setup:
 *   1. Create a project at https://sentry.io
 *   2. Set EXPO_PUBLIC_SENTRY_DSN in .env and in eas.json env blocks
 *   3. Run: npx expo install @sentry/react-native
 *   4. Run: npx @sentry/wizard@latest -i reactNative  (auto-patches babel.config.js)
 */
import * as Sentry from "@sentry/react-native"

const DSN = process.env.EXPO_PUBLIC_SENTRY_DSN

/**
 * Call once at app startup (in RootLayout, before any other providers).
 * Safe to call even if DSN is not set — Sentry will be a no-op.
 */
export function initSentry(): void {
  if (!DSN) return

  Sentry.init({
    dsn: DSN,
    // Performance monitoring — 20% of transactions sampled in production
    tracesSampleRate: process.env.NODE_ENV === "production" ? 0.2 : 1.0,
    // Session replay — disabled by default (privacy-sensitive)
    _experiments: { replaysSessionSampleRate: 0, replaysOnErrorSampleRate: 0 },
    // Attach the build environment as a tag
    environment: process.env.NODE_ENV ?? "development",
    // Release name — matches EAS build version
    release: "{{ solution_slug }}@{{ '1.0.0' }}",
    // Don't send PII (user emails etc.) by default
    sendDefaultPii: false,
    // Ignore common non-actionable errors
    ignoreErrors: [
      "Network request failed",
      "Unauthorized",  // Auth redirects are intentional
    ],
  })
}

/**
 * Wrap a user identity into the Sentry scope.
 * Call after successful login — do NOT pass raw email without user consent.
 */
export function setSentryUser(id: string, email?: string): void {
  Sentry.setUser({ id, email })
}

/** Clear user on logout. */
export function clearSentryUser(): void {
  Sentry.setUser(null)
}

/**
 * Capture a handled error (e.g. in catch blocks where you don't want to crash
 * but do want visibility).
 */
export function captureError(err: unknown, context?: Record<string, unknown>): void {
  if (context) Sentry.setContext("extra", context)
  Sentry.captureException(err)
}
