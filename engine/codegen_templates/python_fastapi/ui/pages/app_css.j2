{# app_css.j2 — Minimal custom CSS for the generated app's UI.
   Tailwind via CDN handles most styling. This file adds only custom utilities. #}
/* Generated by A.R.C.H.I.E. — custom utilities */

/* Alpine.js cloak */
[x-cloak] { display: none !important; }

/* Smooth transitions for sidebar */
.sidebar-transition {
    transition: width 200ms ease, margin-left 200ms ease;
}

/* Table row hover effect */
tbody tr { transition: background-color 150ms ease; }

/* Scrollbar styling */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: hsl(215.4 16.3% 80%); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: hsl(215.4 16.3% 60%); }

/* Dark mode overrides */
.dark {
    --tw-bg-opacity: 1;
    color-scheme: dark;
}
