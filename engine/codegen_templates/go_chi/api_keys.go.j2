// APIKey stores hashed API keys for B2B authentication.
type APIKey struct {
	ID             string     `gorm:"primaryKey;size:36" json:"id"`
	Name           string     `gorm:"size:255;not null" json:"name"`
	KeyPrefix      string     `gorm:"size:8;not null;index" json:"key_prefix"`
	KeyHash        string     `gorm:"size:128;not null;uniqueIndex" json:"-"`
	Scopes         JSON       `gorm:"type:jsonb;default:'[]'" json:"scopes"`
	RateLimit      int        `gorm:"default:1000" json:"rate_limit"`
	OrganizationID string     `gorm:"size:64;not null;index" json:"organization_id"`
	CreatedByID    string     `gorm:"size:36;not null" json:"created_by_id"`
	IsActive       bool       `gorm:"default:true" json:"is_active"`
	LastUsedAt     *time.Time `json:"last_used_at"`
	UsageCount     int        `gorm:"default:0" json:"usage_count"`
	ExpiresAt      *time.Time `json:"expires_at"`
	CreatedAt      time.Time  `gorm:"autoCreateTime" json:"created_at"`
	RevokedAt      *time.Time `json:"revoked_at"`
}

// APIKeyCreateRequest is the request body for creating an API key.
type APIKeyCreateRequest struct {
	Name          string   `json:"name" validate:"required,min=1,max=255"`
	Scopes        []string `json:"scopes"`
	RateLimit     int      `json:"rate_limit"`
	ExpiresInDays *int     `json:"expires_in_days"`
}

// APIKeyCreatedResponse includes the raw key (returned only on creation).
type APIKeyCreatedResponse struct {
	APIKey
	Key string `json:"key"`
}

func hashAPIKey(raw string) string {
	h := sha256.Sum256([]byte(raw))
	return hex.EncodeToString(h[:])
}

func generateAPIKey() (raw, prefix, hash string) {
	b := make([]byte, 32)
	if _, err := rand.Read(b); err != nil {
		panic(fmt.Sprintf("failed to generate random key: %v", err))
	}
	raw = hex.EncodeToString(b)
	prefix = raw[:8]
	hash = hashAPIKey(raw)
	return
}

// APIKeyRoutes returns a chi.Router with CRUD endpoints for API keys.
func APIKeyRoutes(db *gorm.DB) chi.Router {
	r := chi.NewRouter()

	// POST /api/keys — Create a new API key
	r.Post("/", func(w http.ResponseWriter, req *http.Request) {
		var body APIKeyCreateRequest
		if err := json.NewDecoder(req.Body).Decode(&body); err != nil {
			http.Error(w, `{"error":"invalid request body"}`, http.StatusBadRequest)
			return
		}
		if body.Name == "" {
			http.Error(w, `{"error":"name is required"}`, http.StatusBadRequest)
			return
		}
		if body.RateLimit <= 0 {
			body.RateLimit = 1000
		}
		if body.Scopes == nil {
			body.Scopes = []string{"read"}
		}

		raw, prefix, hash := generateAPIKey()

		var expiresAt *time.Time
		if body.ExpiresInDays != nil && *body.ExpiresInDays > 0 {
			t := time.Now().Add(time.Duration(*body.ExpiresInDays) * 24 * time.Hour)
			expiresAt = &t
		}

		orgID := GetTenantID(req.Context())
		claims, _ := req.Context().Value(ContextKeyClaims).(*TokenClaims)
		userID := ""
		if claims != nil {
			userID = claims.Sub
		}

		key := APIKey{
			ID:             generateUUID(),
			Name:           body.Name,
			KeyPrefix:      prefix,
			KeyHash:        hash,
			RateLimit:      body.RateLimit,
			OrganizationID: orgID,
			CreatedByID:    userID,
			IsActive:       true,
			ExpiresAt:      expiresAt,
		}

		if err := db.Create(&key).Error; err != nil {
			log.Error().Err(err).Msg("failed to create API key")
			http.Error(w, `{"error":"failed to create API key"}`, http.StatusInternalServerError)
			return
		}

		log.Info().Str("prefix", prefix).Str("org", orgID).Msg("API key created")

		resp := APIKeyCreatedResponse{APIKey: key, Key: raw}
		w.Header().Set("Content-Type", "application/json")
		w.WriteHeader(http.StatusCreated)
		json.NewEncoder(w).Encode(resp)
	})

	// GET /api/keys — List all API keys for the organization
	r.Get("/", func(w http.ResponseWriter, req *http.Request) {
		orgID := GetTenantID(req.Context())
		var keys []APIKey
		db.Where("organization_id = ?", orgID).Order("created_at DESC").Find(&keys)

		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(keys)
	})

	// DELETE /api/keys/{id} — Revoke an API key
	r.Delete("/{id}", func(w http.ResponseWriter, req *http.Request) {
		keyID := chi.URLParam(req, "id")
		orgID := GetTenantID(req.Context())

		var key APIKey
		if err := db.Where("id = ? AND organization_id = ?", keyID, orgID).First(&key).Error; err != nil {
			http.Error(w, `{"error":"not found"}`, http.StatusNotFound)
			return
		}

		now := time.Now()
		db.Model(&key).Updates(map[string]interface{}{
			"is_active":  false,
			"revoked_at": &now,
		})

		log.Info().Str("id", keyID).Str("prefix", key.KeyPrefix).Msg("API key revoked")
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]string{"status": "revoked", "id": keyID})
	})

	// POST /api/keys/{id}/rotate — Rotate an API key
	r.Post("/{id}/rotate", func(w http.ResponseWriter, req *http.Request) {
		keyID := chi.URLParam(req, "id")
		orgID := GetTenantID(req.Context())

		var oldKey APIKey
		if err := db.Where("id = ? AND organization_id = ? AND is_active = ?", keyID, orgID, true).First(&oldKey).Error; err != nil {
			http.Error(w, `{"error":"not found or already revoked"}`, http.StatusNotFound)
			return
		}

		// Revoke old key
		now := time.Now()
		db.Model(&oldKey).Updates(map[string]interface{}{
			"is_active":  false,
			"revoked_at": &now,
		})

		// Create new key with same config
		raw, prefix, hash := generateAPIKey()
		claims, _ := req.Context().Value(ContextKeyClaims).(*TokenClaims)
		userID := ""
		if claims != nil {
			userID = claims.Sub
		}

		newKey := APIKey{
			ID:             generateUUID(),
			Name:           oldKey.Name,
			KeyPrefix:      prefix,
			KeyHash:        hash,
			RateLimit:      oldKey.RateLimit,
			OrganizationID: oldKey.OrganizationID,
			CreatedByID:    userID,
			IsActive:       true,
			ExpiresAt:      oldKey.ExpiresAt,
		}
		db.Create(&newKey)

		log.Info().Str("old", keyID).Str("new_prefix", prefix).Msg("API key rotated")

		resp := APIKeyCreatedResponse{APIKey: newKey, Key: raw}
		w.Header().Set("Content-Type", "application/json")
		w.WriteHeader(http.StatusCreated)
		json.NewEncoder(w).Encode(resp)
	})

	return r
}

// VerifyAPIKey middleware validates X-API-Key header for machine-to-machine auth.
// Falls through to next handler if no API key is present (JWT auth may handle it).
func VerifyAPIKey(db *gorm.DB) func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			apiKey := r.Header.Get("X-API-Key")
			if apiKey == "" {
				next.ServeHTTP(w, r)
				return
			}

			hash := hashAPIKey(apiKey)
			var key APIKey
			if err := db.Where("key_hash = ? AND is_active = ?", hash, true).First(&key).Error; err != nil {
				http.Error(w, `{"error":"invalid API key"}`, http.StatusUnauthorized)
				return
			}

			if key.ExpiresAt != nil && key.ExpiresAt.Before(time.Now()) {
				http.Error(w, `{"error":"API key expired"}`, http.StatusUnauthorized)
				return
			}

			// Update usage stats
			db.Model(&key).Updates(map[string]interface{}{
				"last_used_at": time.Now(),
				"usage_count":  gorm.Expr("usage_count + 1"),
			})

			// Inject tenant context from API key
			ctx := context.WithValue(r.Context(), TenantContextKey, key.OrganizationID)
			next.ServeHTTP(w, r.WithContext(ctx))
		})
	}
}
