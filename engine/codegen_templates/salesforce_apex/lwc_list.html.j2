{# salesforce_apex/lwc_list.html.j2 #}
{# Generates Lightning Web Component HTML for list view with datatable. #}
{# Context: solution_id, bundle_id, model_name, fields, component_name #}
<!-- GENERATED BY ARCHIE — solution_id: {{ solution_id }}, bundle_id: {{ bundle_id }} -->
<!-- DO NOT EDIT IN PLACE — REGENERATE FROM ARCHITECTURE -->
<template>
    <lightning-card title="{{ model_name | replace('_', ' ') }}s" icon-name="standard:record">
        <div slot="actions">
            <lightning-button
                label="New {{ model_name | replace('_', ' ') }}"
                variant="brand"
                onclick={handleNew}>
            </lightning-button>
            <lightning-button
                label="Refresh"
                variant="neutral"
                icon-name="utility:refresh"
                onclick={handleRefresh}
                class="slds-m-left_x-small">
            </lightning-button>
        </div>

        <template if:true={isLoading}>
            <lightning-spinner alternative-text="Loading" size="medium"></lightning-spinner>
        </template>

        <template if:true={error}>
            <div class="slds-p-around_medium">
                <lightning-icon icon-name="utility:error" variant="error" size="small"></lightning-icon>
                <span class="slds-m-left_small">{error}</span>
            </div>
        </template>

        <template if:false={isLoading}>
            <template if:true={hasRecords}>
                <lightning-datatable
                    key-field="Id"
                    data={records}
                    columns={columns}
                    onrowaction={handleRowAction}
                    show-row-number-column
                    sorted-by={sortedBy}
                    sorted-direction={sortedDirection}
                    onsort={handleSort}>
                </lightning-datatable>
            </template>

            <template if:false={hasRecords}>
                <div class="slds-p-around_medium slds-text-align_center slds-text-color_weak">
                    No {{ model_name | replace('_', ' ') | lower }}s found. Click "New" to create one.
                </div>
            </template>
        </template>
    </lightning-card>
</template>
