from fastapi import FastAPI, APIRouter, Request
from fastapi.responses import JSONResponse


# ── Versioned router factory ──────────────────────────────────────────────────

def make_v1_router() -> APIRouter:
    """All stable API routes live under /v1/."""
    return APIRouter(prefix="/v1")


def make_v2_router() -> APIRouter:
    """Preview/next routes under /v2/ (opt-in, may break between releases)."""
    return APIRouter(prefix="/v2")


# ── Deprecation middleware ────────────────────────────────────────────────────

DEPRECATED_PATHS: dict[str, str] = {
    # "/old-path": "/v1/new-path"
}


async def deprecation_middleware(request: Request, call_next):
    """Add Deprecation header for sunset routes, redirect if mapping exists."""
    path = request.url.path
    if path in DEPRECATED_PATHS:
        new_path = DEPRECATED_PATHS[path]
        return JSONResponse(
            status_code=301,
            headers={
                "Location": new_path,
                "Deprecation": "true",
                "Sunset": "{{ deprecation_sunset_date | default('2026-12-31') }}",
                "Link": f'<{new_path}>; rel="successor-version"',
            },
            content={"message": f"This endpoint is deprecated. Use {new_path} instead."},
        )
    response = await call_next(request)
    # Tag all /v1/ responses with version header
    if path.startswith("/v1/"):
        response.headers["X-API-Version"] = "1"
    elif path.startswith("/v2/"):
        response.headers["X-API-Version"] = "2"
        response.headers["X-API-Version-Status"] = "preview"
    return response


