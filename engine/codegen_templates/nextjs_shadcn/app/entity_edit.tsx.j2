{# app/[entity]/[id]/edit/page.tsx — Edit form (pre-populated, uses PATCH).
   Context: entity_name, entity_slug, fields, state_machine_field #}
"use client"

import { useRouter } from "next/navigation"
import Link from "next/link"
import { useQuery, useMutation, useQueryClient } from "@tanstack/react-query"
import { useForm } from "react-hook-form"
import { zodResolver } from "@hookform/resolvers/zod"
import { z } from "zod"
import { toast } from "sonner"
import { ArrowLeft, Loader2 } from "lucide-react"
import { Button } from "@/components/ui/button"
import { Input } from "@/components/ui/input"
import { Textarea } from "@/components/ui/textarea"
import { Switch } from "@/components/ui/switch"
import { Skeleton } from "@/components/ui/skeleton"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import {
  Form, FormControl, FormField, FormItem, FormLabel, FormMessage,
} from "@/components/ui/form"
import {
  Select, SelectContent, SelectItem, SelectTrigger, SelectValue,
} from "@/components/ui/select"
{% set fk_fields = [] %}
{% for field in fields %}{% if field.get('foreign_key') %}{% if fk_fields.append(field) %}{% endif %}{% endif %}{% endfor %}
{% if fk_fields %}
import { EntityPicker } from "@/components/entity-picker"
{% endif %}
import { api, ApiError } from "@/lib/api"

{# ── Editable fields: exclude PK, timestamps, state machine field, system-managed ── #}
{% set edit_fields = [] %}
{% for field in fields %}
{% if not field.get('primary_key') and field.name not in ('id', 'created_at', 'updated_at', 'deleted_at', 'createdAt', 'updatedAt', 'deletedAt') and field.name != (state_machine_field | default('status')) and not field.get('system_managed') %}
{% if edit_fields.append(field) %}{% endif %}
{% endif %}
{% endfor %}

const formSchema = z.object({
{% for field in edit_fields %}
{% if field.type in ('string', 'text', 'enum') %}
{% if field.get('enum_values') %}
  {{ field.name }}: z.enum([{% for v in field.enum_values %}"{{ v }}"{% if not loop.last %}, {% endif %}{% endfor %}]).default("{{ field.enum_values[0] }}"),
{% else %}
  {{ field.name }}: z.string().optional().default(""),
{% endif %}
{% elif field.type in ('integer', 'int') %}
  {{ field.name }}: z.coerce.number().int().optional(),
{% elif field.type in ('decimal', 'float', 'number') %}
  {{ field.name }}: z.coerce.number().optional(),
{% elif field.type == 'boolean' %}
  {{ field.name }}: z.boolean().default(false),
{% elif field.type in ('datetime', 'date') %}
  {{ field.name }}: z.string().optional().default(""),
{% else %}
  {{ field.name }}: z.string().optional().default(""),
{% endif %}
{% endfor %}
})

type FormValues = z.infer<typeof formSchema>

export default function {{ entity_name }}EditPage({ params }: { params: { id: string } }) {
  const { id } = params
  const router = useRouter()
  const queryClient = useQueryClient()

  const { data: item, isLoading } = useQuery({
    queryKey: ["{{ entity_slug }}", id],
    queryFn: () => api.get<Record<string, any>>(`/api/{{ api_resource }}/${id}`),
  })

  const form = useForm<FormValues>({
    resolver: zodResolver(formSchema),
    values: item ? {
{% for field in edit_fields %}
{% if field.type == 'boolean' %}
      {{ field.name }}: item.{{ field.name }} ?? false,
{% elif field.type in ('integer', 'int', 'decimal', 'float', 'number') %}
      {{ field.name }}: item.{{ field.name }} ?? 0,
{% else %}
      {{ field.name }}: item.{{ field.name }} ?? "",
{% endif %}
{% endfor %}
    } : undefined,
  })

  const updateMutation = useMutation({
    mutationFn: (values: FormValues) => {
      // Only send non-empty fields — avoid overwriting with empty strings
      const payload = Object.fromEntries(
        Object.entries(values).filter(([, v]) => v !== "" && v !== null && v !== undefined)
      )
      return api.put(`/api/{{ api_resource }}/${id}`, payload)
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ["{{ entity_slug }}", id] })
      toast.success("{{ entity_name | replace('_', ' ') }} updated")
      router.push(`/{{ entity_slug }}/${id}`)
    },
    onError: (err: unknown) => {
      const apiErr = err as ApiError
      if (apiErr?.fieldErrors?.length) {
        apiErr.fieldErrors.forEach((fe) => {
          const field = fe.loc?.[fe.loc.length - 1] as string
          if (field) form.setError(field as any, { message: fe.msg })
        })
        toast.error("Validation failed", { description: apiErr.detail })
      } else {
        toast.error("Update failed", { description: apiErr?.detail || apiErr?.message })
      }
    },
  })

  if (isLoading) {
    return (
      <div className="max-w-2xl space-y-6">
        <Skeleton className="h-8 w-64" />
        <Card><CardContent className="p-6 space-y-4">
          {[...Array(5)].map((_, i) => <Skeleton key={i} className="h-10 w-full" />)}
        </CardContent></Card>
      </div>
    )
  }

  return (
    <div className="max-w-2xl space-y-6">
      <div className="flex items-center gap-4">
        <Link href={`/{{ entity_slug }}/${id}`}>
          <Button variant="ghost" size="icon">
            <ArrowLeft className="h-4 w-4" />
          </Button>
        </Link>
        <h1 className="text-2xl font-semibold tracking-tight">
          Edit {{ entity_name | replace('_', ' ') }}
        </h1>
      </div>

      <Card>
        <CardHeader>
          <CardTitle>Details</CardTitle>
        </CardHeader>
        <CardContent>
          <Form {...form}>
            <form onSubmit={form.handleSubmit((v) => updateMutation.mutate(v))} className="space-y-4">
{% for field in edit_fields %}
{% if field.get('enum_values') %}
              <FormField
                control={form.control}
                name="{{ field.name }}"
                render={({ field: f }) => (
                  <FormItem>
                    <FormLabel>{{ field.name | replace('_', ' ') | title }}</FormLabel>
                    <Select onValueChange={f.onChange} value={f.value as string}>
                      <FormControl>
                        <SelectTrigger>
                          <SelectValue placeholder="Select {{ field.name | replace('_', ' ') }}" />
                        </SelectTrigger>
                      </FormControl>
                      <SelectContent>
{% for val in field.enum_values %}
                        <SelectItem value="{{ val }}">{{ val | replace('_', ' ') | title }}</SelectItem>
{% endfor %}
                      </SelectContent>
                    </Select>
                    <FormMessage />
                  </FormItem>
                )}
              />
{% elif field.type == 'text' %}
              <FormField
                control={form.control}
                name="{{ field.name }}"
                render={({ field: f }) => (
                  <FormItem>
                    <FormLabel>{{ field.name | replace('_', ' ') | title }}</FormLabel>
                    <FormControl>
                      <Textarea {...f} rows={4} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
{% elif field.type == 'boolean' %}
              <FormField
                control={form.control}
                name="{{ field.name }}"
                render={({ field: f }) => (
                  <FormItem className="flex items-center justify-between rounded-lg border p-4">
                    <FormLabel>{{ field.name | replace('_', ' ') | title }}</FormLabel>
                    <FormControl>
                      <Switch checked={f.value as boolean} onCheckedChange={f.onChange} />
                    </FormControl>
                  </FormItem>
                )}
              />
{% elif field.get('foreign_key') and field.get('foreign_entity') %}
              <FormField
                control={form.control}
                name="{{ field.name }}"
                render={({ field: f }) => (
                  <FormItem>
                    <FormLabel>{{ field.name | replace('_id', '') | replace('_', ' ') | title }}</FormLabel>
                    <FormControl>
                      <EntityPicker
                        entityType="{{ field.get('foreign_entity_slug') or (field.get('foreign_entity') or '') | lower }}"
                        apiResource="{{ field.get('foreign_api_resource') or ((field.get('foreign_entity') or '') | lower + 's') }}"
                        value={f.value as string}
                        onChange={f.onChange}
                        placeholder="Search {{ (field.get('foreign_entity') or '') | lower | replace('_', ' ') }}s..."
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
{% elif field.type in ('integer', 'int', 'decimal', 'float', 'number') %}
              <FormField
                control={form.control}
                name="{{ field.name }}"
                render={({ field: f }) => (
                  <FormItem>
                    <FormLabel>{{ field.name | replace('_', ' ') | title }}</FormLabel>
                    <FormControl>
                      <Input type="number" step="{{ '0.01' if field.type in ('decimal', 'float') else '1' }}" {...f} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
{% elif field.type in ('datetime', 'date') %}
              <FormField
                control={form.control}
                name="{{ field.name }}"
                render={({ field: f }) => (
                  <FormItem>
                    <FormLabel>{{ field.name | replace('_', ' ') | title }}</FormLabel>
                    <FormControl>
                      <Input type="{{ 'datetime-local' if field.type == 'datetime' else 'date' }}" {...f} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
{% else %}
              <FormField
                control={form.control}
                name="{{ field.name }}"
                render={({ field: f }) => (
                  <FormItem>
                    <FormLabel>{{ field.name | replace('_', ' ') | title }}</FormLabel>
                    <FormControl>
                      <Input {...f} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
{% endif %}
{% endfor %}
              <div className="flex justify-end gap-2 pt-4">
                <Link href={`/{{ entity_slug }}/${id}`}>
                  <Button type="button" variant="outline">Cancel</Button>
                </Link>
                <Button type="submit" disabled={updateMutation.isPending}>
                  {updateMutation.isPending && <Loader2 className="mr-2 h-4 w-4 animate-spin" />}
                  Save Changes
                </Button>
              </div>
            </form>
          </Form>
        </CardContent>
      </Card>
    </div>
  )
}
