{# app/modules/solutions_product/templates/mobile/config/eas.json.j2 #}
{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "{{ api_base_url | default('http://localhost:8000') }}"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "{{ staging_api_url | default('https://staging-api.example.com') }}"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "{{ production_api_url | default('https://api.example.com') }}"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
