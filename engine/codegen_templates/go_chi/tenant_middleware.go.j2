package main

import (
	"context"
	"net/http"

	"github.com/rs/zerolog/log"
)

// TenantContextKey is the context key for the current organization ID.
const TenantContextKey contextKey = "orgID"

// TenantMiddleware extracts the organization_id from JWT claims and injects it
// into the request context. All database queries should scope by this value.
//
// If no org claim is present (platform admin), the request proceeds without
// tenant scoping.
func TenantMiddleware(next http.Handler) http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		claims, _ := r.Context().Value(ContextKeyClaims).(*TokenClaims)
		if claims != nil && claims.Org != "" {
			ctx := context.WithValue(r.Context(), TenantContextKey, claims.Org)
			next.ServeHTTP(w, r.WithContext(ctx))
			return
		}
		// No tenant context — platform admin or unauthenticated
		next.ServeHTTP(w, r)
	})
}

// GetTenantID extracts the organization ID from the request context.
// Returns empty string if no tenant context is set.
func GetTenantID(ctx context.Context) string {
	orgID, _ := ctx.Value(TenantContextKey).(string)
	return orgID
}

// RequireTenant is middleware that rejects requests without a tenant context.
// Use on routes that must be organization-scoped.
func RequireTenant(next http.Handler) http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		orgID := GetTenantID(r.Context())
		if orgID == "" {
			log.Warn().Str("path", r.URL.Path).Msg("tenant required but not present")
			http.Error(w, `{"error":"organization context required"}`, http.StatusForbidden)
			return
		}
		next.ServeHTTP(w, r)
	})
}

// TenantScopeQuery returns a WHERE clause fragment for tenant isolation.
// Usage: db.Where(TenantScopeQuery(ctx)).Find(&records)
func TenantScopeQuery(ctx context.Context) map[string]interface{} {
	orgID := GetTenantID(ctx)
	if orgID == "" {
		return nil // No tenant scoping — platform admin
	}
	return map[string]interface{}{"organization_id": orgID}
}
