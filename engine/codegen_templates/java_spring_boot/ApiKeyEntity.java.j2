// ── Service ──

@Service
class ApiKeyService {
    @Autowired
    private ApiKeyRepository repo;

    private static final SecureRandom RANDOM = new SecureRandom();

    record CreatedKey(ApiKey entity, String rawKey) {}

    CreatedKey create(String name, int rateLimit, String orgId, String userId, Instant expiresAt) {
        byte[] bytes = new byte[32];
        RANDOM.nextBytes(bytes);
        String rawKey = HexFormat.of().formatHex(bytes);
        String prefix = rawKey.substring(0, 8);
        String hash = sha256(rawKey);

        ApiKey key = new ApiKey();
        key.setName(name);
        key.setKeyPrefix(prefix);
        key.setKeyHash(hash);
        key.setRateLimit(rateLimit > 0 ? rateLimit : 1000);
        key.setOrganizationId(orgId);
        key.setCreatedById(userId);
        key.setExpiresAt(expiresAt);
        repo.save(key);
        return new CreatedKey(key, rawKey);
    }

    Optional<ApiKey> verify(String rawKey) {
        String hash = sha256(rawKey);
        return repo.findByKeyHashAndActiveTrue(hash)
                .filter(k -> k.getExpiresAt() == null || k.getExpiresAt().isAfter(Instant.now()));
    }

    void recordUsage(ApiKey key) {
        key.setLastUsedAt(Instant.now());
        key.setUsageCount(key.getUsageCount() + 1);
        repo.save(key);
    }

    void revoke(String keyId, String orgId) {
        repo.findById(keyId)
                .filter(k -> k.getOrganizationId().equals(orgId))
                .ifPresent(k -> {
                    k.setActive(false);
                    k.setRevokedAt(Instant.now());
                    repo.save(k);
                });
    }

    List<ApiKey> listForOrg(String orgId) {
        return repo.findByOrganizationIdOrderByCreatedAtDesc(orgId);
    }

    private static String sha256(String input) {
        try {
            MessageDigest md = MessageDigest.getInstance("SHA-256");
            byte[] hash = md.digest(input.getBytes(StandardCharsets.UTF_8));
            return HexFormat.of().formatHex(hash);
        } catch (NoSuchAlgorithmException e) {
            throw new RuntimeException("SHA-256 not available", e);
        }
    }
}

// ── Controller ──

@RestController
@RequestMapping("/api/keys")
class ApiKeyController {
    @Autowired
    private ApiKeyService service;

    record CreateRequest(String name, int rateLimit, Integer expiresInDays) {}
    record CreateResponse(String id, String name, String keyPrefix, String key,
                          int rateLimit, boolean active, Instant createdAt) {}

    @PostMapping
    ResponseEntity<CreateResponse> create(@RequestBody CreateRequest req) {
        Instant expires = req.expiresInDays() != null
                ? Instant.now().plusSeconds(req.expiresInDays() * 86400L) : null;
        // TODO: extract orgId and userId from SecurityContext
        var created = service.create(req.name(), req.rateLimit(), "default", "system", expires);
        var k = created.entity();
        return ResponseEntity.status(HttpStatus.CREATED).body(
                new CreateResponse(k.getId(), k.getName(), k.getKeyPrefix(),
                        created.rawKey(), k.getRateLimit(), k.isActive(), k.getCreatedAt()));
    }

    @GetMapping
    List<ApiKey> list() {
        return service.listForOrg("default");
    }

    @DeleteMapping("/{id}")
    Map<String, String> revoke(@PathVariable String id) {
        service.revoke(id, "default");
        return Map.of("status", "revoked", "id", id);
    }
}

// ── Authentication Filter ──

class ApiKeyAuthenticationFilter extends OncePerRequestFilter {
    private final ApiKeyService apiKeyService;

    ApiKeyAuthenticationFilter(ApiKeyService apiKeyService) {
        this.apiKeyService = apiKeyService;
    }

    @Override
    protected void doFilterInternal(HttpServletRequest request,
                                    HttpServletResponse response,
                                    FilterChain chain) throws ServletException, IOException {
        String apiKey = request.getHeader("X-API-Key");
        if (apiKey != null && !apiKey.isBlank()) {
            Optional<ApiKey> key = apiKeyService.verify(apiKey);
            if (key.isEmpty()) {
                response.setStatus(HttpServletResponse.SC_UNAUTHORIZED);
                response.getWriter().write("{\"error\":\"Invalid API key\"}");
                return;
            }
            apiKeyService.recordUsage(key.get());
            // Set tenant context from API key
            com.archie.generated.{{ java_package }}.config.TenantContext
                    .setCurrentTenant(key.get().getOrganizationId());
        }
        chain.doFilter(request, response);
    }
}
