/* ── Workflow Controllers ── */
{% for workflow in workflows %}
function workflow_{{ workflow.name_snake }}() {
    return {
        currentStepIndex: 0,
        stepData: {},
        stepSaving: false,
        completed: false,
        entityId: null,

        init() {},

        nextStep() {
            if (this.currentStepIndex < {{ workflow.steps | length }} - 1) this.currentStepIndex++;
        },

        prevStep() {
            if (this.currentStepIndex > 0) this.currentStepIndex--;
        },

        async executeStepAction(action, stepIndex) {
            this.stepSaving = true;
            const shell = Alpine.$data(document.querySelector('[x-data="appShell()"]'));
            try {
{% if workflow.primary_entity %}
                if (!this.entityId) {
                    // First step — create the entity
                    const created = await api.post('{{ workflow.primary_entity.api_base_path }}', this.stepData);
                    this.entityId = created.id;
                } else {
                    // Subsequent steps — update
                    await api.put(`{{ workflow.primary_entity.api_base_path }}/${this.entityId}`, this.stepData);
                }
{% endif %}
                if (shell) shell.showToast(`${action} completed`);
                this.nextStep();
            } catch (e) {
                if (shell) shell.showToast(`${action} failed: ${e.message}`, 'error');
            } finally {
                this.stepSaving = false;
            }
        },

        async completeWorkflow() {
            this.stepSaving = true;
            const shell = Alpine.$data(document.querySelector('[x-data="appShell()"]'));
            try {
{% if workflow.primary_entity %}
                if (this.entityId) {
                    await api.put(`{{ workflow.primary_entity.api_base_path }}/${this.entityId}`, this.stepData);
                }
{% endif %}
                this.completed = true;
                if (shell) shell.showToast('Workflow completed');
            } catch (e) {
                if (shell) shell.showToast(`Complete failed: ${e.message}`, 'error');
            } finally {
                this.stepSaving = false;
            }
        },

        resetWorkflow() {
            this.currentStepIndex = 0;
            this.stepData = {};
            this.entityId = null;
            this.completed = false;
        }
    };
}
{% endfor %}
