{# app/modules/solutions_product/templates/go_chi/docker_compose.yml.j2 #}
{# Docker Compose: App + PostgreSQL + Redis. #}
{# Context: solution_id, bundle_id, solution_name #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
services:
  app:
    build:
      context: .
      target: run
    ports:
      - "8080:8080"
    environment:
      - ENV=development
      - PORT=8080
      - DATABASE_URL=postgres://app:app@postgres:5432/{{ solution_name | lower | replace(' ', '_') | replace('-', '_') }}?sslmode=disable
      - CACHE_URL=redis://redis:6379/0
      - JWT_SECRET=dev-secret-change-me
      - LOG_LEVEL=debug
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy

  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: app
      POSTGRES_PASSWORD: app
      POSTGRES_DB: {{ solution_name | lower | replace(' ', '_') | replace('-', '_') }}
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U app"]
      interval: 5s
      timeout: 3s
      retries: 5

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5

{% if identity_provider is defined and identity_provider.type == "keycloak" %}
  keycloak:
    image: quay.io/keycloak/keycloak:24.0
    command: start-dev --import-realm
    environment:
      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: admin
      KC_DB: postgres
      KC_DB_URL: jdbc:postgresql://postgres/{{ solution_name | lower | replace(' ', '_') | replace('-', '_') }}_keycloak
      KC_DB_USERNAME: app
      KC_DB_PASSWORD: app
      KC_HOSTNAME_STRICT: "false"
      KC_HTTP_ENABLED: "true"
    ports:
      - "8080:8080"
    volumes:
      - ./keycloak/realm.json:/opt/keycloak/data/import/realm.json:ro
    depends_on:
      postgres:
        condition: service_healthy
{% endif %}

volumes:
  pgdata:
