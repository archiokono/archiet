describe('LoginScreen', () => {
  it('renders email and password fields', () => {
    render(<LoginScreen />, { wrapper: Wrapper });
    expect(screen.getByPlaceholderText(/email/i) || screen.getByTestId('email-input')).toBeTruthy();
    expect(screen.getByPlaceholderText(/password/i) || screen.getByTestId('password-input')).toBeTruthy();
  });

  it('has sign-in button', () => {
    render(<LoginScreen />, { wrapper: Wrapper });
    expect(screen.getByText(/sign in|log in/i)).toBeTruthy();
  });

  it('navigates to dashboard on valid credentials', async () => {
    render(<LoginScreen />, { wrapper: Wrapper });
    const emailInput = screen.getByPlaceholderText(/email/i) || screen.getByTestId('email-input');
    const passInput = screen.getByPlaceholderText(/password/i) || screen.getByTestId('password-input');
    fireEvent.changeText(emailInput, 'user@example.com');
    fireEvent.changeText(passInput, 'Valid@123');
    fireEvent.press(screen.getByText(/sign in|log in/i));
    await waitFor(() => {
      expect(mockReplace).toHaveBeenCalledWith(expect.stringMatching(/dashboard|\(tabs\)/));
    });
  });

  it('shows error on invalid credentials', async () => {
    render(<LoginScreen />, { wrapper: Wrapper });
    const emailInput = screen.getByPlaceholderText(/email/i) || screen.getByTestId('email-input');
    const passInput = screen.getByPlaceholderText(/password/i) || screen.getByTestId('password-input');
    fireEvent.changeText(emailInput, 'user@example.com');
    fireEvent.changeText(passInput, 'WrongPassword');
    fireEvent.press(screen.getByText(/sign in|log in/i));
    await waitFor(() => {
      expect(screen.getByText(/invalid|credentials|wrong/i)).toBeTruthy();
    });
  });

  it('disables button while logging in', async () => {
    let resolveLogin: () => void;
    server.use(
      rest.post(`${BASE}/api/v1/auth/token`, (_req, res, ctx) =>
        new Promise<ReturnType<typeof res>>((resolve) => {
          resolveLogin = () => resolve(res(ctx.json({ access_token: validToken, token_type: 'bearer', expires_in: 3600 })));
          setTimeout(resolveLogin, 2000);
        })
      )
    );
    render(<LoginScreen />, { wrapper: Wrapper });
    const emailInput = screen.getByPlaceholderText(/email/i) || screen.getByTestId('email-input');
    const passInput = screen.getByPlaceholderText(/password/i) || screen.getByTestId('password-input');
    fireEvent.changeText(emailInput, 'user@example.com');
    fireEvent.changeText(passInput, 'Valid@123');
    fireEvent.press(screen.getByText(/sign in|log in/i));
    const btn = screen.queryByText(/sign in|log in/i);
    if (btn) {
      expect(btn.props.disabled || btn.props.accessibilityState?.disabled).toBe(true);
    }
  });
});

