{# dashboard.html.j2 — Dashboard with metric cards, charts, recent activity, quick actions.
   Uses Chart.js via CDN for visualizations.
   Context (from ARCHIE): entities, solution_name, solution_id, product #}
{% raw %}{% extends "layout.html" %}

{% block title %}Dashboard{% endblock %}

{% block content %}
<div x-data="dashboard()" x-init="init()">

    {# Metric cards #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-{% endraw %}{{ [entities | length + 1, 4] | min }}{% raw %} gap-4 mb-8">
{% endraw %}
{% for entity in entities %}
        <div class="bg-white border border-zinc-200 rounded-xl p-5 hover:shadow-sm transition-shadow">
            <div class="flex items-center justify-between mb-3">
                <p class="text-xs text-zinc-500 uppercase tracking-wide font-medium">{{ entity.name_display }}</p>
                <a href="/{{ entity.name_snake }}s" class="text-xs text-blue-600 hover:underline">View</a>
            </div>
            <div class="flex items-end gap-2">
                <span class="text-2xl font-bold text-zinc-900" {% raw %}x-text="counts['{% endraw %}{{ entity.name_snake }}{% raw %}'] ?? '—'"{% endraw %}></span>
                <span class="text-xs text-emerald-600 font-medium mb-1" {% raw %}x-text="deltas['{% endraw %}{{ entity.name_snake }}{% raw %}'] ? '+' + deltas['{% endraw %}{{ entity.name_snake }}{% raw %}'] + ' this week' : ''"{% endraw %}></span>
            </div>
        </div>
{% endfor %}
{% raw %}
    </div>

    {# Charts row #}
    <div class="grid lg:grid-cols-2 gap-6 mb-8">
{% endraw %}
{% for entity in entities %}
{% if entity.status_field and entity.states %}
        <div class="bg-white border border-zinc-200 rounded-xl p-5">
            <h3 class="text-sm font-medium text-zinc-700 mb-4">{{ entity.name_display }} by Status</h3>
            <div class="h-48">
                <canvas id="chart-{{ entity.name_snake }}-status"></canvas>
            </div>
        </div>
{% endif %}
{% endfor %}
{% raw %}
        <div class="bg-white border border-zinc-200 rounded-xl p-5">
            <h3 class="text-sm font-medium text-zinc-700 mb-4">Records Created (Last 7 Days)</h3>
            <div class="h-48">
                <canvas id="chart-activity"></canvas>
            </div>
        </div>
    </div>

    {# Bottom row: Quick actions + Recent activity #}
    <div class="grid lg:grid-cols-3 gap-6">
        {# Quick actions #}
        <div class="bg-white border border-zinc-200 rounded-xl p-5">
            <h3 class="text-sm font-medium text-zinc-700 mb-4">Quick Actions</h3>
            <div class="space-y-2">
{% endraw %}
{% for entity in entities %}
                <a href="/{{ entity.name_snake }}s/new"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-zinc-50 transition-colors group">
                    <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 font-bold text-xs group-hover:bg-blue-100 transition">+</div>
                    <span class="text-sm text-zinc-700">New {{ entity.name_display }}</span>
                </a>
{% endfor %}
{% raw %}
            </div>
        </div>

        {# Recent activity #}
        <div class="lg:col-span-2 bg-white border border-zinc-200 rounded-xl p-5">
            <h3 class="text-sm font-medium text-zinc-700 mb-4">Recent Activity</h3>
            <div class="space-y-0">
                <template x-for="item in recentItems" :key="item._type + '_' + item.id">
                <a :href="'/' + item._type + 's/' + item.id"
                   class="flex items-center justify-between px-3 py-3 -mx-3 rounded-lg hover:bg-zinc-50 transition-colors">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-zinc-100 flex items-center justify-center text-xs font-bold text-zinc-500"
                             x-text="(item._type || '?')[0].toUpperCase()"></div>
                        <div>
                            <span class="text-sm font-medium text-zinc-900" x-text="item._label || item.id"></span>
                            <span class="text-xs text-zinc-400 ml-2" x-text="item._type.replace(/_/g, ' ')"></span>
                        </div>
                    </div>
                    <span class="text-xs text-zinc-400" x-text="formatDate(item.updated_at || item.created_at)"></span>
                </a>
                </template>
                <div x-show="recentItems.length === 0" class="text-center py-8 text-sm text-zinc-500">
                    No activity yet. Create your first record to get started.
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
function formatDate(d) {
    if (!d) return '';
    return new Date(d).toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
}

function dashboard() {
    return {
        counts: {}, deltas: {}, recentItems: [],
        statusData: {},

        async init() {
            const h = authHeaders();
            const allRecent = [];
{% endraw %}
{% for entity in entities %}
            try {
                const r = await fetch('{{ entity.api_path }}?limit=50', { headers: h });
                if (r.ok) {
                    const data = await r.json();
                    const items = Array.isArray(data) ? data : (data.items || data.content || []);
                    this.counts['{{ entity.name_snake }}'] = data.total || items.length;

                    // Delta: count created in last 7 days
                    const weekAgo = new Date(); weekAgo.setDate(weekAgo.getDate() - 7);
                    const recent = items.filter(i => i.created_at && new Date(i.created_at) > weekAgo);
                    this.deltas['{{ entity.name_snake }}'] = recent.length;

{% if entity.status_field and entity.states %}
                    // Status distribution for chart
                    const statusCounts = {};
{% for state in entity.states %}
                    statusCounts['{{ state }}'] = items.filter(i => i.{{ entity.status_field }} === '{{ state }}').length;
{% endfor %}
                    this.statusData['{{ entity.name_snake }}'] = statusCounts;
{% endif %}
                    for (const item of items.slice(0, 5)) {
                        allRecent.push({...item, _type: '{{ entity.name_snake }}', _label: item.{{ entity.label_field | default('name') }} || item.name || item.id});
                    }
                }
            } catch (e) {}
{% endfor %}
{% raw %}
            allRecent.sort((a, b) => new Date(b.updated_at || b.created_at || 0) - new Date(a.updated_at || a.created_at || 0));
            this.recentItems = allRecent.slice(0, 10);

            // Render charts after data loads
            this.$nextTick(() => this.renderCharts());
        },

        renderCharts() {
            const colors = ['#2563eb', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4', '#ec4899', '#6366f1'];
{% endraw %}

{% for entity in entities %}
{% if entity.status_field and entity.states %}
            // {{ entity.name_display }} status distribution
            const {{ entity.name_snake }}El = document.getElementById('chart-{{ entity.name_snake }}-status');
            if ({{ entity.name_snake }}El && this.statusData['{{ entity.name_snake }}']) {
                const data = this.statusData['{{ entity.name_snake }}'];
                new Chart({{ entity.name_snake }}El, {
                    type: 'doughnut',
                    data: {
                        labels: Object.keys(data).map(s => s.replace(/_/g, ' ')),
                        datasets: [{ data: Object.values(data), backgroundColor: colors.slice(0, Object.keys(data).length), borderWidth: 0 }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right', labels: { boxWidth: 12, font: { size: 11 } } } } }
                });
            }
{% endif %}
{% endfor %}
{% raw %}

            // Activity timeline (last 7 days)
            const actEl = document.getElementById('chart-activity');
            if (actEl) {
                const days = [];
                const dayCounts = [];
                for (let i = 6; i >= 0; i--) {
                    const d = new Date(); d.setDate(d.getDate() - i);
                    const label = d.toLocaleDateString(undefined, { weekday: 'short' });
                    days.push(label);
                    const dayStart = new Date(d); dayStart.setHours(0,0,0,0);
                    const dayEnd = new Date(d); dayEnd.setHours(23,59,59,999);
                    const count = this.recentItems.filter(item => {
                        const dt = new Date(item.created_at || item.updated_at);
                        return dt >= dayStart && dt <= dayEnd;
                    }).length;
                    dayCounts.push(count);
                }
                new Chart(actEl, {
                    type: 'bar',
                    data: {
                        labels: days,
                        datasets: [{ label: 'Records', data: dayCounts, backgroundColor: '#2563eb22', borderColor: '#2563eb', borderWidth: 1.5, borderRadius: 4 }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }, plugins: { legend: { display: false } } }
                });
            }
        },
    };
}
</script>
{% endblock %}
{% endraw %}
