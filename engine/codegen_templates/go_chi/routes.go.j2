// Register{{ entity_name }}Routes mounts {{ entity_name }} CRUD endpoints.
func Register{{ entity_name }}Routes(r chi.Router, repo *{{ entity_name }}Repository) {
	r.Group(func(r chi.Router) {
		r.Use(JWTAuthMiddleware)

{% for path in service.paths %}
{% set has_id = '{' in path.path %}
{% if path.method == 'get' and not has_id %}
		// List {{ entity_name }}
		r.Get("{{ path.path }}", func(w http.ResponseWriter, r *http.Request) {
			limit, _ := strconv.Atoi(r.URL.Query().Get("limit"))
			offset, _ := strconv.Atoi(r.URL.Query().Get("offset"))
			search := r.URL.Query().Get("search")
			if limit <= 0 || limit > 500 { limit = 100 }
			if offset < 0 { offset = 0 }
			entities, err := repo.List(r.Context(), limit, offset, search)
			if err != nil {
				writeJSON(w, http.StatusInternalServerError, map[string]string{"error": "Failed to list {{ entity_name }}"})
				return
			}
			writeJSON(w, http.StatusOK, entities)
		})

{% elif path.method == 'get' and has_id %}
		// Get {{ entity_name }} by ID
		r.Get("{{ path.path }}", func(w http.ResponseWriter, r *http.Request) {
			idStr := chi.URLParam(r, "id")
			id, err := uuid.Parse(idStr)
			if err != nil {
				writeJSON(w, http.StatusBadRequest, map[string]string{"error": "Invalid UUID"})
				return
			}
			entity, err := repo.GetByID(r.Context(), id)
			if err != nil {
				if strings.Contains(err.Error(), "no rows") {
					writeJSON(w, http.StatusNotFound, map[string]string{"error": "{{ entity_name }} not found"})
				} else {
					writeJSON(w, http.StatusInternalServerError, map[string]string{"error": err.Error()})
				}
				return
			}
			writeJSON(w, http.StatusOK, entity)
		})

{% elif path.method == 'post' and not has_id %}
		// Create {{ entity_name }}
		r.Post("{{ path.path }}", func(w http.ResponseWriter, r *http.Request) {
			var entity {{ entity_name }}
			if err := json.NewDecoder(r.Body).Decode(&entity); err != nil {
				writeJSON(w, http.StatusBadRequest, map[string]string{"error": "Invalid request body"})
				return
			}
			if err := repo.Create(r.Context(), &entity); err != nil {
				if strings.Contains(strings.ToUpper(err.Error()), "UNIQUE") || strings.Contains(err.Error(), "duplicate") {
					writeJSON(w, http.StatusConflict, map[string]string{"error": "A {{ entity_name }} with that value already exists"})
				} else if strings.Contains(strings.ToUpper(err.Error()), "NOT NULL") {
					writeJSON(w, http.StatusUnprocessableEntity, map[string]string{"error": "Required field missing: " + err.Error()})
				} else {
					writeJSON(w, http.StatusInternalServerError, map[string]string{"error": err.Error()})
				}
				return
			}
			writeJSON(w, http.StatusCreated, entity)
		})

{% elif path.method == 'put' and has_id %}
		// Update {{ entity_name }}
		r.Put("{{ path.path }}", func(w http.ResponseWriter, r *http.Request) {
			idStr := chi.URLParam(r, "id")
			id, err := uuid.Parse(idStr)
			if err != nil {
				writeJSON(w, http.StatusBadRequest, map[string]string{"error": "Invalid UUID"})
				return
			}
			var update {{ entity_name }}Update
			if err := json.NewDecoder(r.Body).Decode(&update); err != nil {
				writeJSON(w, http.StatusBadRequest, map[string]string{"error": "Invalid request body"})
				return
			}
			if err := repo.Update(r.Context(), id, &update); err != nil {
				if strings.Contains(err.Error(), "no rows") {
					writeJSON(w, http.StatusNotFound, map[string]string{"error": "{{ entity_name }} not found"})
				} else if strings.Contains(strings.ToUpper(err.Error()), "UNIQUE") {
					writeJSON(w, http.StatusConflict, map[string]string{"error": "A {{ entity_name }} with that value already exists"})
				} else {
					writeJSON(w, http.StatusInternalServerError, map[string]string{"error": err.Error()})
				}
				return
			}
			// Return updated entity
			entity, _ := repo.GetByID(r.Context(), id)
			writeJSON(w, http.StatusOK, entity)
		})

{% elif path.method == 'delete' and has_id %}
		// Delete {{ entity_name }}
		r.Delete("{{ path.path }}", func(w http.ResponseWriter, r *http.Request) {
			idStr := chi.URLParam(r, "id")
			id, err := uuid.Parse(idStr)
			if err != nil {
				writeJSON(w, http.StatusBadRequest, map[string]string{"error": "Invalid UUID"})
				return
			}
			if err := repo.Delete(r.Context(), id); err != nil {
				if strings.Contains(err.Error(), "no rows") {
					writeJSON(w, http.StatusNotFound, map[string]string{"error": "{{ entity_name }} not found"})
				} else {
					writeJSON(w, http.StatusInternalServerError, map[string]string{"error": err.Error()})
				}
				return
			}
			w.WriteHeader(http.StatusNoContent)
		})

{% else %}
