{#- app/modules/solutions_product/templates/python_flask/bootstrap.sh.j2 -#}
{#- One-command bootstrap for the generated Python/Flask project. -#}
{#- Context: project_name, solution_id, bundle_id, db_name, port -#}
#!/usr/bin/env bash
set -euo pipefail

PROJECT="{{ project_name }}"
PORT="{{ port | default('5000') }}"

echo "=== Bootstrapping $PROJECT (Flask) ==="
echo "    Generated by A.R.C.H.I.E. (Solution #{{ solution_id }})"
echo ""

# ── Check prerequisites ───────────────────────────────────────────────────

check_cmd() {
    command -v "$1" >/dev/null 2>&1 || { echo "ERROR: $1 is required but not installed."; exit 1; }
}

check_cmd docker
check_cmd "docker compose" || check_cmd docker-compose

echo "[1/5] Prerequisites OK"

# ── Create .env from template ─────────────────────────────────────────────

if [ ! -f .env ]; then
    cp .env.example .env
    ADMIN_PASSWORD=$(openssl rand -base64 24 2>/dev/null || python3 -c "import secrets; print(secrets.token_urlsafe(24))")
    SECRET_KEY=$(openssl rand -base64 48 2>/dev/null || python3 -c "import secrets; print(secrets.token_urlsafe(48))")
    JWT_SECRET=$(openssl rand -base64 48 2>/dev/null || python3 -c "import secrets; print(secrets.token_urlsafe(48))")
    sed -i "s|ADMIN_PASSWORD=CHANGE_THIS_IMMEDIATELY|ADMIN_PASSWORD=${ADMIN_PASSWORD}|" .env
    sed -i "s|SECRET_KEY=CHANGE_THIS_IMMEDIATELY|SECRET_KEY=${SECRET_KEY}|" .env
    sed -i "s|JWT_SECRET=CHANGE_THIS_IMMEDIATELY|JWT_SECRET=${JWT_SECRET}|" .env
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  GENERATED CREDENTIALS — SAVE THESE NOW (shown only once)   ║"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║  ADMIN_PASSWORD = ${ADMIN_PASSWORD}"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    echo "[2/5] Created .env with generated credentials"
else
    echo "[2/5] .env already exists — skipping"
fi

# ── Start services ────────────────────────────────────────────────────────

echo "[3/5] Starting services..."
docker compose up -d --build

# ── Wait for database ────────────────────────────────────────────────────

echo "[4/5] Waiting for database..."
for i in $(seq 1 30); do
    if docker compose exec -T db pg_isready -U postgres >/dev/null 2>&1; then
        echo "       Database ready"
        break
    fi
    if [ "$i" -eq 30 ]; then
        echo "ERROR: Database did not become ready in 30 seconds"
        exit 1
    fi
    sleep 1
done

# Run Flask-Migrate migrations
echo "       Running migrations..."
docker compose run --rm app flask db upgrade 2>/dev/null || echo "       (no migrations to run)"

# ── Verify ────────────────────────────────────────────────────────────────

echo "[5/5] Verifying..."
sleep 3
if curl -sf "http://localhost:${PORT}/health" >/dev/null 2>&1; then
    echo "       Health: OK"
else
    echo "       Health: FAILED (service may still be starting)"
fi

echo ""
echo "=== $PROJECT is running ==="
echo "  App:     http://localhost:${PORT}"
echo "  Health:  http://localhost:${PORT}/health"
echo ""
