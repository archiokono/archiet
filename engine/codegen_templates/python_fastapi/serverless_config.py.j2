# ── Cold start optimization ──

def warmup():
    """Pre-warm connections and caches during Lambda init phase.

    Call this at module-level in lambda_handler.py to shift
    initialization cost from the first request to the init phase.
    """
    if not IS_LAMBDA:
        return

