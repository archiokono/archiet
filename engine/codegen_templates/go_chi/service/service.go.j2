package service

import (
	"context"
	"fmt"

	"github.com/rs/zerolog/log"
)

{% for model_name, model_def in models.items() %}
// {{ model_name }}Service encapsulates business logic for {{ model_name }}.
type {{ model_name }}Service struct {
	// repo would be injected — using interface{} for template generality
}

// New{{ model_name }}Service creates a new service instance.
func New{{ model_name }}Service() *{{ model_name }}Service {
	return &{{ model_name }}Service{}
}

{% if model_def.state_machine %}
{% set sm = model_def.state_machine %}
// ── State Machine: {{ sm.field_name | default('status') }} ──

{% for t in sm.transitions | default([]) %}
// {{ t.trigger | capitalize }} transitions {{ model_name }} from {{ t.from_state }} to {{ t.to_state }}.
func (s *{{ model_name }}Service) {{ t.trigger | capitalize }}(ctx context.Context, entityID string, currentState string, orgID string, userID string) error {
	logger := log.With().
		Str("service", "{{ model_name }}Service").
		Str("trigger", "{{ t.trigger }}").
		Str("entity_id", entityID).
		Logger()

	logger.Info().Msg("state_transition_started")

	// Guard: verify current state
	if currentState != "{{ t.from_state }}" {
		return fmt.Errorf("invalid transition: current state is %s, expected {{ t.from_state }}", currentState)
	}

	// Apply transition → {{ t.to_state }}
	logger.Info().
		Str("from", "{{ t.from_state }}").
		Str("to", "{{ t.to_state }}").
		Msg("state_transition_completed")

	// Audit log effect
	s.AuditLog(ctx, "{{ model_name | lower }}", entityID, "{{ t.trigger }}", userID, orgID)

	return nil
}

{% endfor %}
{% endif %}

{% if model_def.business_rules %}
// ── Business Rules ──

{% for rule in model_def.business_rules %}
// {{ rule.trigger | capitalize }}{{ model_name }} applies the {{ rule.trigger }} business rule.
func (s *{{ model_name }}Service) {{ rule.trigger | capitalize }}{{ model_name }}(ctx context.Context, entityData map[string]interface{}) error {
	logger := log.With().
		Str("service", "{{ model_name }}Service").
		Str("rule", "{{ rule.trigger }}").
		Logger()

	logger.Info().Msg("business_rule_started")

{% for pc in rule.preconditions | default([]) %}
{% if pc.operator == '==' %}
	if entityData["{{ pc.field }}"] != {{ pc.value | tojson }} {
		return fmt.Errorf("precondition failed: {{ pc.field }} must be == {{ pc.value }}")
	}
{% elif pc.operator == '!=' %}
	if entityData["{{ pc.field }}"] == {{ pc.value | tojson }} {
		return fmt.Errorf("precondition failed: {{ pc.field }} must be != {{ pc.value }}")
	}
{% endif %}
{% endfor %}

{% for post in rule.postconditions | default([]) %}
	entityData["{{ post.field }}"] = {{ post.value | tojson }}
{% endfor %}

	logger.Info().Msg("business_rule_completed")
	return nil
}

{% endfor %}
{% endif %}

// AuditLog records a state transition or business action for {{ model_name }}.
func (s *{{ model_name }}Service) AuditLog(ctx context.Context, entityType, entityID, action, userID, orgID string) {
	log.Info().
		Str("entity_type", entityType).
		Str("entity_id", entityID).
		Str("action", action).
		Str("user_id", userID).
		Str("org_id", orgID).
		Msg("audit_log")
}

{% endfor %}
