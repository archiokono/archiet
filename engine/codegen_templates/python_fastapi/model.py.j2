# ── Audit trail event listeners ───────────────────────────────────────────────
# Fires after INSERT/UPDATE on audit-enabled models. Records full snapshot to
# audit_log so you have a complete mutation history without application-layer effort.
import json as _json
from sqlalchemy import event as _sa_event


def _record_audit(mapper, connection, target, action: str):
    """Insert a row into audit_log capturing who changed what."""
    try:
        connection.execute(
            __import__('sqlalchemy').text(
                "INSERT INTO audit_log (entity_type, entity_id, action, actor_id, snapshot)"
                " VALUES (:et, :eid, :act, :uid, CAST(:snap AS jsonb))"
            ),
            {
                "et": target.__class__.__name__,
                "eid": str(getattr(target, "id", "")),
                "act": action,
                "uid": str(
                    getattr(target, "updated_by_id", None)
                    or getattr(target, "created_by_id", None)
                    or "system"
                ),
                "snap": _json.dumps(
                    {c.key: str(getattr(target, c.key, None)) for c in mapper.column_attrs},
                    default=str,
                ),
            },
        )
    except Exception:
        pass  # audit failure must never break the main transaction


