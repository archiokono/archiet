import secrets

from fastapi import APIRouter, Depends, HTTPException, BackgroundTasks
from pydantic import BaseModel, HttpUrl
from sqlalchemy import select
from sqlalchemy.ext.asyncio import AsyncSession

from app.database import get_db
from app.auth_config import verify_token, TokenPayload
from app.webhook_service import WebhookSubscription, WebhookDelivery, deliver_webhook
from app.event_emitter import emit_event

router = APIRouter(prefix="/api/webhooks", tags=["webhooks"])


class CreateSubscriptionRequest(BaseModel):
    url: str
    events: list[str]
    description: str | None = None


class SubscriptionResponse(BaseModel):
    id: int
    url: str
    events: list[str]
    is_active: bool
    description: str | None
    secret: str | None = None  # Only returned on creation

    class Config:
        from_attributes = True


class TestWebhookRequest(BaseModel):
    subscription_id: int
    event_type: str = "test.ping"


@router.post("/subscriptions", response_model=SubscriptionResponse, status_code=201)
async def create_subscription(
    body: CreateSubscriptionRequest,
    db: AsyncSession = Depends(get_db),
    token: TokenPayload = Depends(verify_token),
):
    """Register a new webhook subscription."""
    secret = secrets.token_hex(32)
    sub = WebhookSubscription(
        url=body.url,
        secret=secret,
        events=body.events,
        description=body.description,
    )
    db.add(sub)
    await db.commit()
    await db.refresh(sub)
    return SubscriptionResponse(
        id=sub.id, url=sub.url, events=sub.events,
        is_active=sub.is_active, description=sub.description, secret=secret,
    )


@router.get("/subscriptions")
async def list_subscriptions(
    db: AsyncSession = Depends(get_db),
    token: TokenPayload = Depends(verify_token),
):
    """List all webhook subscriptions."""
    result = await db.execute(
        select(WebhookSubscription).where(WebhookSubscription.is_active == True)
    )
    subs = result.scalars().all()
    return {"subscriptions": [
        {"id": s.id, "url": s.url, "events": s.events, "is_active": s.is_active, "description": s.description}
        for s in subs
    ]}


@router.delete("/subscriptions/{sub_id}", status_code=204)
async def delete_subscription(
    sub_id: int,
    db: AsyncSession = Depends(get_db),
    token: TokenPayload = Depends(verify_token),
):
    """Deactivate a webhook subscription."""
    result = await db.execute(select(WebhookSubscription).where(WebhookSubscription.id == sub_id))
    sub = result.scalar_one_or_none()
    if not sub:
        raise HTTPException(status_code=404, detail="Subscription not found")
    sub.is_active = False
    await db.commit()


@router.get("/deliveries")
async def list_deliveries(
    status: str | None = None,
    limit: int = 50,
    db: AsyncSession = Depends(get_db),
    token: TokenPayload = Depends(verify_token),
):
    """List webhook delivery log entries."""
    query = select(WebhookDelivery).order_by(WebhookDelivery.created_at.desc()).limit(limit)
    if status:
        query = query.where(WebhookDelivery.status == status)
    result = await db.execute(query)
    deliveries = result.scalars().all()
    return {"deliveries": [
        {
            "id": d.id, "subscription_id": d.subscription_id, "event_type": d.event_type,
            "status": d.status, "attempts": d.attempts, "response_code": d.response_code,
            "error_message": d.error_message, "created_at": str(d.created_at),
        }
        for d in deliveries
    ]}


@router.post("/test")
async def test_webhook(
    body: TestWebhookRequest,
    background_tasks: BackgroundTasks,
    db: AsyncSession = Depends(get_db),
    token: TokenPayload = Depends(verify_token),
):
    """Send a test event to a specific subscription."""
    result = await db.execute(select(WebhookSubscription).where(WebhookSubscription.id == body.subscription_id))
    sub = result.scalar_one_or_none()
    if not sub:
        raise HTTPException(status_code=404, detail="Subscription not found")

    payload = {"event": body.event_type, "data": {"message": "Test webhook from ARCHIE"}}
    background_tasks.add_task(deliver_webhook, db, sub, body.event_type, payload)
    return {"status": "queued", "event": body.event_type, "subscription_id": sub.id}
