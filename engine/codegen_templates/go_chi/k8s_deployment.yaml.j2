{# app/modules/solutions_product/templates/go_chi/k8s_deployment.yaml.j2 #}
{# Generates Kubernetes Deployment + HPA + Service + probes + security context. #}
{# Context: solution_id, bundle_id, deployments (dict of service_name -> deploy config) #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE
{% for service_name, deploy in deployments.items() %}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
  labels:
    app: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
    archie-solution: "{{ solution_id }}"
spec:
  replicas: {{ deploy.scaling.min_replicas | default(1) }}
  selector:
    matchLabels:
      app: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
  template:
    metadata:
      labels:
        app: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
    spec:
      securityContext:
        runAsNonRoot: true
        runAsUser: 65534
        fsGroup: 65534
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
          image: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}:latest
          ports:
            - containerPort: 8080
              protocol: TCP
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop: ["ALL"]
          env:
            - name: ENV
              value: "production"
            - name: PORT
              value: "8080"
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}-secrets
                  key: database-url
            - name: JWT_SECRET
              valueFrom:
                secretKeyRef:
                  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}-secrets
                  key: jwt-secret
            {% if deploy.cache and deploy.cache != 'none' %}
            - name: CACHE_URL
              valueFrom:
                secretKeyRef:
                  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}-secrets
                  key: cache-url
            {% endif %}
            {% if deploy.messaging and deploy.messaging != 'none' %}
            - name: MESSAGING_URL
              valueFrom:
                secretKeyRef:
                  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}-secrets
                  key: messaging-url
            {% endif %}
          resources:
            requests:
              cpu: "50m"
              memory: "32Mi"
            limits:
              cpu: "200m"
              memory: "128Mi"
          readinessProbe:
            httpGet:
              path: /ready
              port: 8080
            initialDelaySeconds: 2
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /health
              port: 8080
            initialDelaySeconds: 5
            periodSeconds: 20
---
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}-hpa
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
  minReplicas: {{ deploy.scaling.min_replicas | default(1) }}
  maxReplicas: {{ deploy.scaling.max_replicas | default(3) }}
  metrics:
    - type: Resource
      resource:
        name: {{ deploy.scaling.metric | default('cpu') }}
        target:
          type: Utilization
          averageUtilization: {{ deploy.scaling.threshold | default(80) }}
---
apiVersion: v1
kind: Service
metadata:
  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
spec:
  selector:
    app: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
  ports:
    - port: 80
      targetPort: 8080
  type: ClusterIP
{% endfor %}
