{# mta.yaml.j2 — MTA deployment descriptor.
   Context: solution_id, bundle_id, sol_snake, solution_name #}
# GENERATED BY ARCHIE — solution {{ solution_id }}, bundle {{ bundle_id }}
_schema-version: "3.3.0"
ID: {{ sol_snake }}
version: 1.0.0
description: "{{ solution_name }} — generated by ARCHIE"

modules:
  - name: {{ sol_snake }}-srv
    type: nodejs
    path: .
    parameters:
      buildpack: nodejs_buildpack
      memory: 256M
    requires:
      - name: {{ sol_snake }}-hana
      - name: {{ sol_snake }}-xsuaa
      - name: {{ sol_snake }}-destination
    provides:
      - name: srv-api
        properties:
          srv-url: ${default-url}

  - name: {{ sol_snake }}-db-deployer
    type: hdb
    path: gen/db
    requires:
      - name: {{ sol_snake }}-hana

resources:
  - name: {{ sol_snake }}-hana
    type: com.sap.xs.hana
    parameters:
      service: hana
      service-plan: hdi-shared

  - name: {{ sol_snake }}-xsuaa
    type: org.cloudfoundry.managed-service
    parameters:
      service: xsuaa
      service-plan: application
      path: ./xs-security.json

  - name: {{ sol_snake }}-destination
    type: org.cloudfoundry.managed-service
    parameters:
      service: destination
      service-plan: lite
