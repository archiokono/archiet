{# app/modules/solutions_product/templates/shared/prometheus_alerts.yaml.j2 #}
{# PrometheusRule alerts generated from architecture spec. #}
{# Context: service_name, solution_id, bundle_id, slas, integrations #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE

apiVersion: monitoring.coreos.com/v1
kind: PrometheusRule
metadata:
  name: {{ service_name }}-alerts
  labels:
    app: {{ service_name }}
    generated-by: archie
spec:
  groups:
    - name: {{ service_name }}-sla-alerts
      rules:
        {% for sla in slas %}
        - alert: {{ service_name | replace('-', '_') }}_SLA_{{ sla.name_snake }}_Breach
          expr: histogram_quantile(0.99, rate(http_server_request_duration_seconds_bucket{service="{{ service_name }}"}[5m])) > {{ sla.threshold_seconds }}
          for: 5m
          labels:
            severity: critical
            service: {{ service_name }}
            sla: "{{ sla.name }}"
          annotations:
            summary: "{{ service_name }} p99 latency exceeds {{ sla.value_ms }}ms SLA ({{ sla.name }})"
            description: "The 99th percentile latency for {{ service_name }} has exceeded the {{ sla.name }} SLA threshold of {{ sla.value_ms }}ms for more than 5 minutes."
            runbook_url: "docs/RUNBOOK.md#high-latency"
        {% endfor %}

    - name: {{ service_name }}-error-alerts
      rules:
        - alert: {{ service_name | replace('-', '_') }}_High_Error_Rate
          expr: >
            (
              rate(http_server_request_duration_seconds_count{service="{{ service_name }}", http_response_status_code=~"5.."}[5m])
              /
              rate(http_server_request_duration_seconds_count{service="{{ service_name }}"}[5m])
            ) > 0.01
          for: 5m
          labels:
            severity: warning
            service: {{ service_name }}
          annotations:
            summary: "{{ service_name }} error rate above 1%"
            description: "The 5xx error rate for {{ service_name }} has exceeded 1% for more than 5 minutes."
            runbook_url: "docs/RUNBOOK.md#high-error-rate"

        - alert: {{ service_name | replace('-', '_') }}_Critical_Error_Rate
          expr: >
            (
              rate(http_server_request_duration_seconds_count{service="{{ service_name }}", http_response_status_code=~"5.."}[5m])
              /
              rate(http_server_request_duration_seconds_count{service="{{ service_name }}"}[5m])
            ) > 0.05
          for: 2m
          labels:
            severity: critical
            service: {{ service_name }}
          annotations:
            summary: "{{ service_name }} error rate above 5%"
            description: "The 5xx error rate for {{ service_name }} has exceeded 5% for more than 2 minutes. Immediate investigation required."
            runbook_url: "docs/RUNBOOK.md#high-error-rate"

    - name: {{ service_name }}-dependency-alerts
      rules:
        {% for integration in integrations %}
        - alert: {{ service_name | replace('-', '_') }}_{{ integration.name_snake }}_Down
          expr: up{service="{{ service_name }}", dependency="{{ integration.name }}"} == 0
          for: 2m
          labels:
            severity: critical
            service: {{ service_name }}
            dependency: "{{ integration.name }}"
          annotations:
            summary: "{{ service_name }} cannot reach {{ integration.name }}"
            description: "The dependency {{ integration.name }} ({{ integration.protocol | default('rest') }}) has been unreachable for more than 2 minutes."
            runbook_url: "docs/RUNBOOK.md#dependencies"
        {% endfor %}

    - name: {{ service_name }}-resource-alerts
      rules:
        - alert: {{ service_name | replace('-', '_') }}_High_Memory
          expr: container_memory_working_set_bytes{pod=~"{{ service_name }}.*"} / container_spec_memory_limit_bytes{pod=~"{{ service_name }}.*"} > 0.85
          for: 5m
          labels:
            severity: warning
            service: {{ service_name }}
          annotations:
            summary: "{{ service_name }} memory usage above 85%"
            runbook_url: "docs/RUNBOOK.md#service-unreachable"

        - alert: {{ service_name | replace('-', '_') }}_Pod_Restart
          expr: increase(kube_pod_container_status_restarts_total{pod=~"{{ service_name }}.*"}[1h]) > 3
          for: 1m
          labels:
            severity: warning
            service: {{ service_name }}
          annotations:
            summary: "{{ service_name }} restarted more than 3 times in the last hour"
            runbook_url: "docs/RUNBOOK.md#service-unreachable"
