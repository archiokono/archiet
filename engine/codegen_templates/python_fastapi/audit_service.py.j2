def compute_diff(before: dict, after: dict) -> dict:
    """Compute a field-level diff between two entity states.

    Returns: {field_name: {"old": old_val, "new": new_val}} for changed fields.
    """
    diff = {}
    all_keys = set(list(before.keys()) + list(after.keys()))
    skip = {"updated_at", "modified_at", "deleted_at"}
    for key in all_keys:
        if key in skip:
            continue
        old = before.get(key)
        new = after.get(key)
        if str(old) != str(new):
            diff[key] = {"old": old, "new": new}
    return diff


