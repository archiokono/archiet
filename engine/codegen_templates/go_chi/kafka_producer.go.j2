{# Generates segmentio/kafka-go based producer with delivery confirmation, DLQ. #}
{# Context: solution_id, bundle_id, integrations (dict of name -> contract) #}
// GENERATED BY ARCHIE
// solution_id: {{ solution_id }}
// bundle_id: {{ bundle_id }}
// DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE

package main

import (
	"context"
	"encoding/json"
	"fmt"
	"time"

	"github.com/rs/zerolog/log"
	"github.com/segmentio/kafka-go"
{% if integrations.values() | selectattr('auth_method', 'equalto', 'sasl_ssl') | list %}
	"github.com/segmentio/kafka-go/sasl/plain"
	"crypto/tls"
{% endif %}
)

{% for integration_name, contract in integrations.items() %}
{% if contract.communication_type in ('async_event', 'async_queue') %}
{% set struct_name = integration_name | replace(' ', '') | replace('-', '') | replace('_', '') %}
// {{ struct_name }}Producer — Kafka producer for {{ integration_name }}.
//
// Topic: {{ contract.topic_or_queue | default('N/A') }}
// Message format: {{ contract.message_format | default('json') }}
// Auth: {{ contract.auth_method | default('none') }}
// DLQ enabled: {{ contract.dlq_enabled | default(false) }}
type {{ struct_name }}Producer struct {
	writer    *kafka.Writer
{% if contract.dlq_enabled | default(false) %}
	dlqWriter *kafka.Writer
{% endif %}
	topic     string
}

func New{{ struct_name }}Producer(brokers []string, topic string) *{{ struct_name }}Producer {
	if topic == "" {
		topic = "{{ contract.topic_or_queue | default('default-topic') }}"
	}

{% if contract.auth_method == 'sasl_ssl' %}
	mechanism := plain.Mechanism{
		Username: "", // Set from config
		Password: "", // Set from config
	}
	transport := &kafka.Transport{
		SASL: mechanism,
		TLS:  &tls.Config{},
	}
{% endif %}

	writer := &kafka.Writer{
		Addr:         kafka.TCP(brokers...),
		Topic:        topic,
		Balancer:     &kafka.LeastBytes{},
		BatchSize:    100,
		BatchTimeout: 10 * time.Millisecond,
		RequiredAcks: kafka.RequireAll,
		Async:        false,
{% if contract.auth_method == 'sasl_ssl' %}
		Transport:    transport,
{% endif %}
	}

{% if contract.dlq_enabled | default(false) %}
	dlqWriter := &kafka.Writer{
		Addr:         kafka.TCP(brokers...),
		Topic:        topic + ".dlq",
		Balancer:     &kafka.LeastBytes{},
		RequiredAcks: kafka.RequireAll,
{% if contract.auth_method == 'sasl_ssl' %}
		Transport:    transport,
{% endif %}
	}
{% endif %}

	return &{{ struct_name }}Producer{
		writer:    writer,
{% if contract.dlq_enabled | default(false) %}
		dlqWriter: dlqWriter,
{% endif %}
		topic:     topic,
	}
}

// Send publishes a message with delivery confirmation.
func (p *{{ struct_name }}Producer) Send(ctx context.Context, key string, value interface{}) error {
{% if contract.message_format == 'json' or not contract.message_format %}
	data, err := json.Marshal(value)
	if err != nil {
		return fmt.Errorf("marshal message: %w", err)
	}
{% elif contract.message_format == 'protobuf' %}
	// Protobuf: value must implement proto.Message
	data, ok := value.([]byte)
	if !ok {
		return fmt.Errorf("protobuf value must be []byte")
	}
{% else %}
	data, err := json.Marshal(value)
	if err != nil {
		return fmt.Errorf("marshal message: %w", err)
	}
{% endif %}

	msg := kafka.Message{
		Key:   []byte(key),
		Value: data,
		Time:  time.Now(),
	}

	err = p.writer.WriteMessages(ctx, msg)
	if err != nil {
		log.Error().Err(err).Str("topic", p.topic).Str("key", key).Msg("{{ struct_name }}: send failed")
{% if contract.dlq_enabled | default(false) %}
		_ = p.sendToDLQ(ctx, key, data, err.Error())
{% endif %}
		return fmt.Errorf("send to %s: %w", p.topic, err)
	}

	log.Debug().Str("topic", p.topic).Str("key", key).Msg("{{ struct_name }}: delivered")
	return nil
}

{% if contract.dlq_enabled | default(false) %}
func (p *{{ struct_name }}Producer) sendToDLQ(ctx context.Context, key string, value []byte, errMsg string) error {
	dlqPayload, _ := json.Marshal(map[string]interface{}{
		"original_key":   key,
		"original_value": string(value),
		"error":          errMsg,
		"timestamp":      time.Now().UTC().Format(time.RFC3339),
	})
	err := p.dlqWriter.WriteMessages(ctx, kafka.Message{
		Key:   []byte(key),
		Value: dlqPayload,
	})
	if err != nil {
		log.Error().Err(err).Msg("{{ struct_name }}: DLQ send also failed")
	} else {
		log.Warn().Str("key", key).Msg("{{ struct_name }}: routed to DLQ")
	}
	return err
}
{% endif %}

// Close gracefully shuts down the producer.
func (p *{{ struct_name }}Producer) Close() error {
	var firstErr error
	if err := p.writer.Close(); err != nil {
		firstErr = err
	}
{% if contract.dlq_enabled | default(false) %}
	if err := p.dlqWriter.Close(); err != nil && firstErr == nil {
		firstErr = err
	}
{% endif %}
	log.Info().Msg("{{ struct_name }}Producer closed")
	return firstErr
}

{% endif %}
{% endfor %}
