{# app/modules/solutions_product/templates/python_fastapi/k8s_network_policy.yaml.j2 #}
{# Generates Kubernetes NetworkPolicy manifests from NFR specs with infrastructure enforcement. #}
{# Context: solution_id, bundle_id, app_name, nfr_policies (list of dicts with name, pod_selector, ingress_rules, egress_rules) #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE
{% for nfr in nfr_policies %}
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: {{ nfr.name | lower | replace(' ', '-') | replace('_', '-') }}
  labels:
    app: {{ app_name | lower | replace(' ', '-') | replace('_', '-') }}
    nfr-source: "{{ nfr.id | default('') }}"
spec:
  podSelector:
    matchLabels:
      app: {{ nfr.pod_selector | default(app_name | lower | replace(' ', '-') | replace('_', '-')) }}
  policyTypes:
{% if nfr.ingress_rules %}
    - Ingress
{% endif %}
{% if nfr.egress_rules %}
    - Egress
{% endif %}
{% if nfr.ingress_rules %}
  ingress:
{% for rule in nfr.ingress_rules %}
    - from:
{% if rule.namespace %}
        - namespaceSelector:
            matchLabels:
              name: {{ rule.namespace }}
{% endif %}
{% if rule.pod_label %}
        - podSelector:
            matchLabels:
              app: {{ rule.pod_label }}
{% endif %}
      ports:
        - protocol: {{ rule.protocol | default('TCP') }}
          port: {{ rule.port | default(8000) }}
{% endfor %}
{% endif %}
{% if nfr.egress_rules %}
  egress:
{% for rule in nfr.egress_rules %}
    - to:
{% if rule.namespace %}
        - namespaceSelector:
            matchLabels:
              name: {{ rule.namespace }}
{% endif %}
{% if rule.cidr %}
        - ipBlock:
            cidr: {{ rule.cidr }}
{% endif %}
      ports:
        - protocol: {{ rule.protocol | default('TCP') }}
          port: {{ rule.port | default(443) }}
{% endfor %}
{% endif %}
{% endfor %}
