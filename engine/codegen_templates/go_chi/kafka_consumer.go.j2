// MessageHandler processes a consumed message. Return error to trigger DLQ routing.
type MessageHandler func(ctx context.Context, key string, value []byte, headers []kafka.Header) error

{% for integration_name, contract in integrations.items() %}
{% if contract.communication_type in ('async_event', 'async_queue') %}
{% set struct_name = integration_name | replace(' ', '') | replace('-', '') | replace('_', '') %}
// {{ struct_name }}Consumer — Kafka consumer for {{ integration_name }}.
//
// Topic: {{ contract.topic_or_queue | default('N/A') }}
// Auth: {{ contract.auth_method | default('none') }}
// DLQ enabled: {{ contract.dlq_enabled | default(false) }}
type {{ struct_name }}Consumer struct {
	reader  *kafka.Reader
	handler MessageHandler
{% if contract.dlq_enabled | default(false) %}
	dlqWriter *kafka.Writer
{% endif %}
}

func New{{ struct_name }}Consumer(brokers []string, groupID, topic string, handler MessageHandler) *{{ struct_name }}Consumer {
	if topic == "" {
		topic = "{{ contract.topic_or_queue | default('default-topic') }}"
	}

{% if contract.auth_method == 'sasl_ssl' %}
	dialer := &kafka.Dialer{
		SASLMechanism: plain.Mechanism{
			Username: "", // Set from config
			Password: "", // Set from config
		},
		TLS: &tls.Config{},
	}
{% endif %}

	reader := kafka.NewReader(kafka.ReaderConfig{
		Brokers:        brokers,
		GroupID:        groupID,
		Topic:          topic,
		MinBytes:       1,
		MaxBytes:       10e6,
		CommitInterval: time.Second,
		StartOffset:    kafka.FirstOffset,
{% if contract.auth_method == 'sasl_ssl' %}
		Dialer:         dialer,
{% endif %}
	})

{% if contract.dlq_enabled | default(false) %}
	dlqWriter := &kafka.Writer{
		Addr:         kafka.TCP(brokers...),
		Topic:        topic + ".dlq",
		Balancer:     &kafka.LeastBytes{},
		RequiredAcks: kafka.RequireAll,
	}
{% endif %}

	return &{{ struct_name }}Consumer{
		reader:  reader,
		handler: handler,
{% if contract.dlq_enabled | default(false) %}
		dlqWriter: dlqWriter,
{% endif %}
	}
}

// Consume runs the main consumption loop. Blocks until context is cancelled.
func (c *{{ struct_name }}Consumer) Consume(ctx context.Context) error {
	log.Info().Str("topic", c.reader.Config().Topic).Str("group", c.reader.Config().GroupID).Msg("{{ struct_name }}Consumer started")

	for {
		select {
		case <-ctx.Done():
			log.Info().Msg("{{ struct_name }}Consumer: context cancelled, shutting down")
			return c.Close()
		default:
		}

		msg, err := c.reader.FetchMessage(ctx)
		if err != nil {
			if ctx.Err() != nil {
				return c.Close()
			}
			log.Error().Err(err).Msg("{{ struct_name }}Consumer: fetch error")
			continue
		}

		if processErr := c.handler(ctx, string(msg.Key), msg.Value, msg.Headers); processErr != nil {
			log.Error().Err(processErr).Int64("offset", msg.Offset).Msg("{{ struct_name }}Consumer: handler error")
{% if contract.dlq_enabled | default(false) %}
			_ = c.routeToDLQ(ctx, msg, processErr.Error())
{% endif %}
		}

		if err := c.reader.CommitMessages(ctx, msg); err != nil {
			log.Error().Err(err).Int64("offset", msg.Offset).Msg("{{ struct_name }}Consumer: commit error")
		}
	}
}

{% if contract.dlq_enabled | default(false) %}
func (c *{{ struct_name }}Consumer) routeToDLQ(ctx context.Context, msg kafka.Message, errMsg string) error {
	dlqPayload, _ := json.Marshal(map[string]interface{}{
		"original_topic":     msg.Topic,
		"original_partition": msg.Partition,
		"original_offset":    msg.Offset,
		"original_key":       string(msg.Key),
		"original_value":     string(msg.Value),
		"error":              errMsg,
		"timestamp":          time.Now().UTC().Format(time.RFC3339),
	})
	err := c.dlqWriter.WriteMessages(ctx, kafka.Message{
		Key:   msg.Key,
		Value: dlqPayload,
	})
	if err != nil {
		log.Error().Err(err).Msg("{{ struct_name }}Consumer: DLQ send failed")
	} else {
		log.Warn().Int64("offset", msg.Offset).Msg("{{ struct_name }}Consumer: routed to DLQ")
	}
	return err
}
{% endif %}

// Close gracefully shuts down the consumer.
func (c *{{ struct_name }}Consumer) Close() error {
	var firstErr error
	if err := c.reader.Close(); err != nil {
		firstErr = err
	}
{% if contract.dlq_enabled | default(false) %}
	if err := c.dlqWriter.Close(); err != nil && firstErr == nil {
		firstErr = err
	}
{% endif %}
	log.Info().Msg("{{ struct_name }}Consumer closed")
	return firstErr
}

{% endif %}
{% endfor %}
