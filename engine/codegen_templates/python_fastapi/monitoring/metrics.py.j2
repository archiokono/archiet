# GENERATED BY ARCHIE — solution_id: {{ solution_id }}
# Prometheus metrics: request latency, error rates, per-entity counters.

from typing import Callable
try:
    from prometheus_client import Counter, Gauge, Histogram, generate_latest, CONTENT_TYPE_LATEST
    _HAS_PROMETHEUS = True
except ImportError:
    _HAS_PROMETHEUS = False

from fastapi import APIRouter, Request, Response
from fastapi.responses import PlainTextResponse

# ── Metrics definitions ───────────────────────────────────────────────────────

if _HAS_PROMETHEUS:
    REQUEST_COUNT = Counter(
        "{{ solution_name | lower | replace(' ', '_') }}_requests_total",
        "Total HTTP requests",
        ["method", "endpoint", "status_code"],
    )
    REQUEST_LATENCY = Histogram(
        "{{ solution_name | lower | replace(' ', '_') }}_request_duration_seconds",
        "HTTP request latency",
        ["method", "endpoint"],
        buckets=[0.005, 0.01, 0.025, 0.05, 0.1, 0.25, 0.5, 1.0, 2.5, 5.0],
    )
    ACTIVE_REQUESTS = Gauge(
        "{{ solution_name | lower | replace(' ', '_') }}_active_requests",
        "Currently active HTTP requests",
    )
{% for model_name in model_names %}
    {{ model_name | upper }}_CREATED = Counter(
        "{{ solution_name | lower | replace(' ', '_') }}_{{ model_name | lower }}_created_total",
        "Total {{ model_name }} records created",
    )
    {{ model_name | upper }}_DELETED = Counter(
        "{{ solution_name | lower | replace(' ', '_') }}_{{ model_name | lower }}_deleted_total",
        "Total {{ model_name }} records soft-deleted",
    )
{% endfor %}

# ── Metrics endpoint ──────────────────────────────────────────────────────────

router = APIRouter()


@router.get("/metrics", response_class=PlainTextResponse, include_in_schema=False)
async def metrics_endpoint():
    """Prometheus scrape endpoint. Protected by network policy in production."""
    if not _HAS_PROMETHEUS:
        return PlainTextResponse("# prometheus_client not installed\n", media_type="text/plain")
    return PlainTextResponse(generate_latest(), media_type=CONTENT_TYPE_LATEST)


# ── Middleware ────────────────────────────────────────────────────────────────

async def metrics_middleware(request: Request, call_next: Callable) -> Response:
    """Track request count, latency, and active requests."""
    if not _HAS_PROMETHEUS:
        return await call_next(request)

    endpoint = request.url.path
    method = request.method

    ACTIVE_REQUESTS.inc()
    with REQUEST_LATENCY.labels(method=method, endpoint=endpoint).time():
        response = await call_next(request)

    ACTIVE_REQUESTS.dec()
    REQUEST_COUNT.labels(
        method=method,
        endpoint=endpoint,
        status_code=str(response.status_code),
    ).inc()
    return response
