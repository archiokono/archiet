{% for model_name in model_names %}
// ── {{ model_name }} hooks ─────────────────────────────────────────────────────

export function use{{ model_name }}List(params?: { page?: number; per_page?: number; search?: string }) {
  return useQuery({
    queryKey: ['{{ model_name | lower }}s', params],
    queryFn: () => {{ model_name }}API.list(params).then((r) => r.data),
    keepPreviousData: true,
  });
}

export function use{{ model_name }}Detail(id: string | undefined) {
  return useQuery({
    queryKey: ['{{ model_name | lower }}', id],
    queryFn: () => {{ model_name }}API.get(id!).then((r) => r.data),
    enabled: !!id,
  });
}

export function useCreate{{ model_name }}() {
  const qc = useQueryClient();
  return useMutation({
    mutationFn: (data: any) => {{ model_name }}API.create(data).then((r) => r.data),
    onSuccess: () => qc.invalidateQueries({ queryKey: ['{{ model_name | lower }}s'] }),
  });
}

export function useUpdate{{ model_name }}(id: string) {
  const qc = useQueryClient();
  return useMutation({
    mutationFn: (data: any) => {{ model_name }}API.update(id, data).then((r) => r.data),
    onSuccess: () => {
      qc.invalidateQueries({ queryKey: ['{{ model_name | lower }}s'] });
      qc.invalidateQueries({ queryKey: ['{{ model_name | lower }}', id] });
    },
  });
}

export function useDelete{{ model_name }}() {
  const qc = useQueryClient();
  return useMutation({
    mutationFn: (id: string) => {{ model_name }}API.delete(id),
    onSuccess: () => qc.invalidateQueries({ queryKey: ['{{ model_name | lower }}s'] }),
  });
}
