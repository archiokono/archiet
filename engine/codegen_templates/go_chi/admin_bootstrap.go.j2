package main

import (
	"context"
	"database/sql"
	"log"
	"os"

	"golang.org/x/crypto/bcrypt"
)

// SeedAdmin creates an admin user if none exists.
// Reads ADMIN_EMAIL and ADMIN_PASSWORD from environment variables.
// Skips silently if env vars are not set or an admin already exists.
// Called once from main() after database migration.
func SeedAdmin(ctx context.Context, db *sql.DB) {
	adminEmail := os.Getenv("ADMIN_EMAIL")
	adminPassword := os.Getenv("ADMIN_PASSWORD")

	if adminEmail == "" || adminPassword == "" {
		log.Println("ADMIN_EMAIL/ADMIN_PASSWORD not set — skipping admin bootstrap")
		return
	}

	// Check if any admin already exists
	var count int
	err := db.QueryRowContext(ctx, "SELECT COUNT(*) FROM users WHERE role = 'admin'").Scan(&count)
	if err != nil {
		log.Printf("admin bootstrap: could not check for existing admin: %v", err)
		return
	}
	if count > 0 {
		log.Println("Admin user already exists — skipping bootstrap")
		return
	}

	// Check if this specific email exists (promote to admin)
	var existingID int64
	err = db.QueryRowContext(ctx, "SELECT id FROM users WHERE email = $1", adminEmail).Scan(&existingID)
	if err == nil {
		_, err = db.ExecContext(ctx,
			"UPDATE users SET role = 'admin', email_verified = true WHERE id = $1",
			existingID,
		)
		if err != nil {
			log.Printf("admin bootstrap: could not promote user: %v", err)
			return
		}
		log.Printf("Promoted existing user %s to admin", adminEmail)
		return
	}

	// Create new admin user
	hashedPassword, err := bcrypt.GenerateFromPassword([]byte(adminPassword), bcrypt.DefaultCost)
	if err != nil {
		log.Printf("admin bootstrap: could not hash password: %v", err)
		return
	}

	_, err = db.ExecContext(ctx,
		`INSERT INTO users (email, full_name, hashed_password, role, is_active, email_verified, created_at)
		 VALUES ($1, 'Administrator', $2, 'admin', true, true, NOW())`,
		adminEmail, string(hashedPassword),
	)
	if err != nil {
		log.Printf("admin bootstrap: could not create admin: %v", err)
		return
	}

	log.Printf("Admin user created: %s (role=admin)", adminEmail)
}
