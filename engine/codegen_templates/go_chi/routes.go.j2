{# ── State Machine Transition Endpoints ── #}
{% if state_machine_transitions %}
{% for sm_entity, transitions in state_machine_transitions.items() %}
// Register{{ sm_entity }}TransitionRoutes mounts state machine endpoints for {{ sm_entity }}.
func Register{{ sm_entity }}TransitionRoutes(r chi.Router, repo *{{ sm_entity }}Repository, handler *{{ sm_entity }}Handler) {
	r.Group(func(r chi.Router) {
		r.Use(JWTAuthMiddleware)

{% for t in transitions %}
		// State transition: {{ t.trigger }} ({{ t.from_state }} → {{ t.to_state }})
		r.Post("/api/{{ sm_entity | lower }}s/{entity_id}/{{ t.trigger }}", func(w http.ResponseWriter, r *http.Request) {
			idStr := chi.URLParam(r, "entity_id")
			id, err := uuid.Parse(idStr)
			if err != nil {
				writeJSON(w, http.StatusBadRequest, map[string]string{"error": "Invalid UUID"})
				return
			}
			entity, err := repo.GetByID(r.Context(), id)
			if err != nil {
				writeJSON(w, http.StatusNotFound, map[string]string{"error": "{{ sm_entity }} not found"})
				return
			}
			if err := handler.{{ t.trigger | capitalize | replace('_', '') }}{{ sm_entity }}(r.Context(), entity); err != nil {
				writeJSON(w, http.StatusConflict, map[string]string{"error": err.Error()})
				return
			}
			writeJSON(w, http.StatusOK, entity)
		})

{% endfor %}
		// Available transitions for {{ sm_entity }}
		r.Get("/api/{{ sm_entity | lower }}s/{entity_id}/available-actions", func(w http.ResponseWriter, r *http.Request) {
			idStr := chi.URLParam(r, "entity_id")
			id, err := uuid.Parse(idStr)
			if err != nil {
				writeJSON(w, http.StatusBadRequest, map[string]string{"error": "Invalid UUID"})
				return
			}
			entity, err := repo.GetByID(r.Context(), id)
			if err != nil {
				writeJSON(w, http.StatusNotFound, map[string]string{"error": "{{ sm_entity }} not found"})
				return
			}
			_ = entity // used to determine state for available transitions
			log.Debug().Str("entity_id", id.String()).Msg("available-actions requested for {{ sm_entity }}")
			writeJSON(w, http.StatusOK, map[string]interface{}{"available_triggers": []string{}})
		})
	})
}

