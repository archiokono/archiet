// @Router /v1/{{ slug }}/{id}/transitions/{{ t.trigger }} [post]
func (h *{{ model_name }}Handler) Transition{{ t.trigger | capitalize }}(w http.ResponseWriter, r *http.Request) {
	id := chi.URLParam(r, "id")
	if id == "" {
		render.Status(r, http.StatusBadRequest)
		render.JSON(w, r, map[string]string{"error": "id is required"})
		return
	}
	orgID := orgIDFromCtx(r.Context())
	userID := userIDFromCtx(r.Context())

	entity, err := h.repo.GetByID(r.Context(), id, orgID)
	if err != nil {
		render.Status(r, http.StatusNotFound)
		render.JSON(w, r, map[string]string{"error": "not found"})
		return
	}
	current := ""
	if m, ok := entity.(map[string]interface{}); ok {
		if v, ok := m["{{ model_def.state_machine.field_name | default('status') }}"]; ok {
			current, _ = v.(string)
		}
	}
	if err := h.svc.{{ t.trigger | capitalize }}(r.Context(), id, current, orgID, userID); err != nil {
		log.Warn().Err(err).Str("id", id).Str("transition", "{{ t.trigger }}").Msg("transition_failed")
		render.Status(r, http.StatusConflict)
		render.JSON(w, r, map[string]string{"error": err.Error()})
		return
	}
	updates := map[string]interface{}{"{{ model_def.state_machine.field_name | default('status') }}": "{{ t.to_state }}"}
	if err := h.repo.Update(r.Context(), id, updates, orgID); err != nil {
		render.Status(r, http.StatusInternalServerError)
		render.JSON(w, r, map[string]string{"error": "failed to persist transition"})
		return
	}
	render.Status(r, http.StatusOK)
	render.JSON(w, r, map[string]string{"id": id, "{{ model_def.state_machine.field_name | default('status') }}": "{{ t.to_state }}"})
