/* ── Status badge color mapping ── */
const STATUS_COLORS = {
{% for status, color in status_colors.items() %}
    '{{ status }}': '{{ color }}',
{% endfor %}
    '_default': 'zinc'
};

function statusBadgeClass(value) {
    if (!value) return 'bg-zinc-500/10 text-zinc-400 border-zinc-500/30';
    const key = String(value).toLowerCase().replace(/[\s_-]+/g, '_');
    const color = STATUS_COLORS[key] || STATUS_COLORS['_default'];
    return `bg-${color}-500/10 text-${color}-400 border-${color}-500/30`;
}

/* ── API Client ── */
const api = {
    token: localStorage.getItem('auth_token') || '',
    async request(method, path, body) {
        const headers = { 'Content-Type': 'application/json' };
        if (this.token) headers['Authorization'] = `Bearer ${this.token}`;
        const opts = { method, headers };
        if (body && method !== 'GET') opts.body = JSON.stringify(body);
        const res = await fetch(path, opts);
        if (!res.ok) {
            const err = await res.json().catch(() => ({ detail: res.statusText }));
            throw new Error(err.detail || err.message || `HTTP ${res.status}`);
        }
        if (res.status === 204) return null;
        return res.json();
    },
    get(path) { return this.request('GET', path); },
    post(path, body) { return this.request('POST', path, body); },
    put(path, body) { return this.request('PUT', path, body); },
    del(path) { return this.request('DELETE', path); }
};

/* ── App Shell ── */
function appShell() {
    return {
        currentRoute: '/',
        breadcrumbs: ['Dashboard'],
        healthOk: false,
        userRole: localStorage.getItem('user_role') || '{{ roles[0] if roles else "" }}',
        toasts: [],
        confirmDlg: {
            open: false, title: '', message: '', _resolve: null,
            confirm(title, message) {
                this.title = title; this.message = message; this.open = true;
                return new Promise(r => { this._resolve = r; });
            },
            accept() { this.open = false; if (this._resolve) this._resolve(true); },
            cancel() { this.open = false; if (this._resolve) this._resolve(false); }
        },
        formPanel: { open: false, title: '', data: {}, editId: null, saving: false, entityType: '', apiPath: '' },
        // Dashboard data
        dashboardCounts: {},
        dashboardStatusDist: {},
        recentActivity: [],

        async init() {
            // Parse initial route from hash
            this.currentRoute = window.location.hash.slice(1) || '/';
            this.updateBreadcrumbs();

            // Listen for hash changes
            window.addEventListener('hashchange', () => {
                this.currentRoute = window.location.hash.slice(1) || '/';
                this.updateBreadcrumbs();
            });

            // Check health
            try {
                const h = await api.get('/health');
                this.healthOk = h.status === 'ok';
            } catch { this.healthOk = false; }

            // Load dashboard counts
            await this.loadDashboardData();
        },

        navigate(path) {
            window.location.hash = path;
        },

        updateBreadcrumbs() {
            const parts = this.currentRoute.split('/').filter(Boolean);
            if (parts.length === 0) {
                this.breadcrumbs = ['Dashboard'];
            } else {
                this.breadcrumbs = parts.map(p => p.replace(/_/g, ' ').replace(/^\w/, c => c.toUpperCase()));
            }
        },

        hasRole(roles) {
            if (!roles || roles.length === 0) return true;
            return roles.includes(this.userRole);
        },

        showToast(message, type = 'success') {
            const id = Date.now();
            this.toasts.push({ id, message, type });
            setTimeout(() => { this.toasts = this.toasts.filter(t => t.id !== id); }, 4000);
        },

        async loadDashboardData() {
{% for entity in entities %}
            try {
                const data = await api.get('{{ entity.api_base_path }}?page=1&per_page=1');
                const total = data.total || (Array.isArray(data) ? data.length : (data.items || []).length);
                this.dashboardCounts['{{ entity.name_snake }}'] = total;
{% if entity.status_field %}
                // Load status distribution
                try {
                    const all = await api.get('{{ entity.api_base_path }}?per_page=1000');
                    const items = Array.isArray(all) ? all : (all.items || all.data || []);
                    const dist = {};
                    items.forEach(i => {
                        const s = i.{{ entity.status_field }} || 'unknown';
                        dist[s] = (dist[s] || 0) + 1;
                    });
                    this.dashboardStatusDist['{{ entity.name_snake }}'] = dist;
                } catch {}
{% endif %}
            } catch {
                this.dashboardCounts['{{ entity.name_snake }}'] = 0;
            }
{% endfor %}
            // Load recent activity (last 10 across entities)
            const recent = [];
{% for entity in entities %}
            try {
                const data = await api.get('{{ entity.api_base_path }}?per_page=10&sort=-updated_at');
                const items = Array.isArray(data) ? data : (data.items || data.data || []);
                items.slice(0, 3).forEach(i => {
                    recent.push({
                        id: i.id,
                        entity: '{{ entity.name_snake }}',
                        label: i.{{ entity.label_field or 'id' }} || `#${i.id}`,
                        time: i.updated_at ? new Date(i.updated_at).toLocaleString() : '-'
                    });
                });
            } catch {}
{% endfor %}
            recent.sort((a, b) => (b.time || '').localeCompare(a.time || ''));
            this.recentActivity = recent.slice(0, 10);
        },

        // Form helpers
        openCreateForm(entityType, apiPath, title) {
            this.formPanel = { open: true, title: `New ${title}`, data: {}, editId: null, saving: false, entityType, apiPath };
        },
        openEditFormGeneric(entityType, apiPath, item, title) {
            this.formPanel = { open: true, title: `Edit ${title}`, data: { ...item }, editId: item.id, saving: false, entityType, apiPath };
        },
        async saveEntity(entityType, apiPath) {
            this.formPanel.saving = true;
            try {
                if (this.formPanel.editId) {
                    await api.put(`${apiPath}/${this.formPanel.editId}`, this.formPanel.data);
                    this.showToast('Record updated');
                } else {
                    await api.post(apiPath, this.formPanel.data);
                    this.showToast('Record created');
                }
                this.formPanel.open = false;
                window.dispatchEvent(new CustomEvent('entity:refresh', { detail: { entity: entityType } }));
            } catch (e) {
                this.showToast(`Save failed: ${e.message}`, 'error');
            } finally {
                this.formPanel.saving = false;
            }
        },

        async loadRelated(apiPath, foreignKey, id) {
            try {
                const data = await api.get(`${apiPath}?${foreignKey}=${id}`);
                return Array.isArray(data) ? data : (data.items || data.data || []);
            } catch { return []; }
        }
    };
}

/* ── Entity List Controllers ── */
{% for entity in entities %}
function entityList_{{ entity.name_snake }}() {
    return {
        items: [],
        loading: false,
        searchQuery: '',
        sortField: '',
        sortDir: 'asc',
        selectedIds: [],
        pagination: { currentPage: 1, perPage: 25, totalItems: 0, totalPages: 1, startItem: 0, endItem: 0, pages: [1] },

        async init() {
            await this.loadData();
            window.addEventListener('entity:refresh', (e) => {
                if (e.detail.entity === '{{ entity.name_snake }}') this.loadData();
            });
        },

        async loadData() {
            this.loading = true;
            try {
                let url = `{{ entity.api_base_path }}?page=${this.pagination.currentPage}&per_page=${this.pagination.perPage}`;
                if (this.searchQuery) url += `&search=${encodeURIComponent(this.searchQuery)}`;
                if (this.sortField) url += `&sort=${this.sortDir === 'desc' ? '-' : ''}${this.sortField}`;
                const data = await api.get(url);
                if (Array.isArray(data)) {
                    this.items = data;
                    this.pagination.totalItems = data.length;
                } else {
                    this.items = data.items || data.data || [];
                    this.pagination.totalItems = data.total || this.items.length;
                }
                this.pagination.totalPages = Math.max(1, Math.ceil(this.pagination.totalItems / this.pagination.perPage));
                this.pagination.startItem = this.pagination.totalItems === 0 ? 0 : (this.pagination.currentPage - 1) * this.pagination.perPage + 1;
                this.pagination.endItem = Math.min(this.pagination.currentPage * this.pagination.perPage, this.pagination.totalItems);
                this.updatePageNumbers();
            } catch (e) {
                this.items = [];
            } finally {
                this.loading = false;
            }
        },

        updatePageNumbers() {
            const pages = [];
            const t = this.pagination.totalPages, c = this.pagination.currentPage;
            let s = Math.max(1, c - 2), e = Math.min(t, c + 2);
            if (s > 1) pages.push(1);
            if (s > 2) pages.push('...');
            for (let i = s; i <= e; i++) pages.push(i);
            if (e < t - 1) pages.push('...');
            if (e < t) pages.push(t);
            this.pagination.pages = pages;
        },

        toggleSort(field) {
            if (this.sortField === field) {
                this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc';
            } else {
                this.sortField = field;
                this.sortDir = 'asc';
            }
            this.loadData();
        },

        search() {
            this.pagination.currentPage = 1;
            this.loadData();
        },

        goToPage(page) {
            if (typeof page === 'number' && page >= 1 && page <= this.pagination.totalPages) {
                this.pagination.currentPage = page;
                this.loadData();
            }
        },

        toggleSelectAll(event) {
            this.selectedIds = event.target.checked ? this.items.map(i => i.id) : [];
        },

        navigate(path) { window.location.hash = path; },

        openCreateForm() {
            const shell = Alpine.$data(document.querySelector('[x-data="appShell()"]'));
            if (shell) shell.openCreateForm('{{ entity.name_snake }}', '{{ entity.api_base_path }}', '{{ entity.name_display }}');
        },

        openEditForm(item) {
            const shell = Alpine.$data(document.querySelector('[x-data="appShell()"]'));
            if (shell) shell.openEditFormGeneric('{{ entity.name_snake }}', '{{ entity.api_base_path }}', item, '{{ entity.name_display }}');
        },

        async confirmDeleteItem(id) {
            const shell = Alpine.$data(document.querySelector('[x-data="appShell()"]'));
            if (!shell) return;
            const ok = await shell.confirmDlg.confirm('Delete {{ entity.name_display }}', 'Are you sure? This cannot be undone.');
            if (ok) {
                try {
                    await api.del(`{{ entity.api_base_path }}/${id}`);
                    shell.showToast('Record deleted');
                    this.loadData();
                } catch (e) {
                    shell.showToast(`Delete failed: ${e.message}`, 'error');
                }
            }
        },

        async bulkDelete() {
            const shell = Alpine.$data(document.querySelector('[x-data="appShell()"]'));
            if (!shell) return;
            const ok = await shell.confirmDlg.confirm('Delete Selected', `Delete ${this.selectedIds.length} records?`);
            if (ok) {
                for (const id of this.selectedIds) {
                    try { await api.del(`{{ entity.api_base_path }}/${id}`); } catch {}
                }
                this.selectedIds = [];
                shell.showToast('Records deleted');
                this.loadData();
            }
        }
    };
}
{% endfor %}

