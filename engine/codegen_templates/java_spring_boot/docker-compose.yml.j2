# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE

version: "3.9"

services:
  app:
    build:
      context: .
      target: runtime
    image: {{ solution_name | lower | replace(' ', '-') | replace('_', '-') }}:latest
    container_name: {{ solution_name | lower | replace(' ', '-') | replace('_', '-') }}-app
    ports:
      - "${SERVER_PORT:-8080}:8080"
    environment:
      SPRING_PROFILES_ACTIVE: prod
      DATABASE_URL: jdbc:postgresql://postgres:5432/${POSTGRES_DB:-{{ solution_name | lower | replace(' ', '_') | replace('-', '_') }}}
      DATABASE_USER: ${POSTGRES_USER:-app}
      DATABASE_PASSWORD: ${POSTGRES_PASSWORD}
      SERVER_PORT: 8080
{% if identity_provider and identity_provider.get('jwks_uri') %}
      OIDC_JWKS_URI: ${OIDC_JWKS_URI:-{{ identity_provider.get('jwks_uri', '') }}}
      OIDC_ISSUER: ${OIDC_ISSUER:-{{ identity_provider.get('issuer_url', '') }}}
{% else %}
      OIDC_ISSUER: ${OIDC_ISSUER:-}
{% endif %}
    depends_on:
      postgres:
        condition: service_healthy
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:8080/actuator/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

  postgres:
    image: postgres:16-alpine
    container_name: {{ solution_name | lower | replace(' ', '-') | replace('_', '-') }}-db
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-{{ solution_name | lower | replace(' ', '_') | replace('-', '_') }}}
      POSTGRES_USER: ${POSTGRES_USER:-app}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./src/main/resources/db/init:/docker-entrypoint-initdb.d:ro
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-app} -d ${POSTGRES_DB:-{{ solution_name | lower | replace(' ', '_') | replace('-', '_') }}}"]
      interval: 10s
      timeout: 5s
      retries: 5
{% if has_kafka | default(false) %}

  kafka:
    image: confluentinc/cp-kafka:7.6.0
    container_name: {{ solution_name | lower | replace(' ', '-') | replace('_', '-') }}-kafka
    ports:
      - "9092:9092"
    environment:
      KAFKA_NODE_ID: 1
      KAFKA_PROCESS_ROLES: broker,controller
      KAFKA_LISTENERS: PLAINTEXT://:9092,CONTROLLER://:9093
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://localhost:9092
      KAFKA_CONTROLLER_LISTENER_NAMES: CONTROLLER
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
      KAFKA_CONTROLLER_QUORUM_VOTERS: 1@localhost:9093
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      CLUSTER_ID: archie-generated-cluster
    volumes:
      - kafka_data:/var/lib/kafka/data
    restart: unless-stopped
{% endif %}

volumes:
  postgres_data:
    driver: local
{% if has_kafka | default(false) %}
  kafka_data:
    driver: local
{% endif %}
