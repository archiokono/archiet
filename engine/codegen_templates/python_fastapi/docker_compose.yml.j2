# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
#
# 1. cp .env.example .env  (then fill in real secrets)
# 2. docker-compose up --build
{% set db_name = solution_name | lower | replace(' ', '_') | replace('-', '_') %}
services:

  # ── PostgreSQL database ────────────────────────────────────────────────────
  db:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-{{ db_name }}}
      POSTGRES_USER: ${POSTGRES_USER:-app}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:?Set POSTGRES_PASSWORD in .env}
    volumes:
      - db_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-app} -d ${POSTGRES_DB:-{{ db_name }}}"]
      interval: 5s
      timeout: 3s
      retries: 10

  # ── FastAPI backend ────────────────────────────────────────────────────────
  api:
    build:
      context: .
      target: run
    ports:
      - "${API_PORT:-8000}:8000"
    environment:
      ENV: ${ENV:-development}
      DATABASE_URL: postgresql+asyncpg://${POSTGRES_USER:-app}:${POSTGRES_PASSWORD:-changeme}@db/${POSTGRES_DB:-{{ db_name }}}
      JWT_SECRET: ${JWT_SECRET:-dev-secret-change-in-production}
      JWT_ALGORITHM: ${JWT_ALGORITHM:-HS256}
    depends_on:
      db:
        condition: service_healthy
    restart: unless-stopped

  # ── Next.js frontend (shadcn/ui) ──────────────────────────────────────────
  frontend:
    build:
      context: ./frontend
      args:
        BACKEND_URL: http://api:8000
    ports:
      - "${FRONTEND_PORT:-3000}:3000"
    environment:
      BACKEND_URL: http://api:8000
      NODE_ENV: production
    depends_on:
      - api
    restart: unless-stopped

{% if identity_provider is defined and identity_provider.type == "keycloak" %}
  # ── Keycloak (OIDC identity provider) ──────────────────────────────────────
  keycloak:
    image: quay.io/keycloak/keycloak:24.0
    command: start-dev --import-realm
    environment:
      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: ${KEYCLOAK_ADMIN_PASSWORD:-admin}
      KC_DB: postgres
      KC_DB_URL: jdbc:postgresql://db/${POSTGRES_DB:-{{ db_name }}}_keycloak
      KC_DB_USERNAME: ${POSTGRES_USER:-app}
      KC_DB_PASSWORD: ${POSTGRES_PASSWORD:?Set POSTGRES_PASSWORD in .env}
      KC_HOSTNAME_STRICT: "false"
      KC_HTTP_ENABLED: "true"
    ports:
      - "${KEYCLOAK_PORT:-8080}:8080"
    volumes:
      - ./infrastructure/keycloak/realm-import.json:/opt/keycloak/data/import/realm.json:ro
    depends_on:
      db:
        condition: service_healthy
    restart: unless-stopped
{% endif %}

volumes:
  db_data:
