{# salesforce_apex/custom_object.xml.j2 #}
{# Generates Salesforce Custom Object metadata XML from confirmed architecture fields. #}
{# Context: solution_id, bundle_id, model_name, model_def (with fields, enums, description) #}
{# ArchiMate source: DataObject → Custom Object #}
<?xml version="1.0" encoding="UTF-8"?>
<!-- GENERATED BY ARCHIE — solution_id: {{ solution_id }}, bundle_id: {{ bundle_id }} -->
<!-- x-archimate-source: {{ model_def.archimate_source_id | default('N/A') }} -->
<!-- DO NOT EDIT IN PLACE — REGENERATE FROM ARCHITECTURE -->
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>{{ model_name }}</label>
    <pluralLabel>{{ model_name }}s</pluralLabel>
    <description>{{ model_def.description | default(model_name + ' custom object generated from ArchiMate architecture.') }}</description>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <nameField>
        <label>{{ model_name }} Name</label>
        <type>AutoNumber</type>
        <displayFormat>{{ model_name[:3] | upper }}-{0000}</displayFormat>
    </nameField>

    {% for field in model_def.fields %}
    {% if not field.primary_key and field.name not in ('id', 'created_at', 'updated_at') %}
    <fields>
        <fullName>{{ field.name }}__c</fullName>
        <label>{{ field.name | replace('_', ' ') | title }}</label>
        <description>{{ field.description | default('') }}</description>
        {% if field.type == 'enum' and field.enum_values %}
        <type>Picklist</type>
        <required>{{ field.required | default(false) | lower }}</required>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                {% for val in field.enum_values %}
                <value>
                    <fullName>{{ val }}</fullName>
                    <default>{{ 'true' if loop.first and field.required else 'false' }}</default>
                    <label>{{ val | replace('_', ' ') | title }}</label>
                </value>
                {% endfor %}
            </valueSetDefinition>
        </valueSet>
        {% elif field.type in ('number', 'decimal', 'integer', 'int') and field.format == 'currency' %}
        <type>Currency</type>
        <precision>18</precision>
        <scale>2</scale>
        <required>{{ field.required | default(false) | lower }}</required>
        {% elif field.type in ('number', 'decimal') %}
        <type>Number</type>
        <precision>18</precision>
        <scale>{{ field.scale | default(2) }}</scale>
        <required>{{ field.required | default(false) | lower }}</required>
        {% elif field.type in ('integer', 'int') %}
        <type>Number</type>
        <precision>18</precision>
        <scale>0</scale>
        <required>{{ field.required | default(false) | lower }}</required>
        {% elif field.type == 'boolean' %}
        <type>Checkbox</type>
        <defaultValue>{{ field.default | default('false') | lower }}</defaultValue>
        {% elif field.type in ('timestamp', 'datetime') or field.format == 'date-time' %}
        <type>DateTime</type>
        <required>{{ field.required | default(false) | lower }}</required>
        {% elif field.type == 'date' or field.format == 'date' %}
        <type>Date</type>
        <required>{{ field.required | default(false) | lower }}</required>
        {% elif field.type == 'url' or field.format == 'uri' %}
        <type>Url</type>
        <required>{{ field.required | default(false) | lower }}</required>
        {% elif field.type == 'email' or field.format == 'email' %}
        <type>Email</type>
        <required>{{ field.required | default(false) | lower }}</required>
        {% elif field.type == 'phone' %}
        <type>Phone</type>
        <required>{{ field.required | default(false) | lower }}</required>
        {% elif field.type == 'textarea' or (field.type == 'string' and (field.max_length or 0) > 255) %}
        <type>LongTextArea</type>
        <length>{{ field.max_length or 32768 }}</length>
        <visibleLines>5</visibleLines>
        <required>{{ field.required | default(false) | lower }}</required>
        {% elif field.foreign_key %}
        <type>Lookup</type>
        <referenceTo>{{ field.foreign_key.split('.')[0] }}__c</referenceTo>
        <relationshipLabel>{{ model_name }}s</relationshipLabel>
        <relationshipName>{{ model_name }}s</relationshipName>
        <required>{{ field.required | default(false) | lower }}</required>
        {% else %}
        <type>Text</type>
        <length>{{ field.max_length | default(255) }}</length>
        <required>{{ field.required | default(false) | lower }}</required>
        {% if field.unique | default(false) %}
        <unique>true</unique>
        <externalId>true</externalId>
        {% endif %}
        {% endif %}
    </fields>
    {% endif %}
    {% endfor %}
</CustomObject>
