{# app/modules/solutions_product/templates/python_fastapi/k8s_deployment.yaml.j2 #}
{# Generates Kubernetes Deployment + Service + HPA manifests from confirmed deployment specs. #}
{# Context: solution_id, bundle_id, deployments (dict of service_name -> deploy config with scaling/cache/messaging) #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE
{% for service_name, deploy in deployments.items() %}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
  labels:
    app: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
    archie-solution: "{{ solution_id }}"
spec:
  replicas: {{ deploy.scaling.min_replicas | default(1) }}
  selector:
    matchLabels:
      app: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
  template:
    metadata:
      labels:
        app: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
    spec:
      securityContext:
        runAsNonRoot: true
        runAsUser: 1000
        fsGroup: 1000
      containers:
        - name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
          image: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}:latest
          ports:
            - containerPort: 8000
          env:
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}-secrets
                  key: database-url
            {% if deploy.cache and deploy.cache != 'none' %}
            - name: CACHE_URL
              valueFrom:
                secretKeyRef:
                  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}-secrets
                  key: cache-url
            {% endif %}
            {% if deploy.messaging and deploy.messaging != 'none' %}
            - name: MESSAGING_URL
              valueFrom:
                secretKeyRef:
                  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}-secrets
                  key: messaging-url
            {% endif %}
          resources:
            requests:
              cpu: "100m"
              memory: "256Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
          readinessProbe:
            httpGet:
              path: /health
              port: 8000
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /health
              port: 8000
            initialDelaySeconds: 15
            periodSeconds: 20
---
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}-hpa
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
  minReplicas: {{ deploy.scaling.min_replicas | default(1) }}
  maxReplicas: {{ deploy.scaling.max_replicas | default(3) }}
  metrics:
    - type: Resource
      resource:
        name: {{ deploy.scaling.metric | default('cpu') }}
        target:
          type: Utilization
          averageUtilization: {{ deploy.scaling.threshold | default(80) }}
---
apiVersion: v1
kind: Service
metadata:
  name: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
spec:
  selector:
    app: {{ service_name | lower | replace(' ', '-') | replace('_', '-') }}
  ports:
    - port: 80
      targetPort: 8000
  type: ClusterIP
{% endfor %}
