{# app/modules/solutions_product/templates/python_fastapi/sam_template.yml.j2 #}
{# AWS SAM template with API Gateway, Lambda, and database config. #}
{# Context: solution_id, bundle_id, solution_name, services, deployment (optional) #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE

AWSTemplateFormatVersion: '2010-09-09'
Transform: AWS::Serverless-2016-10-31
Description: >-
  {{ solution_name }} — serverless deployment via AWS SAM.
  Generated by ARCHIE code generator.

Globals:
  Function:
    Timeout: 30
    MemorySize: 256
    Runtime: python3.11
    Architectures:
      - x86_64
    Environment:
      Variables:
        LOG_LEVEL: INFO
        POWERTOOLS_SERVICE_NAME: {{ solution_name | lower | replace(' ', '-') }}
{% if deployment and deployment.database is defined %}
        DATABASE_URL: !Sub >-
          postgresql://${DatabaseUser}:${DatabasePassword}@${Database.Endpoint.Address}:${Database.Endpoint.Port}/${DatabaseName}
{% endif %}

Parameters:
  Stage:
    Type: String
    Default: dev
    AllowedValues:
      - dev
      - staging
      - prod
{% if deployment and deployment.database is defined %}
  DatabaseUser:
    Type: String
    Default: appuser
    NoEcho: true
  DatabasePassword:
    Type: String
    NoEcho: true
  DatabaseName:
    Type: String
    Default: {{ solution_name | lower | replace(' ', '_') | replace('-', '_') }}
{% endif %}

Resources:
  # ── API Gateway ──
  ApiGateway:
    Type: AWS::Serverless::HttpApi
    Properties:
      StageName: !Ref Stage
      CorsConfiguration:
        AllowOrigins:
          - "*"
        AllowMethods:
          - GET
          - POST
          - PUT
          - DELETE
          - PATCH
          - OPTIONS
        AllowHeaders:
          - Content-Type
          - Authorization
          - X-Request-ID

  # ── Lambda Function ──
  AppFunction:
    Type: AWS::Serverless::Function
    Properties:
      FunctionName: !Sub {{ solution_name | lower | replace(' ', '-') }}-${Stage}
      Handler: lambda_handler.lambda_handler
      CodeUri: .
      Description: {{ solution_name }} API
      Events:
        Api:
          Type: HttpApi
          Properties:
            ApiId: !Ref ApiGateway
            Path: /{proxy+}
            Method: ANY
        RootApi:
          Type: HttpApi
          Properties:
            ApiId: !Ref ApiGateway
            Path: /
            Method: ANY
      Policies:
        - AWSLambdaBasicExecutionRole
{% if deployment and deployment.database is defined %}
        - VPCAccessPolicy: {}
      VpcConfig:
        SecurityGroupIds:
          - !Ref LambdaSecurityGroup
        SubnetIds:
          - !Ref PrivateSubnet1
          - !Ref PrivateSubnet2
{% endif %}

  # ── Warmup Rule (prevent cold starts) ──
  WarmupRule:
    Type: AWS::Events::Rule
    Properties:
      ScheduleExpression: rate(5 minutes)
      State: ENABLED
      Targets:
        - Arn: !GetAtt AppFunction.Arn
          Id: warmup
          Input: '{"source": "aws.events", "detail-type": "Scheduled Event"}'

  WarmupPermission:
    Type: AWS::Lambda::Permission
    Properties:
      FunctionName: !Ref AppFunction
      Action: lambda:InvokeFunction
      Principal: events.amazonaws.com
      SourceArn: !GetAtt WarmupRule.Arn

{% if deployment and deployment.database is defined %}
  # ── RDS (PostgreSQL) ──
  Database:
    Type: AWS::RDS::DBInstance
    Properties:
      DBInstanceIdentifier: !Sub {{ solution_name | lower | replace(' ', '-') }}-${Stage}
      DBInstanceClass: {{ deployment.instance_class | default('db.t3.micro') }}
      Engine: postgres
      EngineVersion: "{{ deployment.version | default('16') }}"
      MasterUsername: !Ref DatabaseUser
      MasterUserPassword: !Ref DatabasePassword
      DBName: !Ref DatabaseName
      AllocatedStorage: {{ deployment.storage_gb | default(20) }}
      MaxAllocatedStorage: {{ deployment.max_storage_gb | default(100) }}
      MultiAZ: {{ 'true' if deployment.multi_az | default(false) else 'false' }}
      StorageEncrypted: {{ 'true' if deployment.encryption | default(true) else 'false' }}
      BackupRetentionPeriod: {{ deployment.backup_days | default(7) }}
      VPCSecurityGroups:
        - !Ref DatabaseSecurityGroup
      DBSubnetGroupName: !Ref DatabaseSubnetGroup
      DeletionPolicy: Snapshot

  DatabaseSubnetGroup:
    Type: AWS::RDS::DBSubnetGroup
    Properties:
      DBSubnetGroupDescription: Subnets for {{ solution_name }}
      SubnetIds:
        - !Ref PrivateSubnet1
        - !Ref PrivateSubnet2
{% endif %}

Outputs:
  ApiUrl:
    Description: API Gateway endpoint URL
    Value: !Sub https://${ApiGateway}.execute-api.${AWS::Region}.amazonaws.com/${Stage}
  FunctionArn:
    Description: Lambda function ARN
    Value: !GetAtt AppFunction.Arn
{% if deployment and deployment.database is defined %}
  DatabaseEndpoint:
    Description: RDS endpoint
    Value: !GetAtt Database.Endpoint.Address
{% endif %}
