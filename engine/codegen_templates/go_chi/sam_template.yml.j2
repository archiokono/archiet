{# app/modules/solutions_product/templates/go_chi/sam_template.yml.j2 #}
{# AWS SAM template for Go Lambda functions. #}
{# Context: solution_id, bundle_id, solution_name, deployment (optional) #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE

AWSTemplateFormatVersion: '2010-09-09'
Transform: AWS::Serverless-2016-10-31
Description: >-
  {{ solution_name }} — Go serverless deployment via AWS SAM.
  Generated by ARCHIE code generator.

Globals:
  Function:
    Timeout: 10
    MemorySize: 128
    Architectures:
      - x86_64
    Environment:
      Variables:
        LOG_LEVEL: INFO
{% if deployment and deployment.database is defined %}
        DATABASE_URL: !Sub >-
          postgresql://${DatabaseUser}:${DatabasePassword}@${Database.Endpoint.Address}:${Database.Endpoint.Port}/${DatabaseName}
{% endif %}

Parameters:
  Stage:
    Type: String
    Default: dev
    AllowedValues:
      - dev
      - staging
      - prod
{% if deployment and deployment.database is defined %}
  DatabaseUser:
    Type: String
    Default: appuser
    NoEcho: true
  DatabasePassword:
    Type: String
    NoEcho: true
  DatabaseName:
    Type: String
    Default: {{ solution_name | lower | replace(' ', '_') | replace('-', '_') }}
{% endif %}

Resources:
  # ── API Gateway ──
  ApiGateway:
    Type: AWS::Serverless::HttpApi
    Properties:
      StageName: !Ref Stage
      CorsConfiguration:
        AllowOrigins:
          - "*"
        AllowMethods:
          - GET
          - POST
          - PUT
          - DELETE
          - PATCH
          - OPTIONS
        AllowHeaders:
          - Content-Type
          - Authorization
          - X-Request-ID

  # ── Lambda Function ──
  AppFunction:
    Type: AWS::Serverless::Function
    Metadata:
      BuildMethod: go1.x
    Properties:
      FunctionName: !Sub {{ solution_name | lower | replace(' ', '-') }}-${Stage}
      Handler: bootstrap
      Runtime: provided.al2023
      CodeUri: .
      Description: {{ solution_name }} Go API
      Events:
        Api:
          Type: HttpApi
          Properties:
            ApiId: !Ref ApiGateway
            Path: /{proxy+}
            Method: ANY
        RootApi:
          Type: HttpApi
          Properties:
            ApiId: !Ref ApiGateway
            Path: /
            Method: ANY

  # ── Warmup Rule ──
  WarmupRule:
    Type: AWS::Events::Rule
    Properties:
      ScheduleExpression: rate(5 minutes)
      State: ENABLED
      Targets:
        - Arn: !GetAtt AppFunction.Arn
          Id: warmup

  WarmupPermission:
    Type: AWS::Lambda::Permission
    Properties:
      FunctionName: !Ref AppFunction
      Action: lambda:InvokeFunction
      Principal: events.amazonaws.com
      SourceArn: !GetAtt WarmupRule.Arn

Outputs:
  ApiUrl:
    Description: API Gateway endpoint URL
    Value: !Sub https://${ApiGateway}.execute-api.${AWS::Region}.amazonaws.com/${Stage}
  FunctionArn:
    Description: Lambda function ARN
    Value: !GetAtt AppFunction.Arn
