import * as Notifications from "expo-notifications"
import * as Device from "expo-device"
import { Platform } from "react-native"
import { router } from "expo-router"
import Constants from "expo-constants"

// ── Notification channels ──

export const NOTIFICATION_CHANNELS = {
{% if push_channels %}
{% for ch in push_channels %}
  "{{ ch.id }}": {
    title: "{{ ch.title }}",
    trigger: "{{ ch.trigger }}",
{% if ch.body_template %}
    bodyTemplate: "{{ ch.body_template }}",
{% endif %}
  },
{% endfor %}
{% endif %}
} as const

export type NotificationChannel = keyof typeof NOTIFICATION_CHANNELS

// ── Configuration ──

// Set how notifications appear when app is in foreground
Notifications.setNotificationHandler({
  handleNotification: async () => ({
    shouldShowAlert: true,
    shouldPlaySound: true,
    shouldSetBadge: true,
  }),
})

// ── Registration ──

export async function registerForPushNotifications(): Promise<string | null> {
  if (!Device.isDevice) {
    console.log("Push notifications require a physical device")
    return null
  }

  // Check/request permission
  const { status: existing } = await Notifications.getPermissionsAsync()
  let finalStatus = existing
  if (existing !== "granted") {
    const { status } = await Notifications.requestPermissionsAsync()
    finalStatus = status
  }
  if (finalStatus !== "granted") {
    console.log("Push notification permission denied")
    return null
  }

  // Get Expo push token (works with FCM on Android, APNS on iOS)
  const projectId = Constants.expoConfig?.extra?.eas?.projectId
  const tokenData = await Notifications.getExpoPushTokenAsync({
    projectId: projectId ?? undefined,
  })

  // Android: create notification channel
  if (Platform.OS === "android") {
    await Notifications.setNotificationChannelAsync("default", {
      name: "{{ solution_name }} Notifications",
      importance: Notifications.AndroidImportance.MAX,
      vibrationPattern: [0, 250, 250, 250],
    })
  }

  return tokenData.data
}

/**
 * Register the device token with the backend.
 * Call after login when you have an auth token.
 */
export async function registerDeviceToken(
  pushToken: string,
  authToken: string,
  baseUrl: string,
): Promise<void> {
  try {
    await fetch(`${baseUrl}/api/devices/register`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${authToken}`,
      },
      body: JSON.stringify({
        push_token: pushToken,
        platform: Platform.OS,
        device_name: Device.deviceName ?? "Unknown",
      }),
    })
  } catch (err) {
    console.error("Failed to register device token:", err)
  }
}

// ── Notification handlers ──

/**
 * Handle notification tap — navigate to the relevant screen.
 * Data payload should include: { type: "channel_id", entity_id: "..." }
 */
export function setupNotificationResponseHandler(): Notifications.Subscription {
  return Notifications.addNotificationResponseReceivedListener((response) => {
    const data = response.notification.request.content.data as {
      type?: string
      entity_id?: string
      screen?: string
    }

    if (data.screen) {
      // Direct screen navigation
      router.push(data.screen as any)
    } else if (data.type && data.entity_id) {
      // Navigate to entity detail based on notification type
      const route = `/${data.type}/${data.entity_id}`
      router.push(route as any)
    }
  })
}

/**
 * Handle foreground notifications — called while app is open.
 */
export function setupForegroundHandler(): Notifications.Subscription {
  return Notifications.addNotificationReceivedListener((notification) => {
    const data = notification.request.content.data
    console.log("Foreground notification:", data)
  })
}

