def _compute_signature(payload_bytes: bytes, secret: str) -> str:
    """HMAC-SHA256 signature for webhook payload verification."""
    return hmac.new(secret.encode(), payload_bytes, hashlib.sha256).hexdigest()


async def deliver_webhook(
    db: AsyncSession,
    event_name: str,
    payload: dict,
{% if multi_tenancy is defined and multi_tenancy %}
    organization_id: str | None = None,
{% endif %}
) -> int:
    """Deliver a webhook event to all matching subscriptions.

    Returns the number of successful deliveries.
    """
    import httpx

    query = select(WebhookSubscription).where(WebhookSubscription.is_active == True)
{% if multi_tenancy is defined and multi_tenancy %}
    if organization_id:
        query = query.where(WebhookSubscription.organization_id == organization_id)
{% endif %}
    result = await db.execute(query)
    subscriptions = result.scalars().all()

    delivered = 0
    for sub in subscriptions:
        # Check event match
        sub_events = sub.events or []
        if not _event_matches(event_name, sub_events):
            continue

        success = await _deliver_with_retry(db, sub, event_name, payload)
        if success:
            delivered += 1

    return delivered


async def _deliver_with_retry(
    db: AsyncSession,
    sub: WebhookSubscription,
    event_name: str,
    payload: dict,
) -> bool:
    """Attempt delivery with exponential backoff retry."""
    import httpx

    delivery = WebhookDelivery(
        subscription_id=sub.id,
        event_type=event_name,
        payload=payload,
        status="pending",
    )
    db.add(delivery)
    await db.flush()

    body = json.dumps(payload, default=str).encode()
    signature = _compute_signature(body, sub.secret)
    headers = {
        "Content-Type": "application/json",
        "X-Webhook-Event": event_name,
        "X-Webhook-Signature": f"sha256={signature}",
        "X-Webhook-Delivery-Id": delivery.id,
    }

    for attempt in range(1, MAX_RETRY_ATTEMPTS + 1):
        delivery.attempts = attempt
        start = time.monotonic()
        try:
            async with httpx.AsyncClient(timeout=10.0) as client:
                resp = await client.post(sub.url, content=body, headers=headers)
            elapsed_ms = int((time.monotonic() - start) * 1000)
            delivery.duration_ms = elapsed_ms
            delivery.response_code = resp.status_code

            if 200 <= resp.status_code < 300:
                delivery.status = "delivered"
                sub.last_delivery_at = datetime.now(timezone.utc)
                sub.failure_count = 0
                await db.commit()
                return True
            else:
                delivery.error_message = f"HTTP {resp.status_code}"
        except Exception as exc:
            elapsed_ms = int((time.monotonic() - start) * 1000)
            delivery.duration_ms = elapsed_ms
            delivery.error_message = str(exc)[:500]

        if attempt < MAX_RETRY_ATTEMPTS:
{% if webhook_retry_backoff == 'linear' %}
            delay = 5 * attempt
{% else %}
            delay = 2 ** attempt  # exponential: 2s, 4s, 8s
{% endif %}
            logger.warning("Webhook %s attempt %d/%d failed, retrying in %ds", sub.id, attempt, MAX_RETRY_ATTEMPTS, delay)
            await asyncio.sleep(delay)

    delivery.status = "failed"
    sub.failure_count = (sub.failure_count or 0) + 1
    await db.commit()
    logger.error("Webhook %s permanently failed after %d attempts", sub.id, MAX_RETRY_ATTEMPTS)
    return False


def _event_matches(event_type: str, subscribed_events: list[str]) -> bool:
    """Check if event matches subscription (supports wildcards)."""
    for pattern in subscribed_events:
        if pattern == event_type or pattern == "*":
            return True
        if "*" in pattern:
            prefix, _, suffix = pattern.partition("*")
            if event_type.startswith(prefix) and event_type.endswith(suffix):
                return True
    return False


