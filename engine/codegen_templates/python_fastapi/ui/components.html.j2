/* ── Status Badge ── */
const STATUS_COLORS = {
{% for status, color in status_colors.items() %}
    '{{ status }}': '{{ color }}',
{% endfor %}
    '_default': 'zinc'
};

function statusBadgeClass(value) {
    if (!value) return 'bg-zinc-500/10 text-zinc-400 border-zinc-500/30';
    const key = String(value).toLowerCase().replace(/[\s_-]+/g, '_');
    const color = STATUS_COLORS[key] || STATUS_COLORS['_default'];
    return `bg-${color}-500/10 text-${color}-400 border-${color}-500/30`;
}

/* ── Pagination ── */
function paginationComponent(totalItems, perPage) {
    return {
        currentPage: 1,
        perPage: perPage || 25,
        totalItems: totalItems || 0,
        get totalPages() { return Math.max(1, Math.ceil(this.totalItems / this.perPage)); },
        get startItem() { return this.totalItems === 0 ? 0 : (this.currentPage - 1) * this.perPage + 1; },
        get endItem() { return Math.min(this.currentPage * this.perPage, this.totalItems); },
        get pages() {
            const pages = [];
            const total = this.totalPages;
            const current = this.currentPage;
            let start = Math.max(1, current - 2);
            let end = Math.min(total, current + 2);
            if (start > 1) pages.push(1);
            if (start > 2) pages.push('...');
            for (let i = start; i <= end; i++) pages.push(i);
            if (end < total - 1) pages.push('...');
            if (end < total) pages.push(total);
            return pages;
        },
        goTo(page) {
            if (typeof page === 'number' && page >= 1 && page <= this.totalPages) {
                this.currentPage = page;
            }
        },
        prev() { if (this.currentPage > 1) this.currentPage--; },
        next() { if (this.currentPage < this.totalPages) this.currentPage++; }
    };
}

/* ── Debounced Search ── */
function debouncedSearch(callback, delay = 300) {
    let timer = null;
    return function(value) {
        clearTimeout(timer);
        timer = setTimeout(() => callback(value), delay);
    };
}

/* ── API Client ── */
const api = {
    baseUrl: '',
    token: localStorage.getItem('auth_token') || '',

    async request(method, path, body = null) {
        const headers = { 'Content-Type': 'application/json' };
        if (this.token) headers['Authorization'] = `Bearer ${this.token}`;
        const opts = { method, headers };
        if (body && method !== 'GET') opts.body = JSON.stringify(body);
        const res = await fetch(`${this.baseUrl}${path}`, opts);
        if (res.status === 401) {
            window.dispatchEvent(new CustomEvent('auth:expired'));
            throw new Error('Authentication expired');
        }
        if (!res.ok) {
            const err = await res.json().catch(() => ({ detail: res.statusText }));
            throw new Error(err.detail || err.message || res.statusText);
        }
        if (res.status === 204) return null;
        return res.json();
    },

    get(path) { return this.request('GET', path); },
    post(path, body) { return this.request('POST', path, body); },
    put(path, body) { return this.request('PUT', path, body); },
    patch(path, body) { return this.request('PATCH', path, body); },
    del(path) { return this.request('DELETE', path); }
};
