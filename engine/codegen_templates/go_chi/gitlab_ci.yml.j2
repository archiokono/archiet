{# app/modules/solutions_product/templates/go_chi/gitlab_ci.yml.j2 #}
{# GitLab CI/CD pipeline for Go/Chi microservices. #}
{# Context: solution_id, bundle_id, solution_name, ci_cd (dict with provider config) #}
# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
# DO NOT EDIT IN PLACE -- REGENERATE FROM ARCHITECTURE
{% set svc_name = solution_name | lower | replace(' ', '-') | replace('_', '-') %}
{% set registry = ci_cd.container_registry | default('ghcr') %}
{% set staging_ns = ci_cd.k8s_staging_namespace | default('staging') %}
{% set prod_ns = ci_cd.k8s_prod_namespace | default('production') %}
{% set manual_approval = ci_cd.require_manual_approval | default(true) %}
{% set security_scan = ci_cd.run_security_scan | default(true) %}
{% set compliance_url = ci_cd.compliance_check_url | default('') %}

stages:
  - build-lint
  - test
{% if security_scan %}
  - security-scan
{% endif %}
  - push-image
  - deploy-staging
  - deploy-production

variables:
  IMAGE_NAME: {{ svc_name }}
{% if registry == 'ghcr' %}
  REGISTRY: ghcr.io/${GITHUB_OWNER}
{% elif registry == 'ecr' %}
  REGISTRY: ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
{% elif registry == 'gcr' %}
  REGISTRY: gcr.io/${GCP_PROJECT_ID}
{% elif registry == 'acr' %}
  REGISTRY: ${ACR_REGISTRY}.azurecr.io
{% endif %}
  GOPATH: "$CI_PROJECT_DIR/.go"

cache:
  paths:
    - .go/pkg/mod

# ── Stage 1: Build & Lint ──
build-lint:
  stage: build-lint
  image: golang:1.22
  script:
    - go mod download
    - go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest
    - golangci-lint run ./...

# ── Stage 2: Test ──
test:
  stage: test
  image: golang:1.22
  services:
    - name: postgres:16
      alias: postgres
      variables:
        POSTGRES_USER: test
        POSTGRES_PASSWORD: test
        POSTGRES_DB: test_db
  variables:
    DATABASE_URL: postgresql://test:test@postgres:5432/test_db  # secrets-safety-ok
  script:
    - go mod download
    - go run migration.go
    - go test -v -coverprofile=coverage.out -count=1 ./...
    - go test -v -run TestContract ./...
  artifacts:
    paths:
      - coverage.out
{% if security_scan %}

# ── Stage 3: Security Scan ──
security-scan:
  stage: security-scan
  image: docker:latest
  services:
    - docker:dind
  variables:
    DOCKER_TLS_CERTDIR: ""
  script:
    - docker build -t ${IMAGE_NAME}:scan .
    - |
      apk add --no-cache curl
      curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin
    - trivy image --exit-code 1 --severity CRITICAL,HIGH --ignore-unfixed ${IMAGE_NAME}:scan
    - |
      apk add --no-cache go
      go install golang.org/x/vuln/cmd/govulncheck@latest
      govulncheck ./...
  allow_failure: false
{% endif %}

# ── Stage 4: Push Image ──
push-image:
  stage: push-image
  image: docker:latest
  services:
    - docker:dind
  variables:
    DOCKER_TLS_CERTDIR: ""
  only:
    - main
  script:
{% if registry == 'ghcr' %}
    - echo "${REGISTRY_TOKEN}" | docker login ghcr.io -u "${GITHUB_OWNER}" --password-stdin
{% elif registry == 'ecr' %}
    - apk add --no-cache aws-cli
    - aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${REGISTRY}
{% elif registry == 'gcr' %}
    - echo "${GCP_SA_KEY}" | docker login -u _json_key --password-stdin https://gcr.io
{% elif registry == 'acr' %}
    - echo "${ACR_PASSWORD}" | docker login ${REGISTRY} -u "${ACR_USERNAME}" --password-stdin
{% endif %}
    - docker build -t ${REGISTRY}/${IMAGE_NAME}:${CI_COMMIT_SHA} -t ${REGISTRY}/${IMAGE_NAME}:latest .
    - docker push ${REGISTRY}/${IMAGE_NAME}:${CI_COMMIT_SHA}
    - docker push ${REGISTRY}/${IMAGE_NAME}:latest

# ── Stage 5: Deploy to Staging ──
deploy-staging:
  stage: deploy-staging
  image: bitnami/kubectl:latest
  environment:
    name: staging
  only:
    - main
  script:
    - echo "${KUBECONFIG_DATA}" | base64 -d > /tmp/kubeconfig
    - export KUBECONFIG=/tmp/kubeconfig
    - sed -i "s|image:.*|image: ${REGISTRY}/${IMAGE_NAME}:${CI_COMMIT_SHA}|g" k8s/deployment.yaml
    - kubectl apply -f k8s/ -n {{ staging_ns }}
    - kubectl rollout status deployment/{{ svc_name }} -n {{ staging_ns }} --timeout=300s
    - |
      STAGING_URL=$(kubectl get svc {{ svc_name }} -n {{ staging_ns }} -o jsonpath='{.status.loadBalancer.ingress[0].ip}')
      curl -sf "http://${STAGING_URL}/health" || exit 1

# ── Stage 6: Deploy to Production ──
deploy-production:
  stage: deploy-production
  image: bitnami/kubectl:latest
  environment:
    name: production
  only:
    - main
{% if manual_approval %}
  when: manual
{% endif %}
  script:
    - echo "${KUBECONFIG_DATA}" | base64 -d > /tmp/kubeconfig
    - export KUBECONFIG=/tmp/kubeconfig
    - sed -i "s|image:.*|image: ${REGISTRY}/${IMAGE_NAME}:${CI_COMMIT_SHA}|g" k8s/deployment.yaml
    - kubectl apply -f k8s/ -n {{ prod_ns }}
    - kubectl rollout status deployment/{{ svc_name }} -n {{ prod_ns }} --timeout=300s
{% if compliance_url %}
    - |
      curl -sf -X POST "{{ compliance_url }}" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer ${ARCHIE_API_TOKEN}" \
        -d '{"service_url": "http://{{ svc_name }}.{{ prod_ns }}.svc.cluster.local"}' || echo "Compliance check failed (non-blocking)"
{% endif %}
