{# app/modules/solutions_product/templates/python_fastapi/admin_ui.html.j2 #}
{# Generates a single-page CRUD admin interface using Alpine.js + Tailwind CDN. #}
{# Context: project_name, solution_id, entities (list of entity defs with fields) #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ project_name }} — Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>[x-cloak] { display: none !important; }</style>
    <script>
    // Auth helper: reads JWT from localStorage or cookie, injects into all fetch calls
    const _origFetch = window.fetch;
    window.fetch = function(url, opts) {
        opts = opts || {};
        opts.headers = opts.headers || {};
        const token = localStorage.getItem('token') || (document.cookie.match(/(?:^|;\s*)token=([^;]*)/) || [])[1] || '';
        if (token && !opts.headers['Authorization']) {
            opts.headers['Authorization'] = 'Bearer ' + token;
        }
        return _origFetch.call(this, url, opts);
    };
    </script>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen">

<div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-bold">{{ project_name }}</h1>
            <p class="text-zinc-400 text-sm">Generated from A.R.C.H.I.E. Solution #{{ solution_id }}</p>
        </div>
        <div class="flex gap-3">
            <a href="/docs" class="px-3 py-1.5 text-xs rounded-md border border-zinc-700 text-zinc-400 hover:text-zinc-100 transition-colors">API Docs</a>
            <a href="/health" class="px-3 py-1.5 text-xs rounded-md border border-zinc-700 text-zinc-400 hover:text-zinc-100 transition-colors">Health</a>
        </div>
    </div>

    <!-- Dashboard metrics -->
    <div x-data="dashboardMetrics()" x-init="init()" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4">
            <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Service Health</p>
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full" :class="health === 'ok' ? 'bg-emerald-500' : 'bg-red-500'"></span>
                <span class="text-sm font-medium" x-text="health"></span>
            </div>
        </div>
        {% for entity in entities %}
        <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4">
            <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">{{ entity.name_display }}</p>
            <p class="text-lg font-semibold" x-text="entityCounts['{{ entity.name_snake }}'] || 0"></p>
        </div>
        {% endfor %}
        <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4">
            <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Last Updated</p>
            <p class="text-sm font-medium" x-text="lastUpdated"></p>
        </div>
    </div>

    <!-- Entity tabs and CRUD -->
    <div x-data="adminApp()" x-init="init()">
        <!-- Tab navigation -->
        <div class="flex gap-1 border-b border-zinc-800 mb-6 overflow-x-auto">
            {% for entity in entities %}
            <button @click="activeTab = '{{ entity.name_snake }}'"
                    :class="activeTab === '{{ entity.name_snake }}' ? 'border-blue-500 text-blue-400' : 'border-transparent text-zinc-500 hover:text-zinc-300'"
                    class="px-4 py-2 text-sm font-medium border-b-2 transition-colors whitespace-nowrap">
                {{ entity.name_display }}
                <span class="ml-1.5 text-xs px-1.5 py-0.5 rounded-full bg-zinc-800" x-text="counts['{{ entity.name_snake }}'] || 0"></span>
            </button>
            {% endfor %}
        </div>

        <!-- Toast notification -->
        <div x-show="toast.show" x-cloak x-transition
             class="fixed top-4 right-4 z-[60] px-4 py-2 rounded-lg text-sm font-medium shadow-lg"
             :class="toast.type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white'">
            <span x-text="toast.message"></span>
        </div>

        {% for entity in entities %}
        <!-- {{ entity.name_display }} panel -->
        <div x-show="activeTab === '{{ entity.name_snake }}'" x-cloak>
            <!-- Toolbar -->
            <div class="flex items-center justify-between mb-4">
                <input type="text" x-model="searchQuery" placeholder="Search {{ entity.name_display }}..."
                       class="w-64 rounded-md border border-zinc-700 bg-zinc-900 px-3 py-1.5 text-sm text-zinc-100 placeholder-zinc-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                <button @click="showCreateForm = true; editingId = null; resetForm('{{ entity.name_snake }}')"
                        class="px-3 py-1.5 text-xs font-medium rounded-md bg-blue-600 text-white hover:bg-blue-700 transition-colors">
                    + New {{ entity.name_display }}
                </button>
            </div>

            <!-- Data table -->
            <div class="border border-zinc-800 rounded-lg overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-zinc-900">
                            <tr>
                                {% for field in entity.fields %}
                                <th @click="toggleSort('{{ field.name }}')"
                                    class="px-4 py-2 text-left text-xs font-medium text-zinc-400 uppercase tracking-wider cursor-pointer hover:text-zinc-200 select-none">
                                    {{ field.display_name }}
                                    <span x-show="sortField === '{{ field.name }}'" x-text="sortDir === 'asc' ? ' &#9650;' : ' &#9660;'" class="text-blue-400"></span>
                                </th>
                                {% endfor %}
                                <th class="px-4 py-2 text-right text-xs font-medium text-zinc-400">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-800">
                            <template x-for="item in filteredItems('{{ entity.name_snake }}')" :key="item.id">
                                <tr class="hover:bg-zinc-900/50 transition-colors">
                                    {% for field in entity.fields %}
                                    {% if field.type == 'boolean' %}
                                    <td class="px-4 py-2 text-zinc-300">
                                        <span :class="item.{{ field.name }} ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/30' : 'bg-zinc-500/10 text-zinc-400 border-zinc-500/30'"
                                              class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium border"
                                              x-text="item.{{ field.name }} ? 'Yes' : 'No'"></span>
                                    </td>
                                    {% else %}
                                    <td class="px-4 py-2 text-zinc-300 max-w-xs truncate" x-text="item.{{ field.name }}"></td>
                                    {% endif %}
                                    {% endfor %}
                                    <td class="px-4 py-2 text-right whitespace-nowrap">
                                        <button @click="editItem('{{ entity.name_snake }}', item)" class="text-blue-400 hover:text-blue-300 text-xs mr-2">Edit</button>
                                        <button @click="confirmDelete('{{ entity.name_snake }}', item.id)" class="text-red-400 hover:text-red-300 text-xs">Delete</button>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
                <div x-show="!filteredItems('{{ entity.name_snake }}').length" class="px-4 py-8 text-center text-zinc-500 text-sm">
                    No records found.
                </div>
            </div>

            <!-- Create/Edit form (slide-over) -->
            <div x-show="showCreateForm" x-cloak class="fixed inset-0 z-50 flex justify-end" @keydown.escape.window="showCreateForm = false">
                <div class="absolute inset-0 bg-black/50" @click="showCreateForm = false"></div>
                <div class="relative w-full max-w-md bg-zinc-900 border-l border-zinc-800 p-6 overflow-y-auto" @click.stop>
                    <h3 class="text-lg font-semibold mb-4" x-text="editingId ? 'Edit {{ entity.name_display }}' : 'New {{ entity.name_display }}'"></h3>
                    <form @submit.prevent="saveItem('{{ entity.name_snake }}')">
                        {% for field in entity.fields %}
                        {% if not field.is_auto %}
                        <div class="mb-4">
                            <label class="block text-xs font-medium text-zinc-400 mb-1">{{ field.display_name }}{% if field.required %} *{% endif %}</label>
                            {% if field.type == 'boolean' %}
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" x-model="formData.{{ field.name }}" class="sr-only peer">
                                <div class="w-9 h-5 bg-zinc-700 peer-focus:ring-2 peer-focus:ring-blue-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                            </label>
                            {% elif field.type == 'integer' or field.type == 'number' %}
                            <input type="number" x-model="formData.{{ field.name }}" {% if field.required %}required{% endif %}
                                   {% if field.type == 'number' %}step="any"{% endif %}
                                   class="w-full rounded-md border border-zinc-700 bg-zinc-800 px-3 py-1.5 text-sm text-zinc-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            {% elif field.type == 'text' %}
                            <textarea x-model="formData.{{ field.name }}" rows="3" {% if field.required %}required{% endif %}
                                      class="w-full rounded-md border border-zinc-700 bg-zinc-800 px-3 py-1.5 text-sm text-zinc-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"></textarea>
                            {% elif field.enum_values %}
                            <select x-model="formData.{{ field.name }}"
                                    class="w-full rounded-md border border-zinc-700 bg-zinc-800 px-3 py-1.5 text-sm text-zinc-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                                <option value="">Select...</option>
                                {% for val in field.enum_values %}
                                <option value="{{ val }}">{{ val }}</option>
                                {% endfor %}
                            </select>
                            {% elif field.type == 'date-time' %}
                            <input type="datetime-local" x-model="formData.{{ field.name }}" {% if field.required %}required{% endif %}
                                   class="w-full rounded-md border border-zinc-700 bg-zinc-800 px-3 py-1.5 text-sm text-zinc-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            {% else %}
                            <input type="text" x-model="formData.{{ field.name }}" {% if field.required %}required{% endif %}
                                   class="w-full rounded-md border border-zinc-700 bg-zinc-800 px-3 py-1.5 text-sm text-zinc-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            {% endif %}
                        </div>
                        {% endif %}
                        {% endfor %}
                        <div class="flex gap-2 mt-6">
                            <button type="submit" :disabled="saving"
                                    class="flex-1 px-3 py-2 text-sm font-medium rounded-md bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-50 transition-colors">
                                <span x-show="!saving" x-text="editingId ? 'Update' : 'Create'"></span>
                                <span x-show="saving">Saving...</span>
                            </button>
                            <button type="button" @click="showCreateForm = false"
                                    class="px-3 py-2 text-sm rounded-md border border-zinc-700 text-zinc-400 hover:text-zinc-100 transition-colors">Cancel</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Delete confirmation modal -->
            <div x-show="showDeleteConfirm" x-cloak class="fixed inset-0 z-50 flex items-center justify-center" @keydown.escape.window="showDeleteConfirm = false">
                <div class="absolute inset-0 bg-black/50" @click="showDeleteConfirm = false"></div>
                <div class="relative bg-zinc-900 border border-zinc-800 rounded-lg p-6 max-w-sm w-full mx-4" @click.stop>
                    <h3 class="text-lg font-semibold mb-2">Confirm Delete</h3>
                    <p class="text-zinc-400 text-sm mb-4">Are you sure you want to delete this record? This action cannot be undone.</p>
                    <div class="flex gap-2 justify-end">
                        <button @click="showDeleteConfirm = false"
                                class="px-3 py-1.5 text-sm rounded-md border border-zinc-700 text-zinc-400 hover:text-zinc-100 transition-colors">Cancel</button>
                        <button @click="executeDelete()"
                                class="px-3 py-1.5 text-sm font-medium rounded-md bg-red-600 text-white hover:bg-red-700 transition-colors">Delete</button>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>

<script>
function dashboardMetrics() {
    return {
        health: 'checking...',
        entityCounts: {},
        lastUpdated: '-',

        async init() {
            try {
                const res = await fetch('/health');
                const data = await res.json();
                this.health = data.status || 'unknown';
            } catch (e) {
                this.health = 'unreachable';
            }

            {% for entity in entities %}
            try {
                const res = await fetch('{{ entity.api_path }}');
                const data = await res.json();
                const items = Array.isArray(data) ? data : (data.items || data.data || []);
                this.entityCounts['{{ entity.name_snake }}'] = items.length;
            } catch (e) {
                this.entityCounts['{{ entity.name_snake }}'] = 0;
            }
            {% endfor %}

            this.lastUpdated = new Date().toLocaleString();
        }
    };
}

function adminApp() {
    return {
        activeTab: '{{ entities[0].name_snake if entities else "" }}',
        searchQuery: '',
        showCreateForm: false,
        showDeleteConfirm: false,
        editingId: null,
        deleteTarget: { entityName: null, id: null },
        formData: {},
        items: {},
        counts: {},
        saving: false,
        sortField: '',
        sortDir: 'asc',
        toast: { show: false, message: '', type: 'success' },

        async init() {
            {% for entity in entities %}
            await this.loadItems('{{ entity.name_snake }}', '{{ entity.api_path }}');
            {% endfor %}
        },

        showToast(message, type) {
            this.toast = { show: true, message, type };
            setTimeout(() => { this.toast.show = false; }, 3000);
        },

        async loadItems(entityName, apiPath) {
            try {
                const res = await fetch(apiPath);
                const data = await res.json();
                this.items[entityName] = Array.isArray(data) ? data : (data.items || data.data || []);
                this.counts[entityName] = this.items[entityName].length;
            } catch (e) {
                this.items[entityName] = [];
                this.counts[entityName] = 0;
            }
        },

        toggleSort(field) {
            if (this.sortField === field) {
                this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc';
            } else {
                this.sortField = field;
                this.sortDir = 'asc';
            }
        },

        filteredItems(entityName) {
            let items = [...(this.items[entityName] || [])];
            if (this.searchQuery) {
                const q = this.searchQuery.toLowerCase();
                items = items.filter(item =>
                    Object.values(item).some(v => String(v).toLowerCase().includes(q))
                );
            }
            if (this.sortField) {
                items.sort((a, b) => {
                    const va = a[this.sortField], vb = b[this.sortField];
                    if (va == null && vb == null) return 0;
                    if (va == null) return 1;
                    if (vb == null) return -1;
                    const cmp = String(va).localeCompare(String(vb), undefined, { numeric: true });
                    return this.sortDir === 'asc' ? cmp : -cmp;
                });
            }
            return items;
        },

        resetForm(entityName) {
            this.formData = {};
        },

        editItem(entityName, item) {
            this.editingId = item.id;
            this.formData = { ...item };
            this.showCreateForm = true;
        },

        confirmDelete(entityName, id) {
            this.deleteTarget = { entityName, id };
            this.showDeleteConfirm = true;
        },

        async executeDelete() {
            const { entityName, id } = this.deleteTarget;
            const apiPaths = { {% for entity in entities %}'{{ entity.name_snake }}': '{{ entity.api_path }}'{% if not loop.last %}, {% endif %}{% endfor %} };
            this.showDeleteConfirm = false;
            try {
                const res = await fetch(`${apiPaths[entityName]}/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    this.showToast('Record deleted', 'success');
                    await this.loadItems(entityName, apiPaths[entityName]);
                } else {
                    this.showToast('Delete failed: ' + res.statusText, 'error');
                }
            } catch (e) {
                this.showToast('Delete failed: ' + e.message, 'error');
            }
        },

        async saveItem(entityName) {
            const apiPaths = { {% for entity in entities %}'{{ entity.name_snake }}': '{{ entity.api_path }}'{% if not loop.last %}, {% endif %}{% endfor %} };
            const basePath = apiPaths[entityName];
            const method = this.editingId ? 'PUT' : 'POST';
            const url = this.editingId ? `${basePath}/${this.editingId}` : basePath;
            this.saving = true;

            try {
                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.formData)
                });
                if (res.ok) {
                    this.showCreateForm = false;
                    this.showToast(this.editingId ? 'Record updated' : 'Record created', 'success');
                    await this.loadItems(entityName, basePath);
                } else {
                    const err = await res.json().catch(() => ({}));
                    this.showToast('Save failed: ' + (err.detail || res.statusText), 'error');
                }
            } catch (e) {
                this.showToast('Save failed: ' + e.message, 'error');
            } finally {
                this.saving = false;
            }
        }
    };
}
</script>
</body>
</html>
