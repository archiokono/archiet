# bundle_id: {{ bundle_id }}
# generated_at: {{ generated_at }}
#
# Terraform configuration for {{ solution_name }} database provisioning.
# State backend is NOT configured — teams choose their own (S3, GCS, etc.).

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region

  default_tags {
    tags = {
      ManagedBy  = "terraform"
      Source     = "archie-codegen"
      SolutionId = "{{ solution_id }}"
    }
  }
}
