// GENERATED BY ARCHIE — solution_id: {{ solution_id }}
// k6 Load Test — sustained load for production readiness validation.
// Run: k6 run tests/load/k6_load.js
// Stages: ramp-up 1min → peak 3min (100 VUs) → ramp-down 1min.
// Thresholds: p95 < 1000ms, p99 < 3000ms, error rate < 2%.

import http from "k6/http";
import { check, sleep, group } from "k6";
import { SharedArray } from "k6/data";
import { Counter, Rate, Trend } from "k6/metrics";

const BASE_URL = __ENV.K6_API_URL || "http://localhost:8000";
const TOKEN    = __ENV.K6_AUTH_TOKEN || "";

const errorRate        = new Rate("error_rate");
const p95Breaches      = new Counter("p95_breaches");
const createErrorRate  = new Rate("create_error_rate");

export const options = {
  stages: [
    { duration: "1m",  target: 20  },   // ramp up
    { duration: "3m",  target: 100 },   // peak load
    { duration: "1m",  target: 0   },   // ramp down
  ],
  thresholds: {
    "http_req_duration{type:read}":   ["p(95)<1000", "p(99)<3000"],
    "http_req_duration{type:write}":  ["p(95)<2000", "p(99)<5000"],
    "error_rate":                     ["rate<0.02"],   // < 2% errors
    "create_error_rate":              ["rate<0.01"],   // < 1% create errors
    "http_req_failed":                ["rate<0.02"],
  },
};

const HEADERS = {
  "Content-Type": "application/json",
  ...(TOKEN ? { Authorization: `Bearer ${TOKEN}` } : {}),
};

// Pre-built test payloads for each entity
const TEST_PAYLOADS = {
{% for svc in services %}
  "{{ svc.name | lower }}": {
    {% if confirmed_fields and svc.name in confirmed_fields %}
    {% for field in confirmed_fields[svc.name] %}
    {% if field.required and field.name not in ('id', 'created_at', 'updated_at', 'deleted_at', 'organization_id') %}
    "{{ field.name }}": {% if field.type in ('integer', 'number') %}Math.floor(Math.random() * 10000){% elif field.type == 'boolean' %}true{% else %}`load-test-${__VU}-${__ITER}`{% endif %},
    {% endif %}
    {% endfor %}
    {% else %}
    "name": `load-test-${__VU}-${__ITER}`,
    {% endif %}
  },
{% endfor %}
};

export function setup() {
  const res = http.get(`${BASE_URL}/health`);
  if (res.status !== 200) {
    throw new Error(`API not ready: ${res.status}`);
  }
  return { baseUrl: BASE_URL };
}

export default function (data) {
  const { baseUrl } = data;

  // Mix of reads (70%) and writes (30%) — realistic production traffic distribution
  const rand = Math.random();

  if (rand < 0.70) {
    // READ operations
{% for svc in services %}
    group("{{ svc.name }} read", () => {
      const res = http.get(
        `${baseUrl}{{ svc.base_path }}?page=1&per_page=20`,
        { headers: HEADERS, tags: { type: "read", resource: "{{ svc.name | lower }}" } }
      );
      const ok = check(res, {
        "{{ svc.name }} list 200": (r) => r.status === 200,
        "{{ svc.name }} list fast": (r) => r.timings.duration < 1000,
      });
      if (!ok) {
        errorRate.add(1);
        if (res.timings.duration > 1000) p95Breaches.add(1);
      }
    });
{% endfor %}
  } else {
    // WRITE operations
{% for svc in services %}
    group("{{ svc.name }} create", () => {
      const payload = Object.assign({}, TEST_PAYLOADS["{{ svc.name | lower }}"]);
      // Uniquify string fields to avoid unique constraint failures
      Object.keys(payload).forEach((k) => {
        if (typeof payload[k] === "string") {
          payload[k] = `${payload[k]}-${Date.now()}-${Math.random().toString(36).slice(2)}`;
        }
      });

      const res = http.post(
        `${baseUrl}{{ svc.base_path }}`,
        JSON.stringify(payload),
        { headers: HEADERS, tags: { type: "write", resource: "{{ svc.name | lower }}" } }
      );
      const ok = check(res, {
        "{{ svc.name }} create 201": (r) => r.status === 201,
        "{{ svc.name }} create fast": (r) => r.timings.duration < 2000,
      });
      if (!ok) {
        createErrorRate.add(1);
        if (res.status >= 500) errorRate.add(1);
      }
    });
{% endfor %}
  }

  sleep(0.5 + Math.random() * 0.5); // 0.5–1s think time
}

export function handleSummary(data) {
  const summary = {
    "solution_id": {{ solution_id }},
    "generated_at": new Date().toISOString(),
    "thresholds": data.metrics,
    "load_test_passed": Object.values(data.metrics)
      .every(m => !m.thresholds || Object.values(m.thresholds).every(t => !t.ok === false)),
  };

  return {
    "tests/load/results.json": JSON.stringify(summary, null, 2),
    stdout: `\n✅ Load test complete — see tests/load/results.json\n`,
  };
}
