/* Generated by A.R.C.H.I.E. — shared Alpine.js utilities */

/* Toast helper: dispatch from anywhere via window.dispatchEvent */
function notify(message, type) {
    window.dispatchEvent(new CustomEvent('notify', { detail: { message, type: type || 'success' } }));
}

/* Format dates nicely */
function formatDate(dateStr) {
    if (!dateStr) return '—';
    const d = new Date(dateStr);
    return isNaN(d) ? dateStr : d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
}

function formatDateTime(dateStr) {
    if (!dateStr) return '—';
    const d = new Date(dateStr);
    return isNaN(d) ? dateStr : d.toLocaleString(undefined, { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
}

/* Auth header helper */
function authHeaders(extra) {
    const h = extra || {};
    const token = localStorage.getItem('archie_token');
    if (token) h['Authorization'] = 'Bearer ' + token;
    return h;
}

/* Notification bell — used in layout topbar */
function notificationBell() {
    return {
        notifications: [], unread: 0, open: false, ws: null,
        async init() {
            await this.load();
            this.connectWebSocket();
            // Poll every 30s as fallback
            setInterval(() => this.loadUnreadCount(), 30000);
        },
        async load() {
            try {
                const r = await fetch('/api/notifications?limit=20', { headers: authHeaders() });
                if (r.ok) {
                    this.notifications = await r.json();
                    this.unread = this.notifications.filter(n => !n.read).length;
                }
            } catch (e) {}
        },
        async loadUnreadCount() {
            try {
                const r = await fetch('/api/notifications/unread-count', { headers: authHeaders() });
                if (r.ok) { const d = await r.json(); this.unread = d.unread; }
            } catch (e) {}
        },
        async markAllRead() {
            await fetch('/api/notifications/read-all', { method: 'POST', headers: authHeaders() });
            this.notifications.forEach(n => n.read = true);
            this.unread = 0;
        },
        connectWebSocket() {
            const proto = location.protocol === 'https:' ? 'wss' : 'ws';
            try {
                this.ws = new WebSocket(`${proto}://${location.host}/ws/notifications?user_id=current`);
                this.ws.onmessage = (e) => {
                    const msg = JSON.parse(e.data);
                    if (msg.type === 'notification') {
                        this.notifications.unshift(msg);
                        this.unread++;
                        notify(msg.title, msg.notification_type || 'info');
                    } else if (msg.type === 'entity_change') {
                        notify(`${msg.entity_type} ${msg.action}d`, 'info');
                    }
                };
                this.ws.onclose = () => { setTimeout(() => this.connectWebSocket(), 5000); };
            } catch (e) {}
        },
    };
}

/* Global search — used in layout topbar */
function globalSearch() {
    return {
        q: '', results: [], open: false, searched: false,
        async search() {
            if (this.q.length < 2) { this.results = []; this.open = false; this.searched = false; return; }
            try {
                const r = await fetch('/api/search?q=' + encodeURIComponent(this.q) + '&limit=20', { headers: authHeaders() });
                if (r.ok) {
                    const data = await r.json();
                    this.results = [];
                    for (const [type, items] of Object.entries(data.results || {})) {
                        for (const item of items) {
                            this.results.push({ ...item, _type: type });
                        }
                    }
                    this.open = true;
                    this.searched = true;
                }
            } catch (e) { console.error('Search failed:', e); }
        },
        groupedResults() {
            const groups = {};
            for (const r of this.results) {
                const type = r._type || r.type || 'results';
                if (!groups[type]) groups[type] = [];
                groups[type].push(r);
            }
            return groups;
        },
    };
}
