{# app/modules/solutions_product/templates/python_fastapi/monitoring/prometheus.yml.j2 #}
# Prometheus config for {{ project_name }}
# Generated by A.R.C.H.I.E. — solution_id: {{ solution_id }}

global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    solution: "{{ solution_id }}"
    environment: "${ENV:-development}"

scrape_configs:
  - job_name: "{{ project_name | lower | replace(' ', '_') }}"
    static_configs:
      - targets: ["app:{{ port | default('8000') }}"]
    metrics_path: /metrics
    scrape_interval: 10s

  - job_name: "postgres"
    static_configs:
      - targets: ["postgres-exporter:9187"]

  - job_name: "node"
    static_configs:
      - targets: ["node-exporter:9100"]

alerting:
  alertmanagers:
    - static_configs:
        - targets: []
          # - alertmanager:9093

rule_files: []
  # - "alerts/*.yml"
