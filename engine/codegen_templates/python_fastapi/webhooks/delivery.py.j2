@router.get("")
async def list_webhooks(
    db: AsyncSession = Depends(get_db),
    token: TokenPayload = Depends(verify_token),
):
    """List all webhook subscriptions."""
    result = await db.execute(select(WebhookSubscription).order_by(WebhookSubscription.created_at.desc()))
    subs = result.scalars().all()
    return [
        {
            "id": s.id, "url": s.url, "events": s.events, "is_active": s.is_active,
            "description": s.description, "failure_count": s.failure_count,
            "last_delivery_at": s.last_delivery_at.isoformat() if s.last_delivery_at else None,
            "created_at": s.created_at.isoformat() if s.created_at else None,
        }
        for s in subs
    ]


@router.post("", status_code=201)
async def create_webhook(
    body: WebhookCreateRequest,
    db: AsyncSession = Depends(get_db),
    token: TokenPayload = Depends(verify_token),
):
    """Create a new webhook subscription."""
    import secrets
    sub = WebhookSubscription(
        url=body.url,
        events=body.events,
        description=body.description,
        secret=secrets.token_hex(32),
    )
    db.add(sub)
    await db.commit()
    await db.refresh(sub)
    return {"id": sub.id, "url": sub.url, "secret": sub.secret, "events": sub.events}


@router.delete("/{webhook_id}")
async def delete_webhook(
    webhook_id: str,
    db: AsyncSession = Depends(get_db),
    token: TokenPayload = Depends(verify_token),
):
    """Remove a webhook subscription."""
    result = await db.execute(select(WebhookSubscription).where(WebhookSubscription.id == webhook_id))
    sub = result.scalar_one_or_none()
    if not sub:
        raise HTTPException(404, "Webhook not found")
    await db.delete(sub)
    await db.commit()
    return {"deleted": True}


@router.post("/test/{webhook_id}")
async def test_webhook(
    webhook_id: str,
    db: AsyncSession = Depends(get_db),
    token: TokenPayload = Depends(verify_token),
):
    """Send a test payload to a webhook."""
    result = await db.execute(select(WebhookSubscription).where(WebhookSubscription.id == webhook_id))
    sub = result.scalar_one_or_none()
    if not sub:
        raise HTTPException(404, "Webhook not found")

    test_payload = {
        "event": "webhook.test",
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "data": {"message": "This is a test webhook delivery"},
    }
    success = await _deliver_with_retry(db, sub, "webhook.test", test_payload)
