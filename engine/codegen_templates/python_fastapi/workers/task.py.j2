        _execute(payload or {})
        # ─────────────────────────────────────────────────────────────────

        elapsed = time.monotonic() - start
        logger.info("Completed %s in %.2fs", self.name, elapsed)

    except Exception as exc:
        elapsed = time.monotonic() - start
        logger.error("Failed %s after %.2fs (attempt %d): %s", self.name, elapsed, self.request.retries + 1, exc)

{% if backoff == 'exponential' %}
        countdown = 2 ** self.request.retries  # 1s, 2s, 4s, 8s...
{% else %}
        countdown = 5 * (self.request.retries + 1)  # 5s, 10s, 15s...
{% endif %}

        if self.request.retries < {{ max_retries }}:
            raise self.retry(exc=exc, countdown=countdown)
        else:
{% if dlq %}
            _send_to_dead_letter(self.name, payload, str(exc))
{% endif %}
            logger.critical("Dead letter: %s permanently failed after %d attempts", self.name, {{ max_retries }})
            raise


