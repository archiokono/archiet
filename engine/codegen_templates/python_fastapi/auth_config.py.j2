def require_role(*allowed_roles: str):
    """Dependency that checks the caller has at least one of the allowed roles.

    Usage:
        @router.get("/admin", dependencies=[Depends(require_role("admin", "superadmin"))])
    """

    def _checker(token: TokenPayload = Depends(verify_token)) -> TokenPayload:
        if not any(role in token.roles for role in allowed_roles):
            raise HTTPException(
                status_code=status.HTTP_403_FORBIDDEN,
                detail=f"Requires one of: {', '.join(allowed_roles)}",
            )
        return token

    return _checker
