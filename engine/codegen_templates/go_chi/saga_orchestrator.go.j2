// SagaStatus represents the state of a saga execution.
type SagaStatus string

const (
	SagaStatusPending      SagaStatus = "pending"
	SagaStatusRunning      SagaStatus = "running"
	SagaStatusCompleted    SagaStatus = "completed"
	SagaStatusCompensating SagaStatus = "compensating"
	SagaStatusFailed       SagaStatus = "failed"
	SagaStatusTimedOut     SagaStatus = "timed_out"
)

// StepStatus represents the state of a single saga step.
type StepStatus string

const (
	StepStatusPending     StepStatus = "pending"
	StepStatusRunning     StepStatus = "running"
	StepStatusCompleted   StepStatus = "completed"
	StepStatusCompensated StepStatus = "compensated"
	StepStatusFailed      StepStatus = "failed"
)

// SagaStepFunc is a function executed as a saga step.
type SagaStepFunc func(ctx context.Context, sagaCtx map[string]interface{}) (interface{}, error)

// SagaStep defines a single step with action and compensation.
type SagaStep struct {
	Name           string
	Action         SagaStepFunc
	Compensation   SagaStepFunc
	TimeoutSeconds float64
	Status         StepStatus
	Result         interface{}
	Error          string
	StartedAt      *time.Time
	CompletedAt    *time.Time
}

// SagaState tracks the full execution state.
type SagaState struct {
	SagaID      string             `json:"saga_id"`
	Name        string             `json:"name"`
	Status      SagaStatus         `json:"status"`
	Steps       []StepState        `json:"steps"`
	Context     map[string]interface{} `json:"context"`
	StartedAt   *time.Time         `json:"started_at"`
	CompletedAt *time.Time         `json:"completed_at"`
	Error       string             `json:"error,omitempty"`
}

// StepState is the serializable view of a step.
type StepState struct {
	Name       string  `json:"name"`
	Status     string  `json:"status"`
	Error      string  `json:"error,omitempty"`
	DurationMs *int64  `json:"duration_ms,omitempty"`
}

// SagaOrchestrator executes steps with compensation on failure.
type SagaOrchestrator struct {
	name           string
	steps          []SagaStep
	timeoutSeconds float64
	mu             sync.Mutex
}

// NewSagaOrchestrator creates a new orchestrator.
func NewSagaOrchestrator(name string, timeoutSeconds float64) *SagaOrchestrator {
	if timeoutSeconds <= 0 {
		timeoutSeconds = 300
	}
	return &SagaOrchestrator{
		name:           name,
		steps:          make([]SagaStep, 0),
		timeoutSeconds: timeoutSeconds,
	}
}

// AddStep adds a step to the saga.
func (s *SagaOrchestrator) AddStep(name string, action, compensation SagaStepFunc, timeoutSeconds float64) {
	if timeoutSeconds <= 0 {
		timeoutSeconds = 30
	}
	s.steps = append(s.steps, SagaStep{
		Name:           name,
		Action:         action,
		Compensation:   compensation,
		TimeoutSeconds: timeoutSeconds,
		Status:         StepStatusPending,
	})
}

// Execute runs all steps. On failure, compensates completed steps in reverse.
func (s *SagaOrchestrator) Execute(ctx context.Context, sagaCtx map[string]interface{}) SagaState {
	s.mu.Lock()
	defer s.mu.Unlock()

	sagaID := uuid.New().String()
	now := time.Now()

	state := SagaState{
		SagaID:    sagaID,
		Name:      s.name,
		Status:    string(SagaStatusRunning),
		Context:   sagaCtx,
		StartedAt: &now,
	}

	log.Printf("Saga %s started: %s", s.name, sagaID)

	// Create timeout context for entire saga
	sagaCtxWithTimeout, cancel := context.WithTimeout(ctx, time.Duration(s.timeoutSeconds)*time.Second)
	defer cancel()

	var completedSteps []*SagaStep

	for i := range s.steps {
		step := &s.steps[i]

		// Check saga timeout
		select {
		case <-sagaCtxWithTimeout.Done():
			state.Status = string(SagaStatusTimedOut)
			state.Error = fmt.Sprintf("saga timed out after %.1fs", s.timeoutSeconds)
			log.Printf("Saga %s timed out", s.name)
			s.compensate(ctx, completedSteps, sagaCtx)
			state.Steps = s.buildStepStates()
			endTime := time.Now()
			state.CompletedAt = &endTime
			return state
		default:
		}

		startTime := time.Now()
		step.StartedAt = &startTime
		step.Status = StepStatusRunning

		// Execute step with per-step timeout
		stepCtx, stepCancel := context.WithTimeout(sagaCtxWithTimeout, time.Duration(step.TimeoutSeconds)*time.Second)
		result, err := step.Action(stepCtx, sagaCtx)
		stepCancel()

		endTime := time.Now()
		step.CompletedAt = &endTime

		if err != nil {
			step.Status = StepStatusFailed
			step.Error = err.Error()
			state.Status = string(SagaStatusFailed)
			state.Error = fmt.Sprintf("step '%s' failed: %v", step.Name, err)
			log.Printf("Saga %s step '%s' failed: %v", s.name, step.Name, err)
			s.compensate(ctx, completedSteps, sagaCtx)
			state.Steps = s.buildStepStates()
			state.CompletedAt = &endTime
			return state
		}

		step.Status = StepStatusCompleted
		step.Result = result
		completedSteps = append(completedSteps, step)

		durationMs := endTime.Sub(startTime).Milliseconds()
		log.Printf("Saga %s step '%s' completed in %dms", s.name, step.Name, durationMs)
	}

	state.Status = string(SagaStatusCompleted)
	endTime := time.Now()
	state.CompletedAt = &endTime
	state.Steps = s.buildStepStates()
	log.Printf("Saga %s completed successfully", s.name)
	return state
}

func (s *SagaOrchestrator) compensate(ctx context.Context, completedSteps []*SagaStep, sagaCtx map[string]interface{}) {
	if len(completedSteps) == 0 {
		return
	}
	log.Printf("Saga %s compensating %d steps", s.name, len(completedSteps))

	for i := len(completedSteps) - 1; i >= 0; i-- {
		step := completedSteps[i]
		if step.Compensation == nil {
			log.Printf("Step '%s' has no compensation — skipping", step.Name)
			continue
		}
		stepCtx, cancel := context.WithTimeout(ctx, time.Duration(step.TimeoutSeconds)*time.Second)
		_, err := step.Compensation(stepCtx, sagaCtx)
		cancel()
		if err != nil {
			log.Printf("Saga %s: compensation failed for step '%s': %v", s.name, step.Name, err)
		} else {
			step.Status = StepStatusCompensated
			log.Printf("Saga %s: compensated step '%s'", s.name, step.Name)
		}
	}
}

func (s *SagaOrchestrator) buildStepStates() []StepState {
	states := make([]StepState, len(s.steps))
	for i, step := range s.steps {
		ss := StepState{
			Name:   step.Name,
			Status: string(step.Status),
			Error:  step.Error,
		}
		if step.StartedAt != nil && step.CompletedAt != nil {
			ms := step.CompletedAt.Sub(*step.StartedAt).Milliseconds()
			ss.DurationMs = &ms
		}
		states[i] = ss
	}
	return states
}

