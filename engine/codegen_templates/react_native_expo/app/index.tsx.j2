{# Home dashboard — greeting, stats, module navigation cards #}
import { ScrollView, Text, TouchableOpacity, View } from "react-native"
import { useRouter } from "expo-router"
import { SafeAreaView } from "react-native-safe-area-context"
import { useQuery } from "@tanstack/react-query"
import { ArrowRight, {% for cls in classes %}{{ cls.icon }}{% if not loop.last %}, {% endif %}{% endfor %} } from "lucide-react-native"
{% if auth == "jwt-local" %}
import { useAuth } from "@/providers/AuthProvider"
{% endif %}
{% for cls in classes %}
import { {{ cls.name | lower }}Api } from "@/lib/api"
{% endfor %}

const SCROLL_STYLE = { paddingBottom: 32 }
const STATS_GRID = { gap: 10 }
const CARD_SHADOW = { shadowColor: "#000", shadowOffset: { width: 0, height: 1 }, shadowOpacity: 0.05, shadowRadius: 3, elevation: 2 }
const EDGES = ["bottom"] as const

{% set colors = ['#6366f1', '#0ea5e9', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6'] %}
{% set bg_colors = ['#eef2ff', '#f0f9ff', '#ecfdf5', '#fffbeb', '#fef2f2', '#f5f3ff'] %}

const MODULE_CONFIG = [
  {% for cls in classes %}
  {
    key: "{{ cls.table_name }}",
    label: "{{ cls.name | replace('_', ' ') | title }}",
    route: "/{{ cls.table_name }}",
    description: "{{ cls.description | default('Manage ' + (cls.name | replace('_', ' ') | lower) + ' records') | truncate(60, true) }}",
    color: "{{ colors[loop.index0 % 6] }}",
    bgColor: "{{ bg_colors[loop.index0 % 6] }}",
  },
  {% endfor %}
]

const STAT_COLORS: Record<string, { text: string; bg: string }> = {
  {% for cls in classes %}
  "{{ cls.table_name }}": { text: "{{ colors[loop.index0 % 6] }}", bg: "{{ bg_colors[loop.index0 % 6] }}" },
  {% endfor %}
}

const MOD_ICON_BG: Record<string, { backgroundColor: string }> = {
  {% for cls in classes %}
  "{{ cls.table_name }}": { backgroundColor: "{{ bg_colors[loop.index0 % 6] }}" },
  {% endfor %}
}

{% macro module_icon(cls, loop_idx) %}{{ cls.icon }}{% endmacro %}

function ModuleIcon({ modKey, color }: { modKey: string; color: string }) {
  {% for cls in classes %}
  if (modKey === "{{ cls.table_name }}") return <{{ cls.icon }} size={22} color={color} />
  {% endfor %}
  return null
}

function greeting() {
  const h = new Date().getHours()
  if (h < 12) return "Good morning"
  if (h < 17) return "Good afternoon"
  return "Good evening"
}

export default function HomeScreen() {
  const router = useRouter()
  {% if auth == "jwt-local" %}
  const { user } = useAuth()
  const name = user?.full_name?.split(" ")[0] || user?.email?.split("@")[0] || "there"
  {% endif %}

  {% for cls in classes %}
  const { data: {{ cls.name | lower }}Data = [] } = useQuery({
    queryKey: ["{{ cls.table_name }}"],
    queryFn: () => {{ cls.name | lower }}Api.list({ per_page: 1 }),
    select: (items) => items,
  })
  {% endfor %}

  const counts: Record<string, number> = {
    {% for cls in classes %}
    "{{ cls.table_name }}": Array.isArray({{ cls.name | lower }}Data) ? {{ cls.name | lower }}Data.length : 0,
    {% endfor %}
  }

  return (
    <SafeAreaView className="flex-1 bg-slate-50" edges={EDGES}>
      <ScrollView className="flex-1" contentContainerStyle={SCROLL_STYLE}>

        {/* Greeting header */}
        <View className="px-5 pt-4 pb-5">
          <Text className="text-sm font-medium text-indigo-600 mb-0.5">{{ solution_name }}</Text>
          {% if auth == "jwt-local" %}
          <Text className="text-2xl font-bold text-slate-900">{greeting()}, {name}</Text>
          {% else %}
          <Text className="text-2xl font-bold text-slate-900">Dashboard</Text>
          {% endif %}
          <Text className="text-sm text-slate-500 mt-1">Here&apos;s an overview of your data.</Text>
        </View>

        {/* Stats — 2-column grid, never overflows */}
        <View className="px-5 mb-5">
          <Text className="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Overview</Text>
          <View className="flex-row flex-wrap" style={STATS_GRID}>
            {% for cls in classes %}
            <View
              className="bg-white rounded-2xl p-4 border border-slate-100"
              style={[CARD_SHADOW, { width: "47.5%" }]}
            >
              <View className="flex-row items-center justify-between mb-2">
                <Text className="text-xs font-medium text-slate-400 uppercase tracking-wider flex-1 mr-2" numberOfLines={1}>
                  {{ cls.name | replace('_', ' ') | title }}
                </Text>
                <View className="w-7 h-7 rounded-lg items-center justify-center" style={MOD_ICON_BG["{{ cls.table_name }}"]}>
                  <ModuleIcon modKey="{{ cls.table_name }}" color="{{ colors[loop.index0 % 6] }}" />
                </View>
              </View>
              <Text className="text-2xl font-bold" style={STAT_COLORS["{{ cls.table_name }}"]}>
                {counts["{{ cls.table_name }}"]}
              </Text>
            </View>
            {% endfor %}
          </View>
        </View>

        {/* Module navigation */}
        <View className="px-5 gap-3">
          <Text className="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Modules</Text>
          {MODULE_CONFIG.map((mod) => (
            <TouchableOpacity
              key={mod.key}
              onPress={() => router.push(mod.route as never)}
              className="bg-white rounded-2xl p-4 border border-slate-100 flex-row items-center active:scale-[0.98]"
              style={CARD_SHADOW}
              accessibilityLabel={"Navigate to " + mod.label}
            >
              <View
                className="w-11 h-11 rounded-xl items-center justify-center mr-3.5"
                style={MOD_ICON_BG[mod.key] ?? { backgroundColor: "#f1f5f9" }}
              >
                <ModuleIcon modKey={mod.key} color={mod.color} />
              </View>
              <View className="flex-1">
                <Text className="text-base font-semibold text-slate-900">{mod.label}</Text>
                <Text className="text-sm text-slate-500 mt-0.5" numberOfLines={1}>{mod.description}</Text>
              </View>
              <ArrowRight size={18} color="#94a3b8" />
            </TouchableOpacity>
          ))}
        </View>

      </ScrollView>
    </SafeAreaView>
  )
}
