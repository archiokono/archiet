{# salesforce_apex/permission_set.xml.j2 #}
{# Generates PermissionSet with object + field-level security for all generated objects. #}
{# Context: solution_id, bundle_id, solution_name, models (dict of model_name -> model_def) #}
<?xml version="1.0" encoding="UTF-8"?>
<!-- GENERATED BY ARCHIE — solution_id: {{ solution_id }}, bundle_id: {{ bundle_id }} -->
<!-- DO NOT EDIT IN PLACE — REGENERATE FROM ARCHITECTURE -->
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>{{ solution_name | replace(' ', '_') }}_Access</label>
    <description>Field-level security and object permissions for {{ solution_name }}. Generated from ArchiMate architecture by A.R.C.H.I.E.</description>
    <hasActivationRequired>false</hasActivationRequired>

    {% for model_name, model_def in models.items() %}
    <!-- Object: {{ model_name }}__c (x-archimate-source: {{ model_def.archimate_source_id | default('N/A') }}) -->
    <objectPermissions>
        <object>{{ model_name }}__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>false</allowDelete>
        <modifyAllRecords>false</modifyAllRecords>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    {% for field in model_def.fields %}
    {% if not field.primary_key and field.name not in ('id', 'created_at', 'updated_at') %}
    <fieldPermissions>
        <field>{{ model_name }}__c.{{ field.name }}__c</field>
        <readable>true</readable>
        <editable>{{ (not field.readonly | default(false)) | lower }}</editable>
    </fieldPermissions>
    {% endif %}
    {% endfor %}

    {% endfor %}

    <!-- Tab visibility for generated custom tabs -->
    {% for model_name in models %}
    <tabSettings>
        <tab>{{ model_name }}__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    {% endfor %}
</PermissionSet>
