{# shared/prometheus_alerts.yml.j2 #}
{# Generates Prometheus alerting rules from genome SLA thresholds. #}
{# Context: solution_id, solution_name #}
{%- set slug = solution_name | lower | replace(' ', '-') | replace('_', '-') -%}
# GENERATED BY ARCHIE — Architectural Genome v1.0.0
# solution_id: {{ solution_id }}
# Genome section: infrastructure.observability + deployment
#
# Deploy to Prometheus: copy to /etc/prometheus/rules/{{ slug }}.yml
# Then reload: curl -X POST http://prometheus:9090/-/reload

groups:
  - name: {{ slug }}-alerts
    rules:

      # ── Availability ──

      - alert: HighErrorRate
        expr: |
          (
            sum(rate(http_server_request_duration_seconds_count{service="{{ slug }}", http_status_code=~"5.."}[5m]))
            /
            sum(rate(http_server_request_duration_seconds_count{service="{{ slug }}"}[5m]))
          ) > 0.01
        for: 5m
        labels:
          severity: critical
          service: {{ slug }}
        annotations:
          summary: "{{ solution_name }} error rate > 1%"
          description: "{% raw %}{{ $value | humanizePercentage }}{% endraw %} of requests returning 5xx over the last 5 minutes."
          runbook: "Check application logs: kubectl logs -l app={{ slug }} --tail=100"

      - alert: ServiceDown
        expr: up{service="{{ slug }}"} == 0
        for: 2m
        labels:
          severity: critical
          service: {{ slug }}
        annotations:
          summary: "{{ solution_name }} is down"
          description: "No healthy instances for 2+ minutes."
          runbook: "Check pod status: kubectl get pods -l app={{ slug }}"

      # ── Latency ──

      - alert: HighP99Latency
        expr: |
          histogram_quantile(0.99,
            sum(rate(http_server_request_duration_seconds_bucket{service="{{ slug }}"}[5m])) by (le)
          ) > 2
        for: 5m
        labels:
          severity: warning
          service: {{ slug }}
        annotations:
          summary: "{{ solution_name }} p99 latency > 2s"
          description: "{% raw %}p99 latency is {{ $value | humanizeDuration }}{% endraw %}."
          runbook: "Check slow queries: review database slow query log and OpenTelemetry traces."

      - alert: HighP50Latency
        expr: |
          histogram_quantile(0.50,
            sum(rate(http_server_request_duration_seconds_bucket{service="{{ slug }}"}[5m])) by (le)
          ) > 0.5
        for: 10m
        labels:
          severity: warning
          service: {{ slug }}
        annotations:
          summary: "{{ solution_name }} median latency > 500ms"
          description: "Median request latency is elevated. May indicate database or external service issues."

      # ── Resources ──

      - alert: HighCPUUsage
        expr: |
          (
            sum(rate(container_cpu_usage_seconds_total{container="{{ slug }}"}[5m]))
            /
            sum(kube_pod_container_resource_limits{container="{{ slug }}", resource="cpu"})
          ) > 0.80
        for: 10m
        labels:
          severity: warning
          service: {{ slug }}
        annotations:
          summary: "{{ solution_name }} CPU > 80%"
          description: "Consider scaling up or optimizing hot paths."

      - alert: HighMemoryUsage
        expr: |
          (
            sum(container_memory_working_set_bytes{container="{{ slug }}"})
            /
            sum(kube_pod_container_resource_limits{container="{{ slug }}", resource="memory"})
          ) > 0.85
        for: 10m
        labels:
          severity: warning
          service: {{ slug }}
        annotations:
          summary: "{{ solution_name }} memory > 85%"
          description: "Memory usage approaching limit. Check for leaks or increase limits."

      - alert: DiskUsageHigh
        expr: |
          (
            sum(container_fs_usage_bytes{container="{{ slug }}"})
            /
            sum(container_fs_limit_bytes{container="{{ slug }}"})
          ) > 0.80
        for: 15m
        labels:
          severity: warning
          service: {{ slug }}
        annotations:
          summary: "{{ solution_name }} disk > 80%"
          description: "Disk usage high. Check log rotation and data cleanup policies."

      # ── Database ──

      - alert: DatabaseConnectionPoolExhausted
        expr: |
          sqlalchemy_pool_checked_out{service="{{ slug }}"}
          >=
          sqlalchemy_pool_size{service="{{ slug }}"}
        for: 5m
        labels:
          severity: critical
          service: {{ slug }}
        annotations:
          summary: "{{ solution_name }} DB connection pool exhausted"
          description: "All database connections are in use. Queries will start failing."
          runbook: "Increase pool_size or investigate long-running queries."

      - alert: SlowDatabaseQueries
        expr: |
          histogram_quantile(0.99,
            sum(rate(db_client_operation_duration_seconds_bucket{service="{{ slug }}"}[5m])) by (le)
          ) > 1
        for: 5m
        labels:
          severity: warning
          service: {{ slug }}
        annotations:
          summary: "{{ solution_name }} slow DB queries (p99 > 1s)"
          description: "Database query p99 latency exceeds 1 second. Check query plans and indexes."

      # ── Security ──

      - alert: HighAuthFailureRate
        expr: |
          sum(rate(http_server_request_duration_seconds_count{service="{{ slug }}", http_status_code="401"}[5m]))
          > 10
        for: 5m
        labels:
          severity: warning
          service: {{ slug }}
        annotations:
          summary: "{{ solution_name }} high auth failure rate"
          description: "More than 10 auth failures per second. Possible brute force attempt."
          runbook: "Check auth logs and consider IP blocking."

      - alert: HighRateLimitHits
        expr: |
          sum(rate(http_server_request_duration_seconds_count{service="{{ slug }}", http_status_code="429"}[5m]))
          > 5
        for: 5m
        labels:
          severity: info
          service: {{ slug }}
        annotations:
          summary: "{{ solution_name }} rate limiting active"
          description: "Clients being rate limited. May indicate abuse or undersized limits."
